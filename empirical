def force_no_unk_safeguards(payload: Dict[str, Any]) -> Dict[str, Any]:
    """Preserve unresolved safeguard values instead of coercing them to PART.

    Downstream scoring already treats UNK as mid-severity where needed, so mutating the
    saved/displayed safeguard matrix here only hides extraction uncertainty.
    """
    safeguard_keys = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]

    for k in safeguard_keys:
        v = str(payload.get(k, "UNK") or "UNK").upper().strip()
        payload[k] = v if v else "UNK"

    v = str(payload.get("RemedyEffectiveness", "UNK") or "UNK").upper().strip()
    payload["RemedyEffectiveness"] = v if v else "UNK"

    return payload


def _base_case_from_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    return {
        "Case_ID": str(payload.get("Case_ID", "") or "").strip(),
        "App_No": str(payload.get("App_No", "") or "").strip(),
        "Year": int(payload.get("Year", 0) or 0),
        "Chamber": str(payload.get("Chamber", "CH") or "CH"),
    }


def reanalyze_human_case(payload: Dict[str, Any]) -> Dict[str, Any]:
    """Recompute derived human-case analysis and keep the result persistable."""
    existing = dict(payload or {})
    base_case = _base_case_from_payload(existing)
    subunit_id = str(existing.get("SubUnit_ID", "NA") or "NA").strip().upper() or "NA"

    source_text = _normalize_human_source_text(_coerce_text(existing.get("_offline_full_text") or existing.get("_human_full_text") or ""))
    source_path = str(existing.get("_offline_source_path", "") or "").strip()

    if len(source_text.strip()) < 200 and source_path:
        if not _OFFLINE_OK:
            raise RuntimeError("Offline extraction dependencies are unavailable for stored case pack reanalysis.")
        if not os.path.exists(source_path):
            raise RuntimeError(f"Stored case pack path not found: {source_path}")
        source_text = _normalize_human_source_text(extract_text_from_path(source_path))
        existing["_offline_full_text"] = source_text
        existing["_human_full_text"] = source_text

    if len(source_text.strip()) < 200 and not source_path:
        guessed_casepack = _find_saved_casepack_path(base_case.get("Case_ID", ""), subunit_id)
        if guessed_casepack:
            source_path = guessed_casepack
            if not _OFFLINE_OK:
                raise RuntimeError("Offline extraction dependencies are unavailable for local case-pack reanalysis.")
            source_text = _normalize_human_source_text(extract_text_from_path(source_path))
            existing["_offline_source_path"] = source_path
            existing["_offline_full_text"] = source_text
            existing["_human_full_text"] = source_text

    if source_path and len(source_text.strip()) >= 200:
        refreshed = build_or_update_payload_from_offline(
            base_case=base_case,
            subunit_id=subunit_id,
            extracted_text=source_text,
            source_path=source_path,
        )
    elif len(source_text.strip()) >= 200:
        refreshed = dict(existing)
        probe = " ".join([base_case.get("Case_ID", ""), base_case.get("App_No", ""), source_text[:12000]])
        refreshed["InterferenceType_Primary"] = infer_interference_type(probe)
        refreshed["ReviewPosture"] = infer_review_posture(probe)
        refreshed["ContextTrigger"] = infer_context_trigger(probe)
        refreshed["AI_FactsBlock"] = extract_facts_block(source_text)
        conclusion = _coerce_text(existing.get("_hudoc_conclusion", "") or "")
        refreshed.update(autocode_safeguards_and_flags(conclusion, source_text))
        refreshed["_human_full_text"] = source_text
        refreshed["TurningPoint_1Sentence"] = extract_turning_point(conclusion, source_text)
        refreshed = apply_human_ground_truth_and_factors(refreshed, source_text, set_outcome=False)
        refreshed.setdefault("_autofill_notes", [])
        refreshed["_autofill_notes"].append("Saved human analysis re-run from stored source text.")
        refreshed["ClusterKey_Core"] = (
            f"{refreshed.get('InterferenceType_Primary','')}_{refreshed.get('ReviewPosture','')}_{refreshed.get('ContextTrigger','')}"
        )
        refreshed = force_no_unk_safeguards(refreshed)
    elif _HUDOC_OK:
        refreshed = recompute_autofill(base_case, subunit_id)
        refreshed.setdefault("_autofill_notes", [])
        refreshed["_autofill_notes"].append("Saved human analysis re-run via HUDOC refresh.")
    else:
        raise RuntimeError("No stored source text available for reanalysis, and HUDOC refresh is unavailable.")

    merged = dict(existing)
    merged.update(refreshed)
    return merged


def human_case_needs_refresh(payload: Dict[str, Any]) -> bool:
    try:
        schema_version = int(payload.get("_human_autocode_schema_version", 0) or 0)
    except Exception:
        schema_version = 0
    if schema_version < int(HUMAN_AUTOCODE_SCHEMA_VERSION):
        return True
    safeguard_keys = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]
    vals = [str(payload.get(k, "") or "").upper().strip() for k in safeguard_keys]
    short_text = not bool(_get_source_text(payload))
    flat_part = bool(vals) and all(v == "PART" for v in vals)
    all_unk = bool(vals) and all(v == "UNK" for v in vals)
    default_driver = str(payload.get("PrimaryDriver", "SG") or "SG").upper().strip() == "SG"
    missing_gt = any(k not in payload for k, _label in GT_CHECKS)
    missing_steps = any(k not in payload for k in HUMAN_LINE_STEPS)
    step_values = [int(payload.get(k, 1) or 1) for k in HUMAN_LINE_STEPS]
    all_steps_one = bool(step_values) and all(v == 1 for v in step_values)
    evidence = payload.get("_autocode_evidence") if isinstance(payload.get("_autocode_evidence"), dict) else {}
    evidence_hits = sum(1 for k in safeguard_keys if evidence.get(k))
    legacy_empty_autocode = all_unk and all_steps_one and evidence_hits == 0
    return short_text or (flat_part and default_driver) or legacy_empty_autocode or missing_gt or missing_steps


def refresh_and_save_human_cases(rows: List[Dict[str, Any]], *, only_stale: bool = False) -> Dict[str, Any]:
    targets = [r for r in rows if (human_case_needs_refresh(r) if only_stale else True)]
    if not targets:
        return {"ok": 0, "failed": [], "total": 0}
    ok = 0
    failed: List[str] = []
    for row in targets:
        label = f"{row.get('Case_ID', '?')} [{row.get('SubUnit_ID', 'NA')}]"
        try:
            refreshed = reanalyze_human_case(row)
            save_case(refreshed)
            ok += 1
        except Exception as e:
            failed.append(f"{label}: {e}")
    return {"ok": ok, "failed": failed, "total": len(targets)}


def _saved_human_cases_signature() -> Tuple[Tuple[str, int, int], ...]:
    sig: List[Tuple[str, int, int]] = []
    for fn in list_saved():
        path = os.path.join(DATA_DIR, fn)
        try:
            stat = os.stat(path)
            sig.append((fn, int(stat.st_mtime_ns), int(stat.st_size)))
        except Exception:
            sig.append((fn, 0, 0))
    sig.sort()
    return tuple(sig)


def _ensure_human_cases_autorefreshed_on_startup() -> None:
    current_sig = _saved_human_cases_signature()
    if st.session_state.get("_human_autorefresh_signature") == current_sig:
        resume_subpage = str(st.session_state.get("_resume_subpage_after_autorefresh", "") or "").strip()
        if resume_subpage:
            remaining_stale = [r for r in load_all_rows() if human_case_needs_refresh(r)]
            if not remaining_stale:
                st.session_state["app_subpage"] = resume_subpage
                st.session_state.pop("_resume_subpage_after_autorefresh", None)
                st.rerun()
        return

    rows = load_all_rows()
    stale_rows = [r for r in rows if human_case_needs_refresh(r)]
    if not stale_rows:
        st.session_state["_human_autorefresh_signature"] = current_sig
        st.session_state["_human_autorefresh_result"] = {"ok": 0, "failed": [], "total": 0, "skipped": len(rows)}
        resume_subpage = str(st.session_state.get("_resume_subpage_after_autorefresh", "") or "").strip()
        if resume_subpage:
            st.session_state["app_subpage"] = resume_subpage
            st.session_state.pop("_resume_subpage_after_autorefresh", None)
            st.rerun()
        return

    with st.spinner(f"Refreshing saved human-case extraction for {len(stale_rows)} dossier(s)..."):
        res = refresh_and_save_human_cases(rows, only_stale=True)

    st.session_state["_human_autorefresh_signature"] = _saved_human_cases_signature()
    st.session_state["_human_autorefresh_result"] = dict(res)
