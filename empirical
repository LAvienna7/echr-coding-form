def infer_subunit_from_filename(filename: str) -> str:
    s = (filename or "").lower()
    # Common markers: (A), _A, __A, subunit a, regime a
    for su in ["a", "b", "c"]:
        if re.search(rf"(?:\(|\[|_|-|__|\s){su}(?:\)|\]|_|-|__|\s|$)", s):
            return su.upper()
        if re.search(rf"sub\s*unit\s*{su}\b", s) or re.search(rf"subunit\s*{su}\b", s):
            return su.upper()
        if re.search(rf"regime\s*{su}\b", s):
            return su.upper()
    return "NA"


def _norm_for_match(s: str) -> str:
    s = (s or "").lower()
    s = os.path.splitext(s)[0]
    s = s.replace("v.", "v").replace("vs.", "v").replace("vs", "v")
    s = s.replace("’", "'")
    s = re.sub(r"[^a-z0-9\s/]", " ", s)
    s = re.sub(r"[_\-]+", " ", s)
    s = re.sub(r"\s+", " ", s).strip()
    return s


def _case_match_score(filename: str, case: Dict[str, Any]) -> Tuple[int, str]:
    """Return (score, reason). Higher is better."""
    fn = _norm_for_match(filename)

    cid = str(case.get("Case_ID", "") or "")
    app = str(case.get("App_No", "") or "")
    cid_norm = _norm_for_match(cid)

    # App numbers can be multiple, separated by commas/&
    appnos = split_appnos(app)

    # Strongest: appno appears in filename (support /, -, _ variants)
    fn_compact = re.sub(r"\s+", "", fn)
    for a in appnos:
        a0 = (a or "").strip()
        if not a0:
            continue
        a_compact = re.sub(r"\s+", "", a0.lower())
        a_dash = a_compact.replace("/", "-")
        a_us = a_compact.replace("/", "_")
        if a_compact in fn_compact or a_dash in fn_compact or a_us in fn_compact:
            return (2000 + len(a_compact), f"matched appno {a0}")

    # Next: Case_ID substring match
    if cid_norm and cid_norm in fn:
        return (1200 + len(cid_norm), "Case_ID substring match")

    # Token overlap heuristic, excluding generic words that cause systematic misassignment
    stop = {
        "v", "and", "others", "the", "of", "in", "on", "for", "to",
        "united", "kingdom", "france", "germany", "switzerland", "russia",
        "sweden", "hungary", "croatia", "bulgaria", "poland", "czech", "republic",
        "case", "judgment", "decision", "application", "app", "no", "echr",
        "article", "art", "pack", "bundle", "file", "pdf", "docx",
    }

    fn_tokens = [t for t in fn.split(" ") if t and t not in stop]
    cid_tokens = [t for t in cid_norm.split(" ") if t and t not in stop]

    if not cid_tokens:
        return (0, "no distinctive Case_ID tokens")

    fn_set = set(fn_tokens)
    cid_set = set(cid_tokens)
    overlap = len(fn_set.intersection(cid_set))

    # Require at least 2 distinctive tokens to avoid matching everything with "United Kingdom"
    if overlap < 2:
        return (0, f"low distinctive token overlap ({overlap})")

    score = 300 + 80 * overlap + min(200, 4 * sum(len(t) for t in cid_set.intersection(fn_set))) - max(0, len(fn_set) - overlap)
    return (score, f"distinctive token overlap {overlap}")


def resolve_case_for_filename(
    filename: str,
    cases: List[Dict[str, Any]],
) -> Tuple[Optional[Dict[str, Any]], str, str, int]:
    """Return (best_case_or_None, inferred_subunit, reason, score)."""
    sub = infer_subunit_from_filename(filename)

    best: Optional[Dict[str, Any]] = None
    best_score = -1
    best_reason = "no match"

    for c in cases:
        sc, rsn = _case_match_score(filename, c)
        if sc > best_score:
            best_score = sc
            best_reason = rsn
            best = c

    # Minimal confidence threshold
    # AppNo matches score ~2000+, Case_ID substring ~1200+, token overlap starts ~300.
    if best_score < 300:
        return (None, sub, "no confident match", best_score)

    return (best, sub, best_reason, best_score)


@st.cache_data(show_spinner=False)
def hudoc_lookup_from_case(case_id: str, appno_raw: str) -> Dict[str, Any]:
    if not _HUDOC_OK:
        return {"_status": "deps_missing"}

    for a in split_appnos(appno_raw):
        hit = hudoc_lookup_by_appno(a)
        if hit.get("_status") == "ok":
            hit["_matched_appno"] = a
            return hit

    try:
        q = f'docname:"{case_id}" AND (documentcollectionid:"JUDGMENTS" OR documentcollectionid:"DECISIONS")'
        df = get_echr(query_payload=q, language=["ENG"], fields=HUDOC_FIELDS, save_file="n")
        if df is not None and not getattr(df, "empty", True):
            recs = df.to_dict(orient="records")

            def _rank_row(r: Dict[str, Any]) -> tuple:
                coll = (r.get("documentcollectionid") or "").upper()
                coll_rank = 0 if coll == "JUDGMENTS" else 1
                kp = r.get("kpdate") or r.get("decisiondate") or ""
                dt = dateparse(str(kp)) if dateparse else None
                ts = -(dt.timestamp()) if dt else 0
                return (coll_rank, ts)

            recs.sort(key=_rank_row)
            best = recs[0]

            try:
                itemid = str(best.get("itemid", "") or "").strip()

                ft_conv = fetch_hudoc_conversion_text(itemid)

                ft_extra = ""
                try:
                    url = f"https://hudoc.echr.coe.int/eng?i={itemid}"
                    _df2, full_texts = get_echr_extra(link=url, language=["ENG"], fields=HUDOC_FIELDS, save_file="n")
                    ft_extra = _coerce_text(full_texts)
                except Exception:
                    ft_extra = ""

                ft_conv = _normalize_human_source_text(ft_conv)
                ft_extra = _normalize_human_source_text(ft_extra)
                ft = ft_conv if len(ft_conv.strip()) >= len(ft_extra.strip()) else ft_extra
                best["_full_text"] = ft
            except Exception:
                best["_full_text"] = ""

            best["_status"] = "ok"
            best["_matched_appno"] = best.get("appno")
            return best
    except Exception:
        pass

    return {"_status": "not_found"}


def pick_yesno(yes_hits: int, no_hits: int) -> str:
    if yes_hits == 0 and no_hits == 0:
        return "UNK"
    if yes_hits > 0 and no_hits == 0:
        return "YES"
    if no_hits > 0 and yes_hits == 0:
        return "NO"
    return "PART"


def find_snippets(text: str, patterns: List[str], window: int = 160, max_snips: int = 3) -> List[str]:
    if not text:
        return []
    t = re.sub(r"\s+", " ", text)
    out: List[str] = []
    for pat in patterns:
        try:
            for m in re.finditer(pat, t, flags=re.IGNORECASE):
                a = max(0, m.start() - window)
                b = min(len(t), m.end() + window)
                snip = t[a:b].strip()
                if snip and snip not in out:
                    out.append(snip)
                if len(out) >= max_snips:
                    return out
        except re.error:
            continue
    return out


def find_snippets_in_sources(
    sources: List[str],
    patterns: List[str],
    *,
    window: int = 160,
    max_snips: int = 3,
) -> List[str]:
    """Search multiple text blocks in priority order and deduplicate snippets."""
    out: List[str] = []
    seen = set()
    for src in sources:
        for snip in find_snippets(src, patterns, window=window, max_snips=max_snips):
            key = re.sub(r"\s+", " ", str(snip or "")).strip()
            if not key or key in seen:
                continue
            seen.add(key)
            out.append(key)
            if len(out) >= max_snips:
                return out
    return out


def _unique_text_sources(*groups: List[str]) -> List[str]:
    out: List[str] = []
    seen = set()
    for group in groups:
        for src in group:
            txt = _coerce_text(src).strip()
            if not txt:
                continue
            key = txt[:500]
            if key in seen:
                continue
            seen.add(key)
            out.append(txt)
    return out


def _merge_unique_snippets(*groups: List[str]) -> List[str]:
    out: List[str] = []
    seen = set()
    for group in groups:
        for snip in group:
            key = re.sub(r"\s+", " ", str(snip or "")).strip()
            if not key or key in seen:
                continue
            seen.add(key)
            out.append(key)
    return out


def _weighted_pick_yesno(
    yes_primary: List[str],
    no_primary: List[str],
    yes_secondary: List[str],
    no_secondary: List[str],
) -> str:
    yes_score = (2 * len(yes_primary)) + len(yes_secondary)
    no_score = (2 * len(no_primary)) + len(no_secondary)
    if yes_score == 0 and no_score == 0:
        return "UNK"
    if yes_score > 0 and no_score == 0:
        return "YES"
    if no_score > 0 and yes_score == 0:
        return "NO"
    if yes_score >= (2 * no_score):
        return "YES"
    if no_score >= (2 * yes_score):
        return "NO"
    return "PART"


def _classify_yesno_from_sources(
    primary_sources: List[str],
    secondary_sources: List[str],
    yes_patterns: List[str],
    no_patterns: Optional[List[str]] = None,
    *,
    max_primary: int = 4,
    max_secondary: int = 3,
) -> Tuple[str, List[str], Dict[str, int]]:
    no_patterns = list(no_patterns or [])
    yes_primary = find_snippets_in_sources(primary_sources, yes_patterns, max_snips=max_primary) if yes_patterns else []
    no_primary = find_snippets_in_sources(primary_sources, no_patterns, max_snips=max_primary) if no_patterns else []
    yes_secondary = find_snippets_in_sources(secondary_sources, yes_patterns, max_snips=max_secondary) if yes_patterns else []
    no_secondary = find_snippets_in_sources(secondary_sources, no_patterns, max_snips=max_secondary) if no_patterns else []
    label = _weighted_pick_yesno(yes_primary, no_primary, yes_secondary, no_secondary)
    evidence = _merge_unique_snippets(yes_primary, no_primary, yes_secondary, no_secondary)
    detail = {
        "yes_primary": len(yes_primary),
        "no_primary": len(no_primary),
        "yes_secondary": len(yes_secondary),
        "no_secondary": len(no_secondary),
    }
    return label, evidence, detail


def autocode_safeguards_and_flags(conclusion: str, full_text: str) -> Dict[str, Any]:
    clean_full_text = _normalize_human_source_text(full_text or "")
    text = (conclusion or "") + ("\n" + clean_full_text if clean_full_text else "")
    sec = extract_sections_text(text)
    law_text = _coerce_text(sec.get("law") or "")
    operative_text = _coerce_text(sec.get("operative") or "")
    facts_text = _coerce_text(sec.get("facts") or "")
    raw_text = _coerce_text(text)

    reasoning_text = law_text if len(law_text.strip()) >= 250 else raw_text
    primary_sources = _unique_text_sources([reasoning_text], [operative_text])
    secondary_sources = _unique_text_sources([facts_text], [raw_text])
    preferred_sources = _unique_text_sources(primary_sources, secondary_sources)
    decision_primary_sources = _unique_text_sources([operative_text], [reasoning_text])
    decision_secondary_sources = _unique_text_sources([facts_text], [raw_text])
    decision_sources = _unique_text_sources(decision_primary_sources, decision_secondary_sources)
    lower = "\n".join(decision_sources).lower()
    evidence: Dict[str, List[str]] = {}

    if not clean_full_text:
        if "journalist" in lower or "article 10" in lower or "freedom of expression" in lower:
            flag_journalist = 1
        else:
            flag_journalist = 0
        if "lawyer" in lower or "legal professional privilege" in lower or "privileged" in lower:
            flag_lawyer = 1
        else:
