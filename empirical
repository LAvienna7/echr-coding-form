def _norm_case_id_for_match(s: str) -> str:
    s0 = str(s or "").lower()
    s0 = re.sub(r"^case\s+of\s+", "", s0)
    s0 = re.sub(r"\band\s+others?\b", " ", s0)
    s0 = re.sub(r"\band\s+other\b", " ", s0)
    s0 = s0.replace("_", " ").replace("-", " ")
    s0 = re.sub(r"[^a-z0-9\s]+", " ", s0)
    s0 = re.sub(r"\s+", " ", s0).strip()
    return s0


def _norm_appno(s: str) -> str:
    return re.sub(r"\D+", "", str(s or ""))


def _extract_appno_candidates(text: str) -> List[str]:
    raw = str(text or "")
    hits = set()
    for m in re.findall(r"\b\d{1,6}/\d{2}\b", raw):
        num = _norm_appno(m)
        if num:
            hits.add(f"appno:{num}")
    for m in re.findall(r"\b\d{5,7}\b", raw):
        num = _norm_appno(m)
        if num:
            hits.add(f"appno:{num}")
    return list(hits)


def _human_case_candidates_for_match(human_row: Dict[str, Any]) -> List[str]:
    candidates: List[str] = []
    case_id = human_row.get("Case_ID", "")
    if case_id:
        candidates.append(_norm_case_id_for_match(case_id))
    app_no = human_row.get("App_No", "")
    if app_no:
        candidates.append(f"appno:{_norm_appno(app_no)}")
    hudoc_app = human_row.get("_hudoc_matched_appno", "")
    if hudoc_app:
        candidates.append(f"appno:{_norm_appno(hudoc_app)}")
    candidates += _extract_appno_candidates(case_id)
    return [c for c in candidates if c and c != "appno:"]


def _robo_case_candidates_for_match(robo_item: Dict[str, Any]) -> List[str]:
    candidates: List[str] = []
    case_id = robo_item.get("InputPayload", {}).get("Case_ID", "")
    if case_id:
        candidates.append(_norm_case_id_for_match(case_id))
        candidates += _extract_appno_candidates(case_id)
    app_no = robo_item.get("InputPayload", {}).get("App_No", "")
    if app_no:
        candidates.append(f"appno:{_norm_appno(app_no)}")
    src = str(robo_item.get("SourceFilename", "") or "")
    if src:
        base = os.path.splitext(src)[0]
        candidates.append(_norm_case_id_for_match(base))
        candidates += _extract_appno_candidates(base)
    return [c for c in candidates if c]


def _subunit_match(human_su: str, robo_su: str) -> bool:
    hs = str(human_su or "").strip().upper()
    rs = str(robo_su or "").strip().upper()
    if not hs or hs == "NA":
        return True
    if not rs or rs == "NA":
        return True
    return hs == rs


def _candidate_match_score(human_cands: set, robo_cands: set) -> int:
    common = human_cands.intersection(robo_cands)
    if not common:
        return 0
    score = 0
    for c in common:
        if c.startswith("appno:"):
            score = max(score, 1)
        else:
            score = max(score, 2)
    return score


def _canonical_case_candidate(candidates: List[str]) -> str:
    vals = sorted({str(c or "").strip() for c in candidates if str(c or "").strip()})
    if not vals:
        return ""
    non_app = [c for c in vals if not c.startswith("appno:")]
    return non_app[0] if non_app else vals[0]


def _human_minority_share_to_variance(v: Any) -> float:
    try:
        m = float(v)
    except Exception:
        return 0.0
    m = min(max(m, 0.0), 0.5)
    return float(m * (1.0 - m))


def _llm_extract_human_fields(text: str) -> Dict[str, Any]:
    if not st.session_state.get("use_llm_human_extract", False):
        return {}
    api_key = st.session_state.get("llm_api_key") or os.getenv("OPENAI_API_KEY", "")
    if not api_key:
        return {"_llm_error": "missing_api_key"}

    cache = st.session_state.get("llm_human_cache")
    if not isinstance(cache, dict):
        cache = {}

    src = str(text or "")
    if not src.strip():
        return {"_llm_error": "empty_text"}

    key = hashlib.sha256(src.encode("utf-8", errors="ignore")).hexdigest()
    if key in cache:
        return cache[key]

    sec = extract_sections_text(src)
    chunks = []
    if sec.get("facts"):
        chunks.append("FACTS:\n" + str(sec.get("facts")))
    if sec.get("law"):
        chunks.append("LAW:\n" + str(sec.get("law")))
    if sec.get("operative"):
        chunks.append("OPERATIVE:\n" + str(sec.get("operative")))
    combined = "\n\n".join(chunks).strip()
    if not combined:
        combined = src
    combined = combined[:12000]

    system = (
        "You extract structured fields from Article 8 ECHR judgments. "
        "Return a single JSON object only. Use these codes:\n"
        "- Art8_Outcome: V, NV, or P\n"
        "- Safeguards: YES, NO, PART, or UNK\n"
        "- RemedyEffectiveness: EFF, LIM, NONE, or UNK\n"
        "- PrimaryDriver: SG, LWF, REM, or PROP\n"
        "- Human_TopFactor1/2/3: one of AUTH, OVERS, REVIEW, NOTICE, RETAIN, DESTROY, SELECTOR, SHARING, SCOPE, FORESEE, REMEDY, PROP, NA\n"
        "If unknown, return UNK (or NA for Human_TopFactor fields)."
    )
    user = (
        "Extract these fields from the text:\n"
        "- Art8_Outcome\n"
        "- Jury_ViolationVotes, Jury_NoViolationVotes, Jury_TotalVotes, Jury_MinorityVotes, Jury_MinorityShare\n"
        "- PrimaryDriver\n"
        "- Human_TopFactor1, Human_TopFactor2, Human_TopFactor3\n"
        "- IndepPriorAuth, ExecOnlyAuth, SelectorCategoriesConstrained, PersonLinkedSelectorsPreAuth, "
        "IndepOversight, ExPostReview, Notification, RetentionLimits, AccessLogging, DestructionRules, "
        "SharingRules_ForeignPartners, RemedyAccess, RemedyEffectiveness\n"
        "- Flag_Journalist, Flag_LawyerPrivilege, Flag_ThirdPartyCapture, Flag_CrossArticleGravity (0 or 1)\n\n"
        "Text:\n"
        f"{combined}"
    )

    payload = {
        "model": str(st.session_state.get("llm_model") or "gpt-4o-mini"),
        "messages": [{"role": "system", "content": system}, {"role": "user", "content": user}],
        "temperature": 0,
        "max_tokens": 800,
    }
    url = "https://api.openai.com/v1/chat/completions"
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(req, timeout=40) as resp:
            raw = resp.read().decode("utf-8", errors="ignore")
        j = json.loads(raw)
        content = (
            j.get("choices", [{}])[0]
            .get("message", {})
            .get("content", "")
        )
    except Exception:
        return {"_llm_error": "request_failed"}

    def _extract_json_blob(s: str) -> Dict[str, Any]:
        try:
            return json.loads(s)
        except Exception:
            pass
        try:
            m = re.search(r"\{.*\}", s, flags=re.DOTALL)
            if m:
                return json.loads(m.group(0))
        except Exception:
            pass
        return {}

    raw_obj = _extract_json_blob(content or "")
    if not isinstance(raw_obj, dict) or not raw_obj:
        return {"_llm_error": "parse_failed"}

    def _norm_outcome(v: Any) -> str:
        vv = str(v or "").upper().strip()
        if vv in ("V", "VIOLATION"):
            return "V"
        if vv in ("NV", "NO VIOLATION", "NO_VIOLATION", "NO-VIOLATION"):
            return "NV"
        if vv in ("P", "PENDING"):
            return "P"
        return "UNK"

    def _norm_yesno(v: Any) -> str:
        vv = str(v or "").upper().strip()
        if vv in YESNO_OPTIONS:
            return vv
        if vv in ("Y", "TRUE"):
            return "YES"
        if vv in ("N", "FALSE"):
            return "NO"
        if vv in ("PARTIAL", "MIXED"):
            return "PART"
        return "UNK"

    def _norm_remedy(v: Any) -> str:
        vv = str(v or "").upper().strip()
        if vv in ("EFF", "LIM", "NONE", "UNK"):
            return vv
        if vv in ("EFFECTIVE", "YES"):
            return "EFF"
        if vv in ("LIMITED", "PART"):
            return "LIM"
        if vv in ("NO", "INEFFECTIVE"):
            return "NONE"
        return "UNK"

    def _norm_factor(v: Any) -> str:
        vv = str(v or "").upper().strip()
        return vv if vv in FACTOR_SET else "NA"

    cleaned: Dict[str, Any] = {}
    cleaned["Art8_Outcome"] = _norm_outcome(raw_obj.get("Art8_Outcome"))
    cleaned["PrimaryDriver"] = str(raw_obj.get("PrimaryDriver", "") or "").upper().strip() or "SG"

    for k in [
        "Jury_ViolationVotes",
        "Jury_NoViolationVotes",
        "Jury_TotalVotes",
        "Jury_MinorityVotes",
    ]:
        try:
            cleaned[k] = int(raw_obj.get(k))  # type: ignore
        except Exception:
            pass
    try:
        cleaned["Jury_MinorityShare"] = float(raw_obj.get("Jury_MinorityShare"))
    except Exception:
        pass

    cleaned["Human_TopFactor1"] = _norm_factor(raw_obj.get("Human_TopFactor1"))
    cleaned["Human_TopFactor2"] = _norm_factor(raw_obj.get("Human_TopFactor2"))
    cleaned["Human_TopFactor3"] = _norm_factor(raw_obj.get("Human_TopFactor3"))

    for k in [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]:
        if k in raw_obj:
            cleaned[k] = _norm_yesno(raw_obj.get(k))
    if "RemedyEffectiveness" in raw_obj:
        cleaned["RemedyEffectiveness"] = _norm_remedy(raw_obj.get("RemedyEffectiveness"))

    for k in ["Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture", "Flag_CrossArticleGravity"]:
        try:
            cleaned[k] = 1 if int(raw_obj.get(k, 0)) else 0
        except Exception:
            cleaned[k] = 1 if str(raw_obj.get(k, "")).strip().lower() in ("1", "true", "yes") else 0

    cache[key] = cleaned
    st.session_state["llm_human_cache"] = cache
    return cleaned

