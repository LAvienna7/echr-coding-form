    ]
    ctx_hits = sum(1 for t in context_terms if t in lower)
    ctx_score = min(1.0, float(ctx_hits) / 6.0)

    # Minimal structured payload
    return {
        "IndepPriorAuth": IndepPriorAuth,
        "ExecOnlyAuth": ExecOnlyAuth,
        "IndepOversight": IndepOversight,
        "ExPostReview": ExPostReview,
        "Notification": Notification,
        "RetentionLimits": RetentionLimits,
        "AccessLogging": AccessLogging,
        "DestructionRules": DestructionRules,
        "SharingRules_ForeignPartners": SharingRules_ForeignPartners,
        "RemedyAccess": RemedyAccess,
        "RemedyEffectiveness": RemedyEffectiveness,
        "_rj_autocode_evidence": evidence,
        "_rj_context_score": ctx_score,
        "_rj_flags": {
            "Flag_Journalist": 1 if ("journalist" in lower or "article 10" in lower) else 0,
            "Flag_LawyerPrivilege": 1 if ("legal professional privilege" in lower or "lawyer" in lower) else 0,
            "Flag_ThirdPartyCapture": 1 if ("third party" in lower or "persons not targeted" in lower) else 0,
        },
    }


def rj_yesno_severity(v: Any) -> int:
    s = str(v or "").upper().strip()
    # deficit severity: YES=0, PART=1, UNK=0.5, NO=2
    if s == "YES":
        return 0
    if s == "NO":
        return 2
    if s == "PART":
        return 1
    return 0.5


def rj_field_yesno_severity(field: str, v: Any) -> float:
    """Field-aware Robo deficit severity.

    `ExecOnlyAuth` is adverse when present, so its polarity is reversed.
    """
    s = str(v or "").upper().strip()
    if str(field or "").strip() == "ExecOnlyAuth":
        if s == "YES":
            return 2.0
        if s == "NO":
            return 0.0
        if s == "PART":
            return 1.0
        return 0.5
    return float(rj_yesno_severity(v))


def rj_remedy_severity(v: Any) -> int:
    s = str(v or "").upper().strip()
    # deficit severity: EFF=0, LIM/UNK=1, NONE=2
    if s == "EFF":
        return 0
    if s == "NONE":
        return 2
    if s == "LIM":
        return 1
    return 1


def _rj_clone_payload(payload: Dict[str, Any]) -> Dict[str, Any]:
    cloned = dict(payload or {})
    flags = payload.get("_rj_flags", {}) if isinstance(payload.get("_rj_flags", {}), dict) else {}
    evidence = payload.get("_rj_autocode_evidence", {}) if isinstance(payload.get("_rj_autocode_evidence", {}), dict) else {}
    cloned["_rj_flags"] = dict(flags)
    cloned["_rj_autocode_evidence"] = {
        str(k): list(v) if isinstance(v, list) else ([str(v)] if v else [])
        for k, v in evidence.items()
    }
    return cloned


def _rj_component_max_contribution(component: str) -> float:
    if component in ROBO_RULE_WEIGHTS:
        return 2.0 * float(ROBO_RULE_WEIGHTS.get(component, 0.0) or 0.0)
    if component in ROBO_FLAG_WEIGHTS:
        return float(ROBO_FLAG_WEIGHTS.get(component, 0.0) or 0.0)
    if component == "ContextSeverity":
        return 1.0
    return 0.0


def _rj_discretion_weight(raw_contribution: float, max_contribution: float) -> int:
    if raw_contribution <= 0.0 or max_contribution <= 0.0:
        return 0
    ratio = float(raw_contribution) / float(max_contribution)
    if ratio <= (1.0 / 3.0):
        return 1
    if ratio <= (2.0 / 3.0):
        return 2
    return 3


def _rj_factor_citation(payload: Dict[str, Any], factor: str) -> str:
    meta = ROBO_DISCRETION_FACTOR_META.get(factor, {})
    evidence = payload.get("_rj_autocode_evidence", {}) if isinstance(payload.get("_rj_autocode_evidence", {}), dict) else {}
    for feature in meta.get("features", []):
        snips = evidence.get(feature) or []
        if snips:
            return str(snips[0])

    dossier_text = str(payload.get("_rj_dossier_text") or "")
    if dossier_text:
        sec = extract_sections_text(dossier_text)
        search_sources = [
            str(sec.get("law") or ""),
            str(sec.get("facts") or ""),
            dossier_text,
        ]
        pats = meta.get("patterns", []) or []
        for src in search_sources:
            snips = rj_find_snippets(src, pats, max_snips=1)
            if snips:
                return str(snips[0])
    return "(no citation located)"


def _rj_weight_entropy(factor_weights: Dict[str, Dict[str, Any]]) -> float:
    vals = [max(0.0, float((factor_weights.get(f) or {}).get("weight", 0) or 0)) for f in ROBO_DISCRETION_FACTORS]
    total = sum(vals)
    if total <= 0.0:
        return 0.0
    ent = 0.0
    for val in vals:
        if val <= 0.0:
            continue
        p = float(val) / float(total)
        ent -= p * math.log(p, 2)
    denom = math.log(max(2, len(vals)), 2)
    return float(round(ent / denom, 6)) if denom > 0 else 0.0


def _rj_population_variance(values: List[float]) -> float:
    if not values:
        return 0.0
    mean = sum(values) / float(len(values))
    return float(sum((float(v) - mean) ** 2 for v in values) / float(len(values)))


def _rj_pick_representative_run(runs: List[Dict[str, Any]], modal_outcome: str) -> Optional[Dict[str, Any]]:
    if not runs:
        return None
    modal = str(modal_outcome or "").upper().strip()
    modal_matches = [r for r in runs if str(r.get("RoboOutcome", "") or "").upper().strip() == modal]
    candidates = modal_matches if modal_matches else runs
    rep = None
    best_dist = float("inf")
    for run in candidates:
        threshold = float(run.get("DecisionThreshold", ROBO_BASE_THRESHOLD) or ROBO_BASE_THRESHOLD)
        score = float(run.get("DecisionScore", threshold) or threshold)
        dist = abs(score - threshold)
        if rep is None or dist < best_dist:
            rep = run
            best_dist = dist
    return rep


def _rj_score_breakdown(payload: Dict[str, Any]) -> Dict[str, Any]:
    weights = dict(ROBO_RULE_WEIGHTS)
    evidence = payload.get("_rj_autocode_evidence") or {}
    evidence_keys = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
        "RemedyEffectiveness",
    ]
    evidence_hits = sum(1 for k in evidence_keys if (evidence.get(k) or []))
    evidence_coverage = float(evidence_hits) / float(len(evidence_keys)) if evidence_keys else 0.0
    scale_multiplier = 0.6 + (0.4 * evidence_coverage)
    raw_components: List[Tuple[str, float]] = []
    raw_component_map: Dict[str, float] = {}
    severe_deficits = 0

    for k in [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]:
        sev = float(rj_field_yesno_severity(k, payload.get(k)))
        comp = sev * float(weights.get(k, 1.0))
        raw_component_map[k] = comp
        raw_components.append((k, comp))
        if sev >= 2.0:
            severe_deficits += 1

    rem = float(rj_remedy_severity(payload.get("RemedyEffectiveness"))) * float(weights.get("RemedyEffectiveness", 1.0))
    raw_component_map["RemedyEffectiveness"] = rem
    raw_components.append(("RemedyEffectiveness", rem))
    if rem >= float(weights.get("RemedyEffectiveness", 1.0)) * 2.0:
        severe_deficits += 1

    flags = payload.get("_rj_flags") or {}
    for fk, fw in ROBO_FLAG_WEIGHTS.items():
        comp = float(fw) if int(flags.get(fk, 0) or 0) == 1 else 0.0
        raw_component_map[fk] = comp
        if comp > 0.0:
            raw_components.append((fk, comp))

    ctx_score = min(1.0, max(0.0, float(payload.get("_rj_context_score", 0.0) or 0.0)))
    raw_component_map["ContextSeverity"] = ctx_score
    if ctx_score > 0.0:
        raw_components.append(("ContextSeverity", ctx_score))

    effective_components = [(k, float(v) * float(scale_multiplier)) for k, v in raw_components]
    effective_component_map = {k: (float(v) * float(scale_multiplier)) for k, v in raw_component_map.items()}
    raw_score = sum(float(v) for _k, v in raw_components)
    scaled_score = sum(float(v) for _k, v in effective_components)
    allow_violation = (severe_deficits >= 1) or (evidence_coverage >= 0.6)

    return {
        "evidence_coverage": float(evidence_coverage),
        "scale_multiplier": float(scale_multiplier),
        "raw_components": raw_components,
        "raw_component_map": raw_component_map,
        "effective_components": effective_components,
        "effective_component_map": effective_component_map,
        "raw_score": float(raw_score),
        "scaled_score": float(scaled_score),
        "severe_deficits": int(severe_deficits),
        "allow_violation": bool(allow_violation),
    }


def _rj_factor_weights_from_breakdown(payload: Dict[str, Any], breakdown: Dict[str, Any]) -> Dict[str, Dict[str, Any]]:
    raw_component_map = breakdown.get("raw_component_map", {}) if isinstance(breakdown.get("raw_component_map", {}), dict) else {}
    effective_component_map = breakdown.get("effective_component_map", {}) if isinstance(breakdown.get("effective_component_map", {}), dict) else {}
    out: Dict[str, Dict[str, Any]] = {}
    for factor in ROBO_DISCRETION_FACTORS:
        meta = ROBO_DISCRETION_FACTOR_META.get(factor, {})
        features = meta.get("features", []) or []
        raw_contribution = sum(float(raw_component_map.get(feature, 0.0) or 0.0) for feature in features)
        effective_contribution = sum(float(effective_component_map.get(feature, 0.0) or 0.0) for feature in features)
        max_contribution = sum(_rj_component_max_contribution(feature) for feature in features)
        out[factor] = {
            "label": str(meta.get("label", factor)),
            "weight": int(_rj_discretion_weight(raw_contribution, max_contribution)),
            "citation": _rj_factor_citation(payload, factor),
            "raw_contribution": float(round(raw_contribution, 6)),
            "effective_contribution": float(round(effective_contribution, 6)),
            "max_contribution": float(round(max_contribution, 6)),
            "mapped_features": list(features),
        }
    return out


def _rj_outcome_from_score(score: float, threshold: float, allow_violation: bool) -> Tuple[str, int]:
    is_violation = 1 if (float(score) >= float(threshold) and bool(allow_violation)) else 0
    return ("V" if is_violation else "NV", int(is_violation))


def _rj_outcome_sensitivity(
    factor_weights: Dict[str, Dict[str, Any]],
    baseline_score: float,
    threshold: float,
    baseline_outcome: str,
    allow_violation: bool,
) -> Dict[str, Any]:
    per_factor: List[Dict[str, Any]] = []
    flips = 0
    for factor in ROBO_DISCRETION_FACTORS:
        row = factor_weights.get(factor, {}) if isinstance(factor_weights.get(factor, {}), dict) else {}
        before_weight = int(row.get("weight", 0) or 0)
        after_weight = max(0, before_weight - 1)
        before_contrib = float(row.get("effective_contribution", 0.0) or 0.0)
        if before_weight > 0:
            after_contrib = before_contrib * (float(after_weight) / float(before_weight))
        else:
            after_contrib = before_contrib
        new_score = float(baseline_score) - before_contrib + after_contrib
        new_outcome, new_outcome_bin = _rj_outcome_from_score(new_score, threshold, allow_violation)
        flipped = 1 if str(new_outcome).upper() != str(baseline_outcome).upper() else 0
        flips += flipped
        per_factor.append({
            "factor": factor,
            "label": str(row.get("label", factor)),
            "citation": str(row.get("citation", "")),
            "weight_before": int(before_weight),
            "weight_after": int(after_weight),
            "score_before": float(round(float(baseline_score), 6)),
            "score_after": float(round(float(new_score), 6)),
            "threshold": float(round(float(threshold), 6)),
            "outcome_before": str(baseline_outcome).upper(),
            "outcome_after": str(new_outcome).upper(),
            "outcome_after_binary": int(new_outcome_bin),
            "flipped": int(flipped),
        })
    tested = len(per_factor) or 1
    return {
        "BaselineOutcome": str(baseline_outcome).upper(),
        "BaselineScore": float(round(float(baseline_score), 6)),
        "Threshold": float(round(float(threshold), 6)),
        "FactorsTested": int(len(per_factor)),
        "FlipRate": float(round(float(flips) / float(tested), 6)),
        "PerFactor": per_factor,
    }


def rj_rule_engine(payload: Dict[str, Any], seed: int, temperature: float) -> Dict[str, Any]:
    """Deterministic rule-engine with controlled randomness (temperature + seed)."""
    rnd = random.Random(int(seed))

    # Controlled randomness perturbs the decision threshold, not the evidence path.
    breakdown = _rj_score_breakdown(payload)
    evidence_coverage = float(breakdown.get("evidence_coverage", 0.0) or 0.0)
    severe_deficits = int(breakdown.get("severe_deficits", 0) or 0)
    raw_score = float(breakdown.get("raw_score", 0.0) or 0.0)
    score = float(breakdown.get("scaled_score", 0.0) or 0.0)
    scale_multiplier = float(breakdown.get("scale_multiplier", 1.0) or 1.0)
    allow_violation = bool(breakdown.get("allow_violation", False))
    raw_components = list(breakdown.get("raw_components", []) or [])
    components = list(breakdown.get("effective_components", []) or [])

    base_threshold = float(ROBO_BASE_THRESHOLD)
    # If evidence coverage is weak, raise threshold to avoid over-confident violations.
    threshold_guard = (1.0 - evidence_coverage) * 2.0
    noise = rnd.gauss(0.0, max(0.0001, float(temperature)) * 0.9)
    threshold = base_threshold + threshold_guard + noise

    # Decide
    outcome, is_violation = _rj_outcome_from_score(score, threshold, allow_violation)

    components.sort(key=lambda x: x[1], reverse=True)
    top_components = [(k, v) for k, v in components if v > 0][:3]
    top_reasons = [k for k, _v in top_components]
    factor_weights = _rj_factor_weights_from_breakdown(payload, breakdown)
    weight_entropy = _rj_weight_entropy(factor_weights)
    outcome_sensitivity = _rj_outcome_sensitivity(
        factor_weights=factor_weights,
        baseline_score=score,
        threshold=threshold,
        baseline_outcome=outcome,
        allow_violation=allow_violation,
    )
    top_factors = sorted(
        [
            (factor, float(meta.get("effective_contribution", 0.0) or 0.0))
            for factor, meta in factor_weights.items()
            if float(meta.get("effective_contribution", 0.0) or 0.0) > 0.0
        ],
        key=lambda kv: kv[1],
        reverse=True,
    )[:3]

    # Build an ECHR-like structured report (rule-based)
    safeguards_summary = ", ".join([f"{k}={payload.get(k,'UNK')}" for k in [
        "IndepPriorAuth","ExecOnlyAuth","IndepOversight","ExPostReview","Notification","RetentionLimits","AccessLogging","DestructionRules","SharingRules_ForeignPartners","RemedyAccess","RemedyEffectiveness"
    ]])
    dossier_text = str(payload.get("_rj_dossier_text") or "")
    sections = extract_sections_text(dossier_text)
    facts_text = sections.get("facts") or dossier_text
    facts_sents = re.split(r"(?<=[\.!\?])\s+", facts_text.strip())
    facts_summary = " ".join([s for s in facts_sents if s][:2]).strip()
    evidence_snips = payload.get("_rj_autocode_evidence") or {}
    top_evidence = []
    for k in top_reasons:
        snips = evidence_snips.get(k) or []
        if snips:
            top_evidence.append(f"{k}: {snips[0][:220]}")

    report = []
    report.append("THE FACTS")
    if facts_summary:
        report.append(facts_summary)
    else:
        report.append("The applicant complains of an interference with private life and or correspondence in the context of a surveillance or data-access measure. The case file provided is a cleaned dossier that excludes the Court’s outcome.")
    report.append("")
    report.append("THE LAW")
    report.append(ROBO_ARTICLE_8_TEXT)
    report.append("")
    report.append("Article 8 requires that any interference be in accordance with the law, pursue a legitimate aim, and be necessary in a democratic society. For surveillance-type measures, the quality of law and end-to-end safeguards are decisive, including independent prior authorisation or equivalent, independent oversight, ex post review, notification where possible, retention and destruction limits, and effective remedies.")
    report.append("")
    report.append("APPLICATION TO THE PRESENT CASE")
    report.append(f"Safeguards grid (heuristically extracted and or user-confirmed): {safeguards_summary}.")
    if top_reasons:
        report.append("Key deficits driving the decision: " + ", ".join(top_reasons) + ".")
        report.append(
            "Top contributions: "
            + ", ".join([f"{k}={round(v, 3)}" for k, v in top_components])
            + "."
        )
        if top_factors:
            report.append(
                "FactorWeights (0-3): "
                + ", ".join([f"{factor}={int(factor_weights.get(factor, {}).get('weight', 0))}" for factor, _v in top_factors])
                + "."
            )
        report.append(
            f"Evidence coverage={round(evidence_coverage,3)}; severe deficits={severe_deficits}; threshold guard={round(threshold_guard,3)}."
        )
    if top_evidence:
        report.append("Evidence highlights: " + " | ".join(top_evidence) + ".")
    else:
        report.append("No salient safeguards deficits were detected at the threshold used by the rule-engine.")
    report.append(f"Decision score={round(score, 3)}; threshold={round(threshold, 3)} (temperature={round(float(temperature),3)}, seed={int(seed)}).")
    report.append("")
    report.append("FOR THESE REASONS")
    report.append(f"The Robo-Judge finds: {('a violation of Article 8' if outcome=='V' else 'no violation of Article 8')}.")

    # Transparency payload
    out = {
        "RoboOutcome": outcome,
        "RoboOutcomeBinary": int(is_violation),
        "DecisionScore": float(round(score, 6)),
        "RawScore": float(round(raw_score, 6)),
        "DecisionThreshold": float(round(threshold, 6)),
        "ScoreScaleMultiplier": float(round(scale_multiplier, 6)),
        "EvidenceCoverage": float(round(evidence_coverage, 6)),
        "AllowViolation": int(allow_violation),
        "Temperature": float(round(float(temperature), 6)),
        "Seed": int(seed),
        "TopReasons": top_reasons,
        "TopFactors": [factor for factor, _v in top_factors],
        "Components": [{"factor": k, "contribution": float(round(v, 6))} for k, v in components],
        "RawComponents": [{"factor": k, "contribution": float(round(v, 6))} for k, v in raw_components],
        "FactorWeights": factor_weights,
        "WeightEntropy": float(weight_entropy),
        "OutcomeSensitivity": outcome_sensitivity,
        "ReportText": "\n".join(report),
    }
    return out


def rj_reason_stability(run_reasons: List[List[str]]) -> Dict[str, Any]:
    if not run_reasons:
        return {"Top1Modal": None, "Top1Share": 0.0, "AvgJaccardToModal": 0.0}

    # Top-1 modal share
    top1 = [r[0] for r in run_reasons if r]
    modal = None
    modal_share = 0.0
    if top1:
        counts: Dict[str, int] = {}
        for x in top1:
            counts[x] = counts.get(x, 0) + 1
        modal = max(counts.items(), key=lambda kv: kv[1])[0]
        modal_share = float(counts[modal]) / float(len(top1))

    # Modal set for Jaccard
    modal_set: set = set()
    if modal is not None:
        # take the first run that has this modal factor as top1 and use its full top3 set
        for rr in run_reasons:
            if rr and rr[0] == modal:
                modal_set = set(rr)
                break

    def jacc(a: set, b: set) -> float:
        if not a and not b:
            return 1.0
        if not a or not b:
            return 0.0
        return float(len(a.intersection(b))) / float(len(a.union(b)))

    js: List[float] = []
    for rr in run_reasons:
        js.append(jacc(set(rr), modal_set))

    return {
        "Top1Modal": modal,
        "Top1Share": float(round(modal_share, 4)),
        "AvgJaccardToModal": float(round(sum(js) / len(js), 4)) if js else 0.0,
    }


def rj_run_reruns(
    payload: Dict[str, Any],
    n: int,
    temperature: float,
    seed_mode: str,
    base_seed: int,
) -> Dict[str, Any]:
    n = max(1, int(n))
    base_seed = int(base_seed)

    runs: List[Dict[str, Any]] = []
    reasons: List[List[str]] = []

    for i in range(n):
        if seed_mode == "cycle":
            seed = base_seed + i
        else:
            # deterministic pseudo-random sequence derived from base_seed
            seed = int(random.Random(base_seed).randint(1, 10_000_000) + i)

        res = rj_rule_engine(payload, seed=seed, temperature=float(temperature))
        runs.append({
            "run": i + 1,
            "seed": res.get("Seed"),
            "temperature": res.get("Temperature"),
            "RoboOutcome": res.get("RoboOutcome"),
            "RoboOutcomeBinary": int(res.get("RoboOutcomeBinary") or 0),
            "DecisionScore": res.get("DecisionScore"),
            "RawScore": res.get("RawScore"),
            "DecisionThreshold": res.get("DecisionThreshold"),
            "ScoreScaleMultiplier": res.get("ScoreScaleMultiplier"),
            "EvidenceCoverage": res.get("EvidenceCoverage"),
            "AllowViolation": res.get("AllowViolation"),
            "TopReasons": res.get("TopReasons") or [],
            "TopFactors": res.get("TopFactors") or [],
            "ReportText": res.get("ReportText"),
            "Components": res.get("Components") or [],
            "RawComponents": res.get("RawComponents") or [],
            "FactorWeights": res.get("FactorWeights") or {},
            "WeightEntropy": res.get("WeightEntropy"),
            "OutcomeSensitivity": res.get("OutcomeSensitivity") or {},
        })
        reasons.append(list(res.get("TopReasons") or []))

    ys = [int(r.get("RoboOutcomeBinary") or 0) for r in runs]
    p = (sum(ys) / float(len(ys))) if ys else 0.0
    variance = p * (1.0 - p)
    disagreement = 1.0 - max(p, 1.0 - p)

    stab = rj_reason_stability(reasons)
    weight_variance_by_factor: Dict[str, float] = {}
    for factor in ROBO_DISCRETION_FACTORS:
        vals = [float((run.get("FactorWeights", {}).get(factor, {}) or {}).get("weight", 0) or 0) for run in runs]
        weight_variance_by_factor[factor] = float(round(_rj_population_variance(vals), 6))
    mean_weight_variance = (
        sum(weight_variance_by_factor.values()) / float(len(weight_variance_by_factor))
        if weight_variance_by_factor else 0.0
    )
    mean_weight_entropy = (
        sum(float(run.get("WeightEntropy", 0.0) or 0.0) for run in runs) / float(len(runs))
        if runs else 0.0
    )
    mean_flip_rate = (
        sum(float((run.get("OutcomeSensitivity", {}) or {}).get("FlipRate", 0.0) or 0.0) for run in runs) / float(len(runs))
        if runs else 0.0
    )

    # Pick modal outcome
    outcome = "V" if p >= 0.5 else "NV"

    return {
        "n": int(n),
        "p_violation": float(round(p, 6)),
        "RoboOutcomeVariance": float(round(variance, 6)),
        "RoboDisagreementRate": float(round(disagreement, 6)),
        "ModalOutcome": outcome,
        "ReasonStability": stab,
        "DiscretionWeightVariance": float(round(mean_weight_variance, 6)),
        "DiscretionWeightVarianceByFactor": weight_variance_by_factor,
        "DiscretionFlipRate": float(round(mean_flip_rate, 6)),
        "DiscretionFlipRat": float(round(mean_flip_rate, 6)),
        "MeanWeightEntropy": float(round(mean_weight_entropy, 6)),
        "runs": runs,
    }


# ----------------------------
# Robo-Judge Output Contract (Canonical JSON Schema)
# ----------------------------
# This standardized output format enables seamless integration with Pages 4 and 5.
# Every robo case must produce this structure.

def build_robo_contract_output(
    case_id: str,
    subunit_id: str,
    dossier_text: str,
    input_payload: Dict[str, Any],
    runs_output: Dict[str, Any],
    leakage_before: Dict[str, Any],
    leakage_after: Dict[str, Any],
) -> Dict[str, Any]:
    """
    Build the canonical Robo-Judge output contract.
    
    Structure:
    - meta: versioning, timestamps, hashes
    - verdict: outcome + confidence
    - decision_text: ECHR-style sections
    - reasoning_structured: factors + scores
    - evidence: citations + extracted elements
    - reruns: stability metrics
    - explainability: coverage and fidelity scores
    """
    import hashlib
    
    now = datetime.utcnow().isoformat()
    dossier_hash = hashlib.sha256(dossier_text.encode('utf-8', errors='ignore')).hexdigest()
    
    runs = runs_output.get("runs", [])
    modal_outcome = runs_output.get("ModalOutcome", "UNK")
    
    # Pick representative run
    rep_run = None
    modal_matches = [r for r in runs if str(r.get("RoboOutcome")) == modal_outcome]
    if modal_matches:
        threshold = float(modal_matches[0].get("DecisionThreshold", 0.5))
        best_dist = float('inf')
        for r in modal_matches:
            score = float(r.get("DecisionScore", threshold))
            dist = abs(score - threshold)
            if dist < best_dist:
                best_dist = dist
                rep_run = r
    elif runs:
        rep_run = runs[0]
    
    # Extract structure from dossier
    sections = extract_sections_text(dossier_text)
    facts = sections.get("facts", "")
    law = sections.get("law", "")
    
    # Build decisive factors
    decisive_factors = []
    factor_scores = {}
    factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run, dict) and isinstance(rep_run.get("FactorWeights", {}), dict) else {}
    if rep_run:
        for comp in rep_run.get("Components", []):
            factor = comp.get("factor")
            score = comp.get("contribution")
            if factor and score:
                decisive_factors.append(factor)
                factor_scores[factor] = float(score)
    
    # Build safeguards matrix
    safeguards_matrix = {}
    for key in [
        "IndepPriorAuth", "ExecOnlyAuth", "IndepOversight", "ExPostReview",
        "Notification", "RetentionLimits", "AccessLogging", "DestructionRules",
        "SharingRules_ForeignPartners", "RemedyAccess", "RemedyEffectiveness"
    ]:
        val = input_payload.get(key, "UNK")
        ev = (input_payload.get("_rj_autocode_evidence") or {}).get(key) or []
        safeguards_matrix[key] = {
            "flag": str(val),
            "snippet": ev[:1] if ev else (_evidence_backfill_snippets(law, key)[:1] if law else []),
        }
    
    contract = {
        "meta": {
            "case_id": str(case_id),
            "subunit_id": str(subunit_id),
            "timestamp": now,
            "model_version": "robo-judge-v1-heuristic",
            "ruleset_version": "art8-surveillance-v1",
            "dossier_hash": dossier_hash,
            "leakage_check_before": leakage_before,
            "leakage_check_after": leakage_after,
        },
        "verdict": {
            "outcome": modal_outcome,
            "confidence_score": float(runs_output.get("p_violation", 0.5)),
            "decision_text": rep_run.get("ReportText", "") if rep_run else "",
        },
        "reasoning_structured": {
            "decisive_factors": decisive_factors,
            "factor_scores": factor_scores,
            "factor_weights": factor_weights,
            "perturbation_test": rep_run.get("OutcomeSensitivity", {}) if rep_run else {},
            "safeguards_matrix": safeguards_matrix,
            "line_adherence": {
                "step_interference": 1,
                "step_lawfulness": 1,
                "step_legitimate_aim": 1,
                "step_necessity": 1,
            },
        },
        "evidence": {
            "citations": [
                {
                    "factor": factor,
                    "citation": str(meta.get("citation", "")),
                }
                for factor, meta in factor_weights.items()
            ],
            "extracted_elements": {
                "facts_len": len(facts),
                "law_len": len(law),
                "facts_summary": facts[:200] if facts else "",
                "law_summary": law[:200] if law else "",
            },
        },
        "reruns": {
            "runs": runs,
            "stability_metrics": {
                "p_violation": float(runs_output.get("p_violation", 0.0)),
                "outcome_variance": float(runs_output.get("RoboOutcomeVariance", 0.0)),
                "disagreement_rate": float(runs_output.get("RoboDisagreementRate", 0.0)),
                "discretion_weight_variance": float(runs_output.get("DiscretionWeightVariance", 0.0)),
                "discretion_flip_rate": float(runs_output.get("DiscretionFlipRate", 0.0)),
                "mean_weight_entropy": float(runs_output.get("MeanWeightEntropy", 0.0)),
                "reason_stability": runs_output.get("ReasonStability", {}),
            },
        },
        "explainability": {
            "structure_completeness": 0.0,
            "evidence_coverage_score": 0.0,
            "evidence_quality_score": 0.0,
            "doctrinal_fidelity_score": 0.0,
            "robustness_index": 0.0,
            "overall_explainability": 0.0,
            "claims_total": 0,
            "claims_with_citations": 0,
        },
    }

    try:
        metrics = compute_robo_explainability_metrics(contract, dossier_text)
        contract["explainability"] = {
            "structure_completeness": float(metrics.get("structure_completeness", 0.0)),
            "evidence_coverage_score": float(metrics.get("evidence_coverage_score", 0.0)),
            "evidence_quality_score": float(metrics.get("evidence_quality_score", 0.0)),
            "doctrinal_fidelity_score": float(metrics.get("doctrinal_fidelity_score", 0.0)),
            "robustness_index": float(metrics.get("robustness_index", 0.0)),
            "overall_explainability": float(metrics.get("overall_explainability", 0.0)),
            "claims_total": int(metrics.get("claims_total", 0) or 0),
            "claims_with_citations": int(metrics.get("claims_with_citations", 0) or 0),
        }
    except Exception:
        pass

    return contract


def rj_contract_to_legacy_format(contract: Dict[str, Any]) -> Dict[str, Any]:
    """Convert contract format back to legacy format for backward compatibility."""
    runs = contract.get("reruns", {}).get("runs", [])
    rep_run = None
    for r in runs:
        if str(r.get("RoboOutcome")) == contract.get("verdict", {}).get("outcome"):
            rep_run = r
            break
    if rep_run is None and runs:
        rep_run = runs[0]
    
    return {
        "InputPayload": {},
        "RunSummary": contract.get("reruns", {}).get("stability_metrics", {}),
        "RepresentativeRun": rep_run or {},
        "AllRuns": runs,
    }


def _rj_enrich_saved_item(item: Dict[str, Any]) -> Dict[str, Any]:
    if not isinstance(item, dict):
        return item
    payload = item.get("InputPayload", {}) if isinstance(item.get("InputPayload", {}), dict) else {}
    runs = item.get("AllRuns", []) if isinstance(item.get("AllRuns", []), list) else []
    if not payload or not runs:
        return item

    enriched_runs: List[Dict[str, Any]] = []
    reasons: List[List[str]] = []
    for idx, run in enumerate(runs):
        if not isinstance(run, dict):
            continue
        seed = int(run.get("seed", run.get("Seed", 1)) or 1)
        temp = float(run.get("temperature", run.get("Temperature", 0.0)) or 0.0)
        refreshed = rj_rule_engine(_rj_clone_payload(payload), seed=seed, temperature=temp)
        merged = dict(run)
        merged.update({
            "run": int(run.get("run", idx + 1) or (idx + 1)),
            "seed": refreshed.get("Seed"),
            "temperature": refreshed.get("Temperature"),
            "RoboOutcome": refreshed.get("RoboOutcome"),
            "RoboOutcomeBinary": int(refreshed.get("RoboOutcomeBinary") or 0),
            "DecisionScore": refreshed.get("DecisionScore"),
            "RawScore": refreshed.get("RawScore"),
            "DecisionThreshold": refreshed.get("DecisionThreshold"),
            "ScoreScaleMultiplier": refreshed.get("ScoreScaleMultiplier"),
            "EvidenceCoverage": refreshed.get("EvidenceCoverage"),
            "AllowViolation": refreshed.get("AllowViolation"),
            "TopReasons": refreshed.get("TopReasons") or [],
            "TopFactors": refreshed.get("TopFactors") or [],
            "Components": refreshed.get("Components") or [],
            "RawComponents": refreshed.get("RawComponents") or [],
            "FactorWeights": refreshed.get("FactorWeights") or {},
            "WeightEntropy": refreshed.get("WeightEntropy"),
            "OutcomeSensitivity": refreshed.get("OutcomeSensitivity") or {},
            "ReportText": refreshed.get("ReportText"),
        })
        enriched_runs.append(merged)
        reasons.append(list(merged.get("TopReasons") or []))

    ys = [int(r.get("RoboOutcomeBinary", 0) or 0) for r in enriched_runs]
    p = (sum(ys) / float(len(ys))) if ys else 0.0
    variance = p * (1.0 - p)
    disagreement = 1.0 - max(p, 1.0 - p) if enriched_runs else 0.0
    weight_variance_by_factor: Dict[str, float] = {}
    for factor in ROBO_DISCRETION_FACTORS:
        vals = [float((run.get("FactorWeights", {}).get(factor, {}) or {}).get("weight", 0) or 0) for run in enriched_runs]
        weight_variance_by_factor[factor] = float(round(_rj_population_variance(vals), 6))
    mean_weight_variance = (
        sum(weight_variance_by_factor.values()) / float(len(weight_variance_by_factor))
        if weight_variance_by_factor else 0.0
    )
    mean_weight_entropy = (
        sum(float(run.get("WeightEntropy", 0.0) or 0.0) for run in enriched_runs) / float(len(enriched_runs))
        if enriched_runs else 0.0
    )
    mean_flip_rate = (
        sum(float((run.get("OutcomeSensitivity", {}) or {}).get("FlipRate", 0.0) or 0.0) for run in enriched_runs) / float(len(enriched_runs))
        if enriched_runs else 0.0
    )
    modal_outcome = "V" if p >= 0.5 else "NV"
    run_summary = {
        "n": int(len(enriched_runs)),
        "p_violation": float(round(p, 6)),
        "RoboOutcomeVariance": float(round(variance, 6)),
        "RoboDisagreementRate": float(round(disagreement, 6)),
        "ModalOutcome": modal_outcome,
        "ReasonStability": rj_reason_stability(reasons),
        "DiscretionWeightVariance": float(round(mean_weight_variance, 6)),
        "DiscretionWeightVarianceByFactor": weight_variance_by_factor,
        "DiscretionFlipRate": float(round(mean_flip_rate, 6)),
        "DiscretionFlipRat": float(round(mean_flip_rate, 6)),
        "MeanWeightEntropy": float(round(mean_weight_entropy, 6)),
    }
    rep_run = _rj_pick_representative_run(enriched_runs, modal_outcome) or {}
    dossier_text = str(payload.get("_rj_dossier_text") or "")
    leak = item.get("_contract", {}).get("meta", {}).get("leakage_check_before", {}) if isinstance(item.get("_contract", {}), dict) else {}
    enriched = dict(item)
    enriched["AllRuns"] = enriched_runs
    enriched["RepresentativeRun"] = rep_run
    enriched["RunSummary"] = run_summary
    enriched["_contract"] = build_robo_contract_output(
        case_id=str(payload.get("Case_ID", "") or ""),
        subunit_id=str(payload.get("SubUnit_ID", "NA") or "NA"),
        dossier_text=dossier_text,
        input_payload=payload,
        runs_output=dict(run_summary, runs=enriched_runs),
        leakage_before=leak or {},
        leakage_after=leak or {},
    )
    return enriched


def _rj_fixed_factor_weight_map(item: Dict[str, Any]) -> Dict[str, int]:
    """Return conceptual Robo factor weights on the fixed 0..3 scale."""
    if not isinstance(item, dict):
        return {factor: 0 for factor in ROBO_DISCRETION_FACTORS}

    rep_run = item.get("RepresentativeRun", {}) if isinstance(item.get("RepresentativeRun", {}), dict) else {}
    factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run.get("FactorWeights", {}), dict) else {}

    if not factor_weights:
        payload = item.get("InputPayload", {}) if isinstance(item.get("InputPayload", {}), dict) else {}
        runs = item.get("AllRuns", []) if isinstance(item.get("AllRuns", []), list) else []
        if payload and runs:
            try:
                refreshed = _rj_enrich_saved_item(item)
                rep_run = refreshed.get("RepresentativeRun", {}) if isinstance(refreshed.get("RepresentativeRun", {}), dict) else {}
                factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run.get("FactorWeights", {}), dict) else {}
            except Exception:
                factor_weights = {}

    out: Dict[str, int] = {}
    for factor in ROBO_DISCRETION_FACTORS:
        meta = factor_weights.get(factor, {}) if isinstance(factor_weights.get(factor, {}), dict) else {}
        out[factor] = max(0, min(3, int(meta.get("weight", 0) or 0)))
    return out


def _normalize_factor_share_map(raw_map: Dict[str, Any], factors: Optional[List[str]] = None) -> Dict[str, float]:
    factor_keys = list(factors or ROBO_DISCRETION_FACTORS)
    cleaned: Dict[str, float] = {
        factor: max(0.0, float(raw_map.get(factor, 0.0) or 0.0))
        for factor in factor_keys
    }
    total = sum(cleaned.values())
    if total <= 0.0:
        return {factor: 0.0 for factor in factor_keys}
    return {
        factor: float(round(cleaned.get(factor, 0.0) / total, 6))
        for factor in factor_keys
    }


def _format_share_dataframe(df: Any) -> Any:
    """Render factor-share tables as percentages where possible."""
    try:
        if _PANDAS_OK and pd is not None and hasattr(df, "copy"):
            out = df.copy()
            for col in out.columns:
                out[col] = out[col].map(lambda v: f"{float(v):.1%}")
            return out
    except Exception:
        pass
    return df


def _rj_case_factor_share_map(item: Dict[str, Any]) -> Dict[str, float]:
    """Return per-case Robo factor contribution shares for the representative run."""
    if not isinstance(item, dict):
        return {factor: 0.0 for factor in ROBO_DISCRETION_FACTORS}

    rep_run = item.get("RepresentativeRun", {}) if isinstance(item.get("RepresentativeRun", {}), dict) else {}
    factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run.get("FactorWeights", {}), dict) else {}

    if not factor_weights:
        payload = item.get("InputPayload", {}) if isinstance(item.get("InputPayload", {}), dict) else {}
        runs = item.get("AllRuns", []) if isinstance(item.get("AllRuns", []), list) else []
        if payload and runs:
            try:
                refreshed = _rj_enrich_saved_item(item)
                rep_run = refreshed.get("RepresentativeRun", {}) if isinstance(refreshed.get("RepresentativeRun", {}), dict) else {}
                factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run.get("FactorWeights", {}), dict) else {}
            except Exception:
                factor_weights = {}

    raw_map: Dict[str, float] = {}
    for factor in ROBO_DISCRETION_FACTORS:
        meta = factor_weights.get(factor, {}) if isinstance(factor_weights.get(factor, {}), dict) else {}
        raw_map[factor] = float(
            meta.get("effective_contribution", meta.get("raw_contribution", 0.0)) or 0.0
        )
    return _normalize_factor_share_map(raw_map, list(ROBO_DISCRETION_FACTORS))


