def extract_text_from_docx(path: str) -> str:
    if not _OFFLINE_OK or Document is None:
        raise RuntimeError("Offline ingestion deps missing. Install: pip install pdfplumber python-docx")
    doc = Document(path)
    parts: List[str] = []
    for para in doc.paragraphs:
        t = (para.text or "").strip()
        if t:
            parts.append(t)
    # Basic table extraction (common in case packs)
    for tbl in doc.tables:
        for row in tbl.rows:
            cells = [((c.text or "").strip()) for c in row.cells]
            line = " | ".join([c for c in cells if c])
            if line:
                parts.append(line)
    return "\n".join(parts).strip()


def extract_text_from_pdf(path: str) -> str:
    if not _OFFLINE_OK or pdfplumber is None:
        raise RuntimeError("Offline ingestion deps missing. Install: pip install pdfplumber python-docx")
    parts: List[str] = []
    with pdfplumber.open(path) as pdf:  # type: ignore
        for i, page in enumerate(pdf.pages, start=1):
            txt = page.extract_text() or ""
            txt = txt.strip()
            if txt:
                parts.append(f"\n[PAGE {i}]\n")
                parts.append(txt)
    return "\n".join(parts).strip()


def extract_text_from_path(path: str) -> str:
    ext = os.path.splitext(path)[1].lower().strip()
    if ext == ".pdf":
        return extract_text_from_pdf(path)
    if ext == ".docx":
        return extract_text_from_docx(path)
    raise ValueError(f"Unsupported file type: {ext}")


