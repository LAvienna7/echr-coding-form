ROBO_XAI_FEATURES = [
    "IndepPriorAuth",
    "ExecOnlyAuth",
    "IndepOversight",
    "ExPostReview",
    "Notification",
    "RetentionLimits",
    "AccessLogging",
    "DestructionRules",
    "SharingRules_ForeignPartners",
    "RemedyAccess",
    "RemedyEffectiveness",
    "Flag_Journalist",
    "Flag_LawyerPrivilege",
    "Flag_ThirdPartyCapture",
    "ContextSeverity",
]


def _robo_xai_raw_feature_value(payload: Dict[str, Any], feature: str) -> Any:
    if feature == "RemedyEffectiveness":
        return str(payload.get(feature, "UNK") or "UNK").upper().strip()
    if feature in ("Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture"):
        flags = payload.get("_rj_flags", {}) if isinstance(payload.get("_rj_flags", {}), dict) else {}
        return int(flags.get(feature, 0) or 0)
    if feature == "ContextSeverity":
        return float(payload.get("_rj_context_score", 0.0) or 0.0)
    return str(payload.get(feature, "UNK") or "UNK").upper().strip()


def _robo_xai_set_feature_value(payload: Dict[str, Any], feature: str, value: Any) -> None:
    if feature == "RemedyEffectiveness":
        payload[feature] = str(value or "UNK").upper().strip()
        return
    if feature in ("Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture"):
        flags = payload.get("_rj_flags", {}) if isinstance(payload.get("_rj_flags", {}), dict) else {}
        flags[feature] = int(value or 0)
        payload["_rj_flags"] = flags
        return
    if feature == "ContextSeverity":
        payload["_rj_context_score"] = float(value or 0.0)
        return
    payload[feature] = str(value or "UNK").upper().strip()


def _robo_xai_numeric_feature_value(payload: Dict[str, Any], feature: str) -> float:
    raw = _robo_xai_raw_feature_value(payload, feature)
    if feature == "RemedyEffectiveness":
        return float(rj_remedy_severity(raw))
    if feature in ("Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture"):
        return float(int(raw or 0))
    if feature == "ContextSeverity":
        return float(raw or 0.0)
    return float(rj_field_yesno_severity(feature, raw))


def _robo_xai_feature_label(feature: str) -> str:
    labels = {
        "IndepPriorAuth": "Independent prior authorisation",
        "ExecOnlyAuth": "Executive-only authorisation",
        "IndepOversight": "Independent oversight",
        "ExPostReview": "Ex post review",
        "Notification": "Notification",
        "RetentionLimits": "Retention limits",
        "AccessLogging": "Access logging",
        "DestructionRules": "Destruction rules",
        "SharingRules_ForeignPartners": "Foreign-sharing rules",
        "RemedyAccess": "Remedy access",
        "RemedyEffectiveness": "Remedy effectiveness",
        "Flag_Journalist": "Journalist sensitivity",
        "Flag_LawyerPrivilege": "Lawyer privilege sensitivity",
        "Flag_ThirdPartyCapture": "Third-party capture sensitivity",
        "ContextSeverity": "Context severity",
    }
    return labels.get(feature, feature)


def _robo_xai_rows_from_batch(robo_batch: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    rows: List[Dict[str, Any]] = []
    for item in robo_batch:
        if not isinstance(item, dict):
            continue
        payload = item.get("InputPayload", {}) if isinstance(item.get("InputPayload", {}), dict) else {}
        rep = item.get("RepresentativeRun", {}) if isinstance(item.get("RepresentativeRun", {}), dict) else {}
        run_summary = item.get("RunSummary", {}) if isinstance(item.get("RunSummary", {}), dict) else {}
        if not payload:
            continue
        label = str(run_summary.get("ModalOutcome", rep.get("RoboOutcome", "")) or "").upper()
        if label not in ("V", "NV"):
            continue
        rows.append({
            "case_label": f"{payload.get('Case_ID', '')} [{payload.get('SubUnit_ID', 'NA')}]",
            "payload": _rj_clone_payload(payload),
            "item": item,
            "label": label,
            "label_bin": 1 if label == "V" else 0,
            "score": float(rep.get("DecisionScore", 0.0) or 0.0),
            "threshold": float(rep.get("DecisionThreshold", ROBO_BASE_THRESHOLD) or ROBO_BASE_THRESHOLD),
            "seed": int(rep.get("seed", rep.get("Seed", 1)) or 1),
            "temperature": float(rep.get("temperature", rep.get("Temperature", 0.0)) or 0.0),
        })
    return rows


def _robo_xai_permutation_importance(rows: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    if len(rows) < 2:
        return []
    out: List[Dict[str, Any]] = []
    for feature in ROBO_XAI_FEATURES:
        values = [_robo_xai_raw_feature_value(r["payload"], feature) for r in rows]
        rotated = values[1:] + values[:1]
        flips = 0
        score_delta = 0.0
        for row, new_val in zip(rows, rotated):
            payload = _rj_clone_payload(row["payload"])
            _robo_xai_set_feature_value(payload, feature, new_val)
            res = rj_rule_engine(payload, seed=int(row["seed"]), temperature=float(row["temperature"]))
            new_bin = int(res.get("RoboOutcomeBinary", 0) or 0)
            if new_bin != int(row["label_bin"]):
                flips += 1
            score_delta += abs(float(res.get("DecisionScore", 0.0) or 0.0) - float(row["score"]))
        flip_rate = float(flips) / float(len(rows))
        mean_abs_score_delta = score_delta / float(len(rows))
        out.append({
            "feature": feature,
            "label": _robo_xai_feature_label(feature),
            "flip_rate": float(round(flip_rate, 4)),
            "mean_abs_score_delta": float(round(mean_abs_score_delta, 4)),
        })
    out.sort(key=lambda x: (x["flip_rate"], x["mean_abs_score_delta"]), reverse=True)
    return out


def _robo_xai_best_split(dataset: List[Dict[str, Any]], features: List[str]) -> Optional[Dict[str, Any]]:
    def gini(labels: List[int]) -> float:
        n = len(labels)
        if n == 0:
            return 0.0
        p = sum(labels) / float(n)
        return 1.0 - (p * p) - ((1.0 - p) * (1.0 - p))

    best = None
    parent_gini = gini([int(r["label_bin"]) for r in dataset])
    for feature in features:
        vals = sorted(set(_robo_xai_numeric_feature_value(r["payload"], feature) for r in dataset))
        if len(vals) < 2:
            continue
        thresholds = [(vals[i] + vals[i + 1]) / 2.0 for i in range(len(vals) - 1)]
        for thr in thresholds:
            left = [r for r in dataset if _robo_xai_numeric_feature_value(r["payload"], feature) <= thr]
            right = [r for r in dataset if _robo_xai_numeric_feature_value(r["payload"], feature) > thr]
            if not left or not right:
                continue
            gain = parent_gini - (
                (len(left) / float(len(dataset))) * gini([int(r["label_bin"]) for r in left])
                + (len(right) / float(len(dataset))) * gini([int(r["label_bin"]) for r in right])
            )
            cand = {
                "feature": feature,
                "threshold": float(thr),
                "gain": float(gain),
                "left": left,
                "right": right,
            }
            if best is None or cand["gain"] > best["gain"]:
                best = cand
    return best


def _robo_xai_build_surrogate_tree(dataset: List[Dict[str, Any]], depth: int = 0, max_depth: int = 2) -> Dict[str, Any]:
    labels = [int(r["label_bin"]) for r in dataset]
    n = len(labels)
    p = sum(labels) / float(n) if n else 0.0
    pred = 1 if p >= 0.5 else 0
    node = {"n": n, "p_violation": float(round(p, 4)), "pred": pred}
    if depth >= max_depth or n < 4 or p in (0.0, 1.0):
        node["leaf"] = True
        return node
    split = _robo_xai_best_split(dataset, ROBO_XAI_FEATURES)
    if not split or split["gain"] <= 0.0:
        node["leaf"] = True
        return node
    node.update({
        "leaf": False,
        "feature": split["feature"],
        "threshold": split["threshold"],
        "gain": float(round(split["gain"], 4)),
        "left": _robo_xai_build_surrogate_tree(split["left"], depth + 1, max_depth),
        "right": _robo_xai_build_surrogate_tree(split["right"], depth + 1, max_depth),
    })
    return node


def _robo_xai_predict_surrogate(tree: Dict[str, Any], payload: Dict[str, Any]) -> int:
    if tree.get("leaf", False):
        return int(tree.get("pred", 0))
    feature = str(tree.get("feature", ""))
    thr = float(tree.get("threshold", 0.0))
    val = _robo_xai_numeric_feature_value(payload, feature)
    branch = tree.get("left") if val <= thr else tree.get("right")
    if isinstance(branch, dict):
        return _robo_xai_predict_surrogate(branch, payload)
    return int(tree.get("pred", 0))


def _robo_xai_render_tree(tree: Dict[str, Any], indent: int = 0) -> List[str]:
    pad = "  " * indent
    if tree.get("leaf", False):
        label = "V" if int(tree.get("pred", 0)) == 1 else "NV"
        return [f"{pad}Predict {label} (n={tree.get('n')}, p(V)={tree.get('p_violation')})"]
    feature = _robo_xai_feature_label(str(tree.get("feature", "")))
    thr = float(tree.get("threshold", 0.0))
    lines = [f"{pad}If {feature} <= {thr:.2f}:"]
    lines.extend(_robo_xai_render_tree(tree.get("left", {}), indent + 1))
    lines.append(f"{pad}Else:")
    lines.extend(_robo_xai_render_tree(tree.get("right", {}), indent + 1))
    return lines


def _robo_xai_counterfactual_candidates(payload: Dict[str, Any], outcome: str) -> List[Dict[str, Any]]:
    proposals: List[Dict[str, Any]] = []
    target_more_violation = str(outcome).upper() == "NV"
    for feature in ROBO_XAI_FEATURES:
        current = _robo_xai_raw_feature_value(payload, feature)
        if feature == "RemedyEffectiveness":
            order = ["EFF", "LIM", "NONE"]
        elif feature in ("Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture"):
            order = [0, 1]
        elif feature == "ContextSeverity":
            order = [0.0, 0.5, 1.0]
        else:
            order = ["YES", "PART", "NO"]

        if current not in order:
            current = order[0] if not target_more_violation else order[-1]

        cur_idx = order.index(current)
        target_idxs = range(cur_idx + 1, len(order)) if target_more_violation else range(0, cur_idx)
        for idx in target_idxs:
            proposals.append({
                "feature": feature,
                "from": current,
                "to": order[idx],
                "distance": abs(idx - cur_idx),
            })
    return proposals


def _robo_xai_find_counterfactual(row: Dict[str, Any]) -> Optional[Dict[str, Any]]:
    outcome = str(row.get("label", "NV") or "NV").upper()
    proposals = _robo_xai_counterfactual_candidates(row["payload"], outcome)
    if not proposals:
        return None
    for width in (1, 2, 3):
        for combo in itertools.combinations(proposals, width):
            feats = [c["feature"] for c in combo]
            if len(set(feats)) != len(feats):
                continue
            payload = _rj_clone_payload(row["payload"])
            for change in combo:
                _robo_xai_set_feature_value(payload, change["feature"], change["to"])
            res = rj_rule_engine(payload, seed=int(row["seed"]), temperature=float(row["temperature"]))
            new_outcome = str(res.get("RoboOutcome", "") or "")
            if new_outcome and new_outcome != outcome:
                return {
                    "changes": list(combo),
                    "result": res,
                    "new_outcome": new_outcome,
                    "distance": sum(int(c["distance"]) for c in combo),
                }
    return None


