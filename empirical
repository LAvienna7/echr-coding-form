def render_human_vs_robo():
    """Compare human judgments vs Robo-Judge outcomes."""
    st.header("Human vs Robo Comparison")
    st.caption(
        "Load human-coded dossiers and Robo-Judge runs for the same cases. Compare outcomes, consistency, explainability, and doctrinal fidelity."
    )

    human_rows = load_all_rows()
    if not human_rows:
        st.info("No human-coded dossiers found. Code some cases first in the Coding Form.")
        return
    stale_human = [r for r in human_rows if human_case_needs_refresh(r)]
    if stale_human:
        st.warning(
            f"{len(stale_human)} saved human dossiers still look stale or legacy-flat. "
            "Their safeguard extraction and derived analysis should be refreshed before comparing them to Robo-Judge."
        )
        if st.button("Refresh + save stale human dossiers", key="human_vs_robo_refresh_stale"):
            res_refresh = refresh_and_save_human_cases(human_rows, only_stale=True)
            if res_refresh["failed"]:
                st.warning(f"Refreshed {res_refresh['ok']}/{res_refresh['total']} stale dossiers.")
                with st.expander("Refresh failures", expanded=False):
                    for msg in res_refresh["failed"]:
                        st.write("- " + msg)
            else:
                st.success(f"Refreshed and saved {res_refresh['ok']} stale human dossiers.")
            st.rerun()
        st.info("Comparison visuals are paused until the stale human dossiers are refreshed.")
        return

    robo_batch_files = list_saved_robo_batches()

    if not robo_batch_files:
        st.info("No saved Robo-Judge batches found. Run the Robo-Judge first.")
        return

    selected_robo_file = st.selectbox(
        "Select saved Robo-Judge batch",
        options=robo_batch_files,
        format_func=lambda f: f.replace("robo_batch__", "").replace(".json", ""),
        key="human_vs_robo_batch_select",
    )

    batch_path = os.path.join(ROBO_BATCH_DIR, selected_robo_file)
    try:
        with open(batch_path, "r", encoding="utf-8") as f:
            robo_batch = json.load(f)
    except Exception as e:
        st.error(f"Failed to load Robo batch: {e}")
        return

    if not isinstance(robo_batch, list):
        st.error("Robo batch format unexpected.")
        return
    robo_batch = [_rj_enrich_saved_item(item) if isinstance(item, dict) else item for item in robo_batch]

    st.markdown("---")
    st.subheader("Matched cases")

    # Build match map
    comparison_data = []

    robo_index = []
    for robo_item in robo_batch:
        if not isinstance(robo_item, dict):
            continue
        robo_su = str(robo_item.get("InputPayload", {}).get("SubUnit_ID", "NA")).strip().upper()
        robo_cands = set(_robo_case_candidates_for_match(robo_item))
        if not robo_cands:
            continue
        robo_index.append((robo_item, robo_su, robo_cands))

    for human_row in human_rows:
        human_case = str(human_row.get("Case_ID", "") or "")
        human_cands = set(_human_case_candidates_for_match(human_row))
        if not human_cands:
            continue
        human_su = str(human_row.get("SubUnit_ID", "NA")).strip().upper()
        human_outcome = str(human_row.get("Art8_Outcome", "")).upper()

        best_item = None
        best_score = 0
        for robo_item, robo_su, robo_cands in robo_index:
            if not _subunit_match(human_su, robo_su):
                continue
            score = _candidate_match_score(human_cands, robo_cands)
            if score > best_score:
                best_score = score
                best_item = robo_item

        if not best_item or best_score <= 0:
            continue

        robo_modal = str(best_item.get("RunSummary", {}).get("ModalOutcome", "")).upper()
        robo_summary = best_item.get("RunSummary", {})
        robo_contract = best_item.get("_contract", {})

        # Compute metrics
        outcome_match = 1 if human_outcome == robo_modal else 0
        human_variance = human_row.get("Art8_BinaryAnyViolation", 0)  # placeholder
        robo_variance = float(robo_summary.get("RoboOutcomeVariance", 0.0))

        # Human explainability
        human_metrics = human_explainability_coverage(human_row)
        human_ecs = human_metrics.get("ECS", 0.0)
        human_line = human_metrics.get("LineAdherence", 0.0)

        # Robo explainability - use contract if available
        robo_ecs = 0.0
        robo_line = 0.0
        if robo_contract:
            robo_expl = compute_robo_explainability_metrics(robo_contract, "")
            robo_ecs = float(robo_expl.get("overall_explainability", 0.0))
            robo_line = float(robo_expl.get("doctrinal_fidelity_score", 0.0))
        else:
            # Fallback: estimate from report text
            rep_run = best_item.get("RepresentativeRun", {})
            report_text = str(rep_run.get("ReportText", ""))
            robo_ecs = len([w for w in report_text.split() if w.lower() in ["safeguards", "evidence", "court", "law", "necessary"]]) / max(1, len(report_text.split())) if report_text else 0.0

        line_similarity = 1.0 - abs(float(human_line) - float(robo_line))
        comparison_data.append({
            "Case_ID": human_case,
            "SubUnit_ID": human_su,
            "Human_Outcome": human_outcome,
            "Robo_Outcome": robo_modal,
            "Outcome_Match": outcome_match,
            "Human_ECS": round(human_ecs, 4),
            "Robo_ECS": round(robo_ecs, 4),
            "Line_Adherence_Similarity": round(line_similarity, 4),
            "Human_LineAdherence": round(human_line, 4),
            "Robo_LineAdherence": round(robo_line, 4),
            "Robo_Variance": round(robo_variance, 6),
            "Robo_p_violation": round(float(robo_summary.get("p_violation", 0.0)), 4),
            "row_idx": comparison_data.__len__(),
            "human_row": human_row,
            "robo_item": best_item,
        })

    if not comparison_data:
        st.warning("No matching cases found between human dossiers and Robo batch.")
        return

    # Display comparison table
    display_data = [
        {
            "Case_ID": d["Case_ID"],
            "SubUnit": d["SubUnit_ID"],
            "Human": d["Human_Outcome"],
            "Robo": d["Robo_Outcome"],
            "Match": "✓" if d["Outcome_Match"] else "✗",
            "Human_ECS": d["Human_ECS"],
            "Robo_ECS": d["Robo_ECS"],
            "Line_Adherence_Similarity": d["Line_Adherence_Similarity"],
            "Robo_Var": d["Robo_Variance"],
        }
        for d in comparison_data
    ]

    if _PANDAS_OK and pd is not None:
        df_comp = pd.DataFrame(display_data)
        st.dataframe(df_comp, use_container_width=True)
    else:
        st.json(display_data)

    # Summary metrics
    st.markdown("---")
    st.subheader("Aggregate metrics")

    total_matched = len(comparison_data)
    total_agreed = sum(d["Outcome_Match"] for d in comparison_data)
    agreement_rate = total_agreed / total_matched if total_matched else 0.0

    c1, c2, c3, c4, c5 = st.columns(5)
    c1.metric("Matched cases", total_matched)
    c2.metric("Outcome agreement", f"{int(total_agreed)}/{int(total_matched)}")
    c3.metric("Agreement rate", f"{agreement_rate:.1%}")
    c4.metric("Avg Robo variance", f"{sum(d['Robo_Variance'] for d in comparison_data) / total_matched:.6f}" if total_matched else "0")
    c5.metric(
        "Avg Line Adherence Similarity",
        f"{sum(d['Line_Adherence_Similarity'] for d in comparison_data) / total_matched:.3f}" if total_matched else "0",
    )

    # ================================================================
    # NEW: Machine Discretion Matrix Heatmap
    # ================================================================
    st.markdown("---")
    st.subheader("Machine Discretion Matrix: Factor Weighting Comparison")
    st.caption(
        "Heatmap showing per-case factor weighting shares for Robo-Judge versus the human coder. "
        "Each row is normalized within the case, so darker cells indicate a larger share of that case's total factor weighting. "
        "The Robo side uses representative-run factor contribution shares, not the discretized fixed `0..3` bins."
    )

    # Build per-case factor-share matrices on a shared within-case scale.
    conceptual_factors = list(ROBO_DISCRETION_FACTORS)
    factor_labels = [str(ROBO_DISCRETION_FACTOR_META.get(f, {}).get("label", f)) for f in conceptual_factors]
    human_factor_mapping: List[Tuple[str, str, float]] = [
        ("IndepPriorAuth", "AUTH", 2.0),
        ("ExecOnlyAuth", "AUTH", 1.5),
        ("IndepOversight", "OVERS", 2.0),
        ("AccessLogging", "OVERS", 1.0),
        ("ExPostReview", "REVIEW", 1.5),
        ("Notification", "NOTICE", 1.0),
        ("RetentionLimits", "RETAIN", 1.5),
        ("DestructionRules", "DESTROY", 1.0),
        ("SharingRules_ForeignPartners", "SHARING", 1.0),
        ("RemedyAccess", "REMEDY", 1.5),
    ]
    def _human_deficit_factor_scores(hrow: Dict[str, Any]) -> Dict[str, float]:
        raw_scores: Dict[str, float] = {factor: 0.0 for factor in conceptual_factors}
        for field, factor, rel_w in human_factor_mapping:
            raw_scores[factor] += float(_field_yesno_severity(field, hrow.get(field))) * float(rel_w)
        raw_scores["REMEDY"] += float(_remedy_severity(hrow.get("RemedyEffectiveness"))) * 1.0
        return raw_scores

    def _human_decisive_factor_weights(hrow: Dict[str, Any]) -> Dict[str, int]:
        out: Dict[str, int] = {factor: 0 for factor in conceptual_factors}
        rank_weights = [3, 2, 1]
        for idx, rank_w in enumerate(rank_weights, start=1):
            factor = str(hrow.get(f"Human_TopFactor{idx}", "NA") or "NA").upper().strip()
            if factor in out:
                out[factor] = max(out[factor], int(rank_w))
        driver = str(hrow.get("PrimaryDriver", "") or "").upper().strip()
        if driver == "PROP":
            out["PROP"] = max(out["PROP"], 2)
        elif driver == "REM":
            out["REMEDY"] = max(out["REMEDY"], 2)
        return out

    def _human_comparison_factor_shares(hrow: Dict[str, Any]) -> Dict[str, float]:
        human_decisive = _human_decisive_factor_weights(hrow)
        human_scores = _human_deficit_factor_scores(hrow)
        rank_bonus = {1: 3.0, 2: 2.0, 3: 1.0}
        for idx, bonus in rank_bonus.items():
            factor = str(hrow.get(f"Human_TopFactor{idx}", "NA") or "NA").upper().strip()
            if factor in human_scores:
                human_scores[factor] += float(bonus)
        driver = str(hrow.get("PrimaryDriver", "") or "").upper().strip()
        if driver == "PROP":
            human_scores["PROP"] += 2.0
        elif driver == "REM":
            human_scores["REMEDY"] += 2.0

        # Ensure manually identified decisive factors still contribute even if deficit coding is sparse.
        for factor in conceptual_factors:
            human_scores[factor] = max(float(human_scores.get(factor, 0.0) or 0.0), float(human_decisive.get(factor, 0) or 0))
        return _normalize_factor_share_map(human_scores, conceptual_factors)

    human_factor_matrix = []
    robo_factor_matrix = []
    case_labels_matrix = []

    for d in comparison_data:
        human_row = d["human_row"]
        robo_item = d["robo_item"]
        case_labels_matrix.append(f"{d['Case_ID']}[{d['SubUnit_ID']}]")

        # Human side: convert safeguard deficits + decisive factors into per-case factor shares.
        human_factor_map = _human_comparison_factor_shares(human_row)
        human_factors = [float(human_factor_map.get(factor, 0)) for factor in conceptual_factors]
        human_factor_matrix.append(human_factors)

        # Robo side: use representative-run factor contribution shares for the case.
        robo_factor_map = _rj_case_factor_share_map(robo_item)
        robo_factors = [float(robo_factor_map.get(factor, 0)) for factor in conceptual_factors]
        robo_factor_matrix.append(robo_factors)

    matrix_min = 0.0
    matrix_values = [float(v) for row in human_factor_matrix for v in row] + [float(v) for row in robo_factor_matrix for v in row]
    matrix_max = max([0.25] + matrix_values) if matrix_values else 0.25

    # Display heatmaps side-by-side if matplotlib is available
    if _MPL_OK and plt is not None and human_factor_matrix and robo_factor_matrix:
        import numpy as np
        fig = plt.figure(figsize=(13.5, max(9, len(case_labels_matrix) * 0.62)))
        gs = fig.add_gridspec(2, 2, width_ratios=[1.0, 0.04], height_ratios=[1.0, 1.0], wspace=0.15, hspace=0.32)
        ax1 = fig.add_subplot(gs[0, 0])
        ax2 = fig.add_subplot(gs[1, 0])
        cax = fig.add_subplot(gs[:, 1])

        # Human heatmap
        human_array = np.nan_to_num(np.array(human_factor_matrix), nan=0.0)
        im1 = ax1.imshow(human_array, cmap="YlOrRd", aspect="auto", vmin=matrix_min, vmax=matrix_max)
        ax1.set_xticks(range(len(conceptual_factors)))
        ax1.set_yticks(range(len(case_labels_matrix)))
        ax1.tick_params(axis="x", labelbottom=False)
        ax1.set_yticklabels(case_labels_matrix, fontsize=8)
        ax1.set_title("Human factor weighting share", fontweight="bold")

        # Robo heatmap
        robo_array = np.nan_to_num(np.array(robo_factor_matrix), nan=0.0)
        im2 = ax2.imshow(robo_array, cmap="YlOrRd", aspect="auto", vmin=matrix_min, vmax=matrix_max)
        ax2.set_xticks(range(len(conceptual_factors)))
        ax2.set_yticks(range(len(case_labels_matrix)))
        ax2.set_xticklabels(factor_labels, rotation=38, ha="right", fontsize=9)
        ax2.set_yticklabels(case_labels_matrix, fontsize=8)
        ax2.set_title("Robo-Judge factor weighting share", fontweight="bold")

        if len(case_labels_matrix) <= 8:
            for row_idx in range(human_array.shape[0]):
                for col_idx in range(human_array.shape[1]):
                    human_val = float(human_array[row_idx, col_idx])
                    robo_val = float(robo_array[row_idx, col_idx])
                    ax1.text(
                        col_idx,
                        row_idx,
                        f"{human_val:.0%}",
                        ha="center",
                        va="center",
                        color=("black" if human_val <= (matrix_max * 0.45) else "white"),
                        fontsize=7,
                    )
                    ax2.text(
                        col_idx,
                        row_idx,
                        f"{robo_val:.0%}",
                        ha="center",
                        va="center",
                        color=("black" if robo_val <= (matrix_max * 0.45) else "white"),
                        fontsize=7,
                    )

        cbar_ticks = np.linspace(0.0, matrix_max, 5)
        cbar = fig.colorbar(im1, cax=cax, ticks=cbar_ticks)
        cbar.ax.set_yticklabels([f"{tick:.0%}" for tick in cbar_ticks])
        cbar.set_label("Per-case factor share of total weighting")

        fig.subplots_adjust(left=0.26, right=0.94, bottom=0.12, top=0.92, wspace=0.16, hspace=0.34)
        st.pyplot(fig, clear_figure=True)

        # Summary: which factors diverge most
        with st.expander("Factor divergence analysis", expanded=False):
            st.caption("Shows which safeguard factors have the largest weighting divergence between human and robo.")
            
            divergence_scores = []
            for factor_idx, factor_name in enumerate(conceptual_factors):
                human_col = [row[factor_idx] if factor_idx < len(row) else 0 for row in human_factor_matrix]
                robo_col = [row[factor_idx] if factor_idx < len(row) else 0 for row in robo_factor_matrix]
                
                # Compute mean absolute divergence
                avg_divergence = sum(abs(h - r) for h, r in zip(human_col, robo_col)) / max(1, len(human_col))
                divergence_scores.append((factor_name, avg_divergence))
            
            divergence_scores.sort(key=lambda x: x[1], reverse=True)
            
            if _PANDAS_OK and pd is not None:
                df_div = pd.DataFrame([
                    {
                        "Factor": str(ROBO_DISCRETION_FACTOR_META.get(name, {}).get("label", name)),
                        "Avg_Divergence": round(div, 4),
                    }
                    for name, div in divergence_scores
                ])
                st.dataframe(df_div, use_container_width=True)
            else:
                for name, div in divergence_scores:
                    label = str(ROBO_DISCRETION_FACTOR_META.get(name, {}).get("label", name))
                    st.write(f"{label}: {div:.4f}")
        
        st.markdown("### Key findings")
        if divergence_scores:
            top = divergence_scores[:3]
            avg_human = [sum(row[i] for row in human_factor_matrix) / max(1, len(human_factor_matrix)) for i in range(len(conceptual_factors))]
            avg_robo = [sum(row[i] for row in robo_factor_matrix) / max(1, len(robo_factor_matrix)) for i in range(len(conceptual_factors))]
            st.write(
                f"- Largest divergences are in {', '.join([str(ROBO_DISCRETION_FACTOR_META.get(t[0], {}).get('label', t[0])) for t in top])}."
            )
            for name, _div in top:
                idx = conceptual_factors.index(name)
                label = str(ROBO_DISCRETION_FACTOR_META.get(name, {}).get("label", name))
                st.write(
                    f"- {label}: human avg={avg_human[idx]:.1%}, robo avg={avg_robo[idx]:.1%} of per-case weighting."
                )
            more_human = [
                str(ROBO_DISCRETION_FACTOR_META.get(conceptual_factors[i], {}).get("label", conceptual_factors[i]))
                for i in range(len(conceptual_factors))
                if avg_human[i] - avg_robo[i] >= 0.10
            ]
            more_robo = [
                str(ROBO_DISCRETION_FACTOR_META.get(conceptual_factors[i], {}).get("label", conceptual_factors[i]))
                for i in range(len(conceptual_factors))
                if avg_robo[i] - avg_human[i] >= 0.10
            ]
            if more_human:
                st.write(f"- Human coders allocate materially more share to: {', '.join(more_human[:5])}.")
            if more_robo:
                st.write(f"- Robo-Judge allocates materially more share to: {', '.join(more_robo[:5])}.")
        else:
            st.write("- No divergence data available yet.")

        with st.expander("Heatmap data tables", expanded=False):
            if _PANDAS_OK and pd is not None:
                st.write("Human per-case factor weighting shares")
                st.dataframe(
                    _format_share_dataframe(pd.DataFrame(human_factor_matrix, columns=factor_labels, index=case_labels_matrix)),
                    use_container_width=True,
                )
                st.write("Robo per-case factor weighting shares")
                st.dataframe(
                    _format_share_dataframe(pd.DataFrame(robo_factor_matrix, columns=factor_labels, index=case_labels_matrix)),
                    use_container_width=True,
                )
    else:
        # Fallback: show as table
        if _PANDAS_OK and pd is not None:
            st.write("**Human factor weighting shares**")
            df_h = pd.DataFrame(human_factor_matrix, columns=factor_labels, index=case_labels_matrix)
            st.dataframe(_format_share_dataframe(df_h), use_container_width=True)
            
            st.write("**Robo-Judge factor weighting shares**")
            df_r = pd.DataFrame(robo_factor_matrix, columns=factor_labels, index=case_labels_matrix)
            st.dataframe(_format_share_dataframe(df_r), use_container_width=True)

    # Failure mode taxonomy (new)
    st.markdown("---")
    with st.expander("Failure Mode Analysis (Mismatch Taxonomy)", expanded=False):
        st.caption("Automatically classify and analyze mismatches between human and robo outcomes.")
        
        # Analyze all mismatches
        mismatches = [d for d in comparison_data if d["Outcome_Match"] == 0]
        
        if mismatches:
            failure_modes_list = []
            for m in mismatches:
                human_row = m["human_row"]
                human_metrics = human_explainability_coverage(human_row)
                
                fm = classify_failure_mode(
                    human_outcome=m["Human_Outcome"],
                    robo_outcome=m["Robo_Outcome"],
                    human_evidence_coverage=human_metrics.get("ECS", 0.0),
                    robo_evidence_coverage=m["Robo_ECS"],
                    extraction_confidence=0.8,
                    leakage_risk="LOW",
                    human_robo_safeguard_overlap=0.5,
                )
                
                failure_modes_list.append({
                    "Case": m["Case_ID"],
                    "Primary_Mode": fm["primary_mode"],
                    "Severity": fm["severity"],
                    "Severity_Score": fm["severity_score"],
                })
            
            # Aggregate by failure mode
            mode_counts = {}
            for item in failure_modes_list:
                mode = item["Primary_Mode"]
                mode_counts[mode] = mode_counts.get(mode, 0) + 1
            
            sorted_modes = sorted(mode_counts.items(), key=lambda x: x[1], reverse=True)
            
            c1, c2 = st.columns([1, 1])
            
            with c1:
                st.write("**Failure Mode Distribution (Pareto)**")
                if _PANDAS_OK and pd is not None:
                    df_modes = pd.DataFrame([
                        {"Failure Mode": m[0].replace("_", " ").title(), "Count": m[1]}
                        for m in sorted_modes
                    ])
                    st.dataframe(df_modes, use_container_width=True)
                else:
                    for mode, count in sorted_modes:
                        st.write(f"- {mode.replace('_', ' ').title()}: {count}")
            
            with c2:
                st.write("**Severity Distribution**")
                severity_counts = {}
                for item in failure_modes_list:
                    sev = item["Severity"]
                    severity_counts[sev] = severity_counts.get(sev, 0) + 1
                
                if severity_counts:
                    if _PANDAS_OK and pd is not None:
                        df_sev = pd.DataFrame([
                            {"Severity": s.upper(), "Count": severity_counts[s]}
                            for s in ["high", "medium", "low"] if s in severity_counts
