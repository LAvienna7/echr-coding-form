        robo_ecs_var = sum((x - robo_ecs_mean) ** 2 for x in robo_ecs_scores) / max(1, len(robo_ecs_scores))
        
        human_ecs_cv = (human_ecs_var ** 0.5) / max(0.0001, human_ecs_mean) if human_ecs_mean > 0 else 0.0
        robo_ecs_cv = (robo_ecs_var ** 0.5) / max(0.0001, robo_ecs_mean) if robo_ecs_mean > 0 else 0.0
        
