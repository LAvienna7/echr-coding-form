            require_same_trigger=bool(params.get("require_same_trigger", False)),
            min_cluster_size=int(params.get("min_cluster_size", 2)),
        )
        clusters = cluster_res.get("clusters", []) if isinstance(cluster_res.get("clusters", []), list) else []

        if clusters:
            weighted_human_var = 0.0
            weighted_robo_var = 0.0
            weight_total = 0.0
            human_disagreements = 0
            robo_disagreements = 0
            disagreement_pairs = 0

            for members in clusters:
                if not members or len(members) < 2:
                    continue
                h_cluster = [human_outcomes[idx] for idx in members if idx < len(human_outcomes)]
                r_cluster = [robo_outcomes[idx] for idx in members if idx < len(robo_outcomes)]
                if len(h_cluster) < 2 or len(r_cluster) < 2:
                    continue
                p_human = sum(h_cluster) / float(len(h_cluster))
                p_robo = sum(r_cluster) / float(len(r_cluster))
                cluster_size = float(len(members))
                weighted_human_var += cluster_size * (p_human * (1.0 - p_human))
                weighted_robo_var += cluster_size * (p_robo * (1.0 - p_robo))
                weight_total += cluster_size

                for i in range(len(members) - 1):
                    for j in range(i + 1, len(members)):
                        disagreement_pairs += 1
                        if h_cluster[i] != h_cluster[j]:
                            human_disagreements += 1
                        if r_cluster[i] != r_cluster[j]:
                            robo_disagreements += 1

            var_human = (weighted_human_var / weight_total) if weight_total > 0 else 0.0
            var_robo_empirical = (weighted_robo_var / weight_total) if weight_total > 0 else 0.0
            human_disagreement_rate = human_disagreements / disagreement_pairs if disagreement_pairs > 0 else 0.0
            robo_disagreement_rate = robo_disagreements / disagreement_pairs if disagreement_pairs > 0 else 0.0
        else:
            p_human = sum(human_outcomes) / len(human_outcomes)
            p_robo = sum(robo_outcomes) / len(robo_outcomes)
