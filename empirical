    return 0


def _snippet_quality(snippet: str) -> float:
    """Lightweight quality heuristic: normative framing + specificity."""
    s = _norm_for_span_match(snippet)
    if not s:
        return 0.0
    # Normative/legal reasoning markers
    norm_words = [
        "the court", "considers", "observes", "notes", "finds", "holds",
        "in accordance with the law", "quality of the law", "foreseeable", "accessible",
        "necessary in a democratic society", "proportionate", "fair balance", "margin of appreciation",
        "adequate", "effective", "safeguards", "guarantees", "oversight", "review",
    ]
    score = 0.0
    if any(w in s for w in norm_words[:6]):
        score += 0.45
    if any(w in s for w in norm_words[6:]):
        score += 0.45
    # Specificity: presence of institutional/legal artefacts
    if any(w in s for w in ["judge", "court", "warrant", "authorisation", "authorization", "tribunal", "commissioner", "g10"]):
        score += 0.10
    return float(min(1.0, score))


