]


def _coerce_text(x: Any) -> str:
    """Best-effort conversion of HUDOC extractor outputs into a single plain string."""
    if x is None:
        return ""
    if isinstance(x, str):
        return x
    if isinstance(x, bytes):
        try:
            return x.decode("utf-8", errors="ignore")
        except Exception:
            return str(x)
    if isinstance(x, list):
        return "\n".join([_coerce_text(p) for p in x if p is not None])
    if isinstance(x, dict):
        for k in ("text", "body", "content", "document", "judgment", "decision"):
            if k in x:
                return _coerce_text(x.get(k))
        return "\n".join([_coerce_text(v) for v in x.values() if v is not None])
    return str(x)


def _is_substantive_human_source_text(text: str) -> bool:
    s = _cleanup_source_text(text)
    if not s:
        return False
    up = s.upper()
    placeholder_markers = [
        "HUDOC - EUROPEAN COURT OF HUMAN RIGHTS",
        "HUDOC-EXEC",
        "EUROPEAN COURT OF HUMAN RIGHTS",
    ]
    if s in placeholder_markers:
        return False
    if len(s) < 120:
        return False
    section_markers = list(_FACTS_MARKERS) + list(_LAW_MARKERS) + list(_OPERATIVE_MARKERS)
    marker_hits = sum(1 for m in section_markers if m and m in up)
    if marker_hits >= 2:
        return True
    if len(s) >= 2500:
        return True
    legal_markers = [
        "ARTICLE 8",
        "THE APPLICANT",
        "THE COURT",
        "PRIVATE LIFE",
        "IN ACCORDANCE WITH THE LAW",
        "NECESSARY IN A DEMOCRATIC SOCIETY",
    ]
    legal_hits = sum(1 for m in legal_markers if m in up)
    return legal_hits >= 2 and len(s) >= 700


def _normalize_human_source_text(text: str) -> str:
    s = _cleanup_source_text(text)
    return s if _is_substantive_human_source_text(s) else ""


def _find_saved_casepack_path(case_id: str, subunit_id: str) -> str:
    base = safe_filename(case_id or "")
    su = subunit_id if subunit_id else "NA"
    if not base:
        return ""
    direct = [
        os.path.join(CASEPACK_DIR, f"{base}__{su}__casepack.pdf"),
        os.path.join(CASEPACK_DIR, f"{base}__{su}__casepack.docx"),
        os.path.join(CASEPACK_DIR, f"{base}__NA__casepack.pdf"),
        os.path.join(CASEPACK_DIR, f"{base}__NA__casepack.docx"),
    ]
    for p in direct:
        if os.path.exists(p):
            return p
    prefix = f"{base}__"
    suffixes = ("__casepack.pdf", "__casepack.docx")
    try:
        for name in sorted(os.listdir(CASEPACK_DIR)):
            if name.startswith(prefix) and name.endswith(suffixes):
                return os.path.join(CASEPACK_DIR, name)
    except Exception:
        pass
    return ""


def _resolve_best_human_source_text(case_id: str, subunit_id: str, hudoc_text: str = "") -> Tuple[str, str, str]:
    """Return (text, source_kind, source_path)."""
    clean_hudoc = _normalize_human_source_text(hudoc_text)
    if clean_hudoc:
        return clean_hudoc, "hudoc", ""
    casepack_path_local = _find_saved_casepack_path(case_id, subunit_id)
    if casepack_path_local and _OFFLINE_OK:
        try:
            extracted = _normalize_human_source_text(extract_text_from_path(casepack_path_local))
            if extracted:
                return extracted, "casepack", casepack_path_local
        except Exception:
            pass
    return "", "", ""


def _strip_html_to_text(raw_html: str) -> str:
    """Lightweight HTML to text conversion (no external deps)."""
    if not raw_html:
        return ""
    s = re.sub(r"<script[^>]*>.*?</script>", " ", raw_html, flags=re.IGNORECASE | re.DOTALL)
    s = re.sub(r"<style[^>]*>.*?</style>", " ", s, flags=re.IGNORECASE | re.DOTALL)
    s = re.sub(r"<(br|p|div|li|h\d)[^>]*>", "\n", s, flags=re.IGNORECASE)
    s = re.sub(r"<[^>]+>", " ", s)
    s = _html.unescape(s)
    return re.sub(r"\s+", " ", s).strip()


def _http_get_text(url: str, timeout: int = 25) -> str:
    """HTTP GET with a browser-like UA. Returns decoded text or empty string."""
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "Mozilla/5.0"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read().decode("utf-8", errors="ignore")
        return raw
    except Exception:
        return ""


def fetch_hudoc_conversion_text(itemid: str) -> str:
    """Fetch ECHR judgment/decision text via HUDOC conversion endpoints."""
    itemid = (itemid or "").strip()
    if not itemid:
        return ""

    candidates = [
        f"https://hudoc.echr.coe.int/app/conversion/txt/?library=ECHR&id={itemid}",
        f"https://hudoc.echr.coe.int/app/conversion/html/?library=ECHR&id={itemid}",
    ]

    for url in candidates:
        raw = _http_get_text(url)
        if not raw or len(raw.strip()) < 500:
            continue
        if "/conversion/html/" in url:
            txt = _strip_html_to_text(raw)
        else:
            txt = re.sub(r"\s+", " ", raw).strip()
        txt = _normalize_human_source_text(txt)
        if txt:
            return txt

    page = _http_get_text(f"https://hudoc.echr.coe.int/eng?i={itemid}")
    return _normalize_human_source_text(_strip_html_to_text(page))


@st.cache_data(show_spinner=False)
def hudoc_lookup_by_appno(appno: str) -> Dict[str, Any]:
    if not _HUDOC_OK:
        return {"_status": "deps_missing"}

    appno = (appno or "").strip()
    if not appno:
        return {"_status": "no_appno"}

    q = f'appno:"{appno}" AND (documentcollectionid:"JUDGMENTS" OR documentcollectionid:"DECISIONS")'
    df = get_echr(query_payload=q, language=["ENG"], fields=HUDOC_FIELDS, save_file="n")
    if df is None or getattr(df, "empty", True):
        q2 = f'appno:{appno}'
        df = get_echr(query_payload=q2, language=["ENG"], fields=HUDOC_FIELDS, save_file="n")

    if df is None or getattr(df, "empty", True):
        return {"_status": "not_found"}

    def _rank_row(r: Dict[str, Any]) -> tuple:
        coll = (r.get("documentcollectionid") or "").upper()
        coll_rank = 0 if coll == "JUDGMENTS" else 1
        kp = r.get("kpdate") or r.get("decisiondate") or ""
        dt = dateparse(str(kp)) if dateparse else None
        ts = -(dt.timestamp()) if dt else 0
        return (coll_rank, ts)

    records = df.to_dict(orient="records")
    records.sort(key=_rank_row)
    best = records[0]

    # Fetch full text (robust)
    try:
        itemid = str(best.get("itemid", "") or "").strip()

        # Prefer HUDOC conversion endpoints first (usually the most reliable in practice)
        ft_conv = fetch_hudoc_conversion_text(itemid)

        # Try extractor-based full text as a secondary source
        ft_extra = ""
        try:
            url = f"https://hudoc.echr.coe.int/eng?i={itemid}"
            _df2, full_texts = get_echr_extra(link=url, language=["ENG"], fields=HUDOC_FIELDS, save_file="n")
            ft_extra = _coerce_text(full_texts)
        except Exception:
            ft_extra = ""

        # Pick the longer non-trivial text
        ft_conv = _normalize_human_source_text(ft_conv)
        ft_extra = _normalize_human_source_text(ft_extra)
        ft = ft_conv if len(ft_conv.strip()) >= len(ft_extra.strip()) else ft_extra
        best["_full_text"] = ft
    except Exception:
        best["_full_text"] = ""

    best["_status"] = "ok"
    return best


