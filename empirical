def _step_evidence_coverage(law_text: str) -> Tuple[float, Dict[str, int], Dict[str, int]]:
    # Returns (evidence_score, evidence_breakdown, first_positions)
    pats = _step_patterns()
    breakdown: Dict[str, int] = {}
    first_pos: Dict[str, int] = {}

    for step, patterns in pats.items():
        hit = 0
        pos = None
        for pat in patterns:
            try:
                m = re.search(pat, law_text, flags=re.IGNORECASE)
            except re.error:
                m = None
            if m:
                hit = 1
                pos = m.start()
                break
        breakdown[step] = hit
        if pos is not None:
            first_pos[step] = int(pos)

    score = (sum(breakdown.values()) / float(len(pats))) if pats else 0.0
    return float(score), breakdown, first_pos


def _order_compliance(first_pos: Dict[str, int]) -> float:
    # Soft ordering: interference -> lawfulness -> aim -> necessity
    order = ["Step_Interference", "Step_Lawfulness", "Step_LegitimateAim", "Step_Necessity"]
    pos = [first_pos.get(k) for k in order if k in first_pos]
    if len(pos) < 2:
        return 0.5  # insufficient info
    return 1.0 if pos == sorted(pos) else 0.0


def human_line_adherence_score(row: Dict[str, Any]) -> Tuple[float, Dict[str, Any]]:
    """Evidence-based doctrinal line adherence.

    Combines:
      - checkbox coverage (Step_* fields)
      - textual evidence coverage in THE LAW section
      - ordering compliance (soft)

    Final score weights: evidence 0.75, checkbox 0.15, order 0.10
    """
    checkbox = {k: _as_int01(row.get(k, 0)) for k in HUMAN_LINE_STEPS}
    checkbox_score = (sum(checkbox.values()) / float(len(HUMAN_LINE_STEPS))) if HUMAN_LINE_STEPS else 0.0

    src = _get_source_text(row)
    law = extract_law_section_text(src) if src else ""
    ev_score, ev_breakdown, first_pos = _step_evidence_coverage(law)
    order_score = _order_compliance(first_pos)

    score = (0.75 * ev_score) + (0.15 * float(checkbox_score)) + (0.10 * float(order_score))
    return float(round(score, 4)), {
        "checkbox": checkbox,
        "checkbox_score": float(round(checkbox_score, 4)),
        "evidence": ev_breakdown,
        "evidence_score": float(round(ev_score, 4)),
        "order_score": float(round(order_score, 4)),
    }


def human_explainability_coverage(row: Dict[str, Any]) -> Dict[str, Any]:
    """Explainability Coverage Score (ECS) for human judgments.

    Improvements vs. baseline:
      - Uses THE LAW section as evidence scope.
      - Safeguard coverage counts only evidence snippets supported within the LAW section.
      - Adds a quality component (normative reasoning markers + specificity).
      - If LAW-scoped evidence is missing, backfill with LAW-section pattern search.

    Outputs:
      - ECS (0..1)
      - ECS_Coverage (0..1)
      - ECS_Quality (0..1)
      - LineAdherence (0..1, evidence-based)
      - _ECS_SectionDiagnostics (for UI audit)
    """
    evidence = row.get("_autocode_evidence") or {}
    if not isinstance(evidence, dict):
        evidence = {}

    src = _get_source_text(row)
    sec = extract_sections_text(src) if src else {"law": "", "facts": "", "operative": "", "diagnostics": {}}
    law_text = str(sec.get("law") or "").strip()
    if not law_text:
        law_text = str(src or "")
    law_norm = _norm_for_span_match(law_text)
    facts_text = str(sec.get("facts") or "").strip() if src else ""

    # 1) Doctrinal line adherence (evidence-based)
    las, las_meta = human_line_adherence_score(row)
    step_evidence_score = float(las_meta.get("evidence_score", 0.0))

    # 2) Safeguard evidence coverage within LAW, with backfill
    safeguard_total = len(AXIS1_SAFEGUARDS)
    safeguard_hits = 0
    safeguard_qual_sum = 0.0

    for k in AXIS1_SAFEGUARDS:
        raw = evidence.get(k)
        if isinstance(raw, list):
            snips = raw
        elif raw:
            snips = [str(raw)]
        else:
            snips = []
        supported = [s for s in snips if _snippet_supported_in_section(str(s or ""), law_norm)]
        # Backfill from LAW if missing or not LAW-supported.
        if not supported:
            backfilled = _evidence_backfill_snippets(law_text, k)
            # Prefer LAW-supported backfill, otherwise accept backfill as weak evidence
            supported = [s for s in backfilled if _snippet_supported_in_section(str(s or ""), law_norm)] or backfilled
        if supported:
            safeguard_hits += 1
            safeguard_qual_sum += max(_snippet_quality(str(s)) for s in supported)

    safeguards_cov = (safeguard_hits / float(safeguard_total)) if safeguard_total else 0.0
    safeguards_qual = (safeguard_qual_sum / float(safeguard_hits)) if safeguard_hits else 0.0

    # 3) Remedy coverage (LAW-scoped if possible)
    remedy_eff = str(row.get("RemedyEffectiveness", "") or "").upper().strip()
    rawr = evidence.get("RemedyAccess")
    if isinstance(rawr, list):
        rem_snips = rawr
    elif rawr:
        rem_snips = [str(rawr)]
    else:
        rem_snips = []
    rem_supported = [s for s in rem_snips if _snippet_supported_in_section(str(s or ""), law_norm)]
    if not rem_supported:
        backfilled = _evidence_backfill_snippets(law_text, "RemedyAccess")
        rem_supported = [s for s in backfilled if _snippet_supported_in_section(str(s or ""), law_norm)] or backfilled
    remedy_cov = 1.0 if (rem_supported or remedy_eff not in ("", "UNK")) else 0.0
    remedy_qual = max((_snippet_quality(str(s)) for s in rem_supported), default=0.0)

    # 4) Turning point presence (LAW-scoped)
    tp = str(row.get("TurningPoint_1Sentence", "") or "").strip()
    turning_cov = 1.0 if (len(tp) >= 20 and _snippet_supported_in_section(tp, law_norm)) else 0.0
    turning_qual = _snippet_quality(tp) if turning_cov else 0.0

    # 5) Facts presence (separate from LAW)
    facts_cov = 1.0 if word_count(facts_text) >= 180 else (1.0 if word_count(str(row.get("AI_FactsBlock", "") or "")) >= 120 else 0.0)

    # Coverage and quality composites
    cov = (0.30 * step_evidence_score) + (0.50 * safeguards_cov) + (0.10 * remedy_cov) + (0.05 * turning_cov) + (0.05 * facts_cov)
    qual = (0.70 * safeguards_qual) + (0.20 * remedy_qual) + (0.10 * turning_qual)
    ecs = cov * (0.65 + 0.35 * qual)

    return {
        "ECS": float(round(ecs, 4)),
        "ECS_Coverage": float(round(cov, 4)),
        "ECS_Quality": float(round(qual, 4)),
        "LineAdherence": float(round(las, 4)),
        "LineEvidenceCoverage": float(round(step_evidence_score, 4)),
        "StepsCovered_Checkbox": int(sum(int(v) for v in (las_meta.get("checkbox") or {}).values())),
        "StepsCovered_Evidence": int(sum(int(v) for v in (las_meta.get("evidence") or {}).values())),
        "SafeguardsEvidenceCovered": int(safeguard_hits),
        "SafeguardsEvidenceCoverage": float(round(safeguards_cov, 4)),
        "SafeguardsEvidenceQuality": float(round(safeguards_qual, 4)),
        "RemedyCoverage": float(remedy_cov),
        "TurningPointCoverage": float(turning_cov),
        "FactsCoverage": float(facts_cov),
        "_ECS_SectionDiagnostics": sec.get("diagnostics") if isinstance(sec, dict) else {},
    }


