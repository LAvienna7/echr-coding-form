    def _rj_apply_redaction_to_batch(batch_items: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
        overrides = st.session_state.get("rj_redacted_overrides") or {}
        if not isinstance(overrides, dict):
            overrides = {}

        prog = st.progress(0)
        status = st.empty()
        max_passes = 3
        total_all = len(batch_items) if batch_items else 1

        passes = 0
        while passes < max_passes:
            targets = [
                b for b in batch_items
                if (not b.get("leak_ok")) or rj_redaction_needs_cleanup(str(b.get("_text") or ""))
            ]
            if not targets:
                break
            passes += 1
            status.write(f"Auto-redacting pass {passes}/{max_passes} (remaining {len(targets)})...")

            for i, b in enumerate(targets):
                txt = str(b.get("_text") or "")
                if not txt:
                    b["redacted_ok"] = False
                    b["needs_cleanup"] = True
                    prog.progress(int(((i + 1) / max(1, len(targets))) * 100))
                    continue

                base_ok = b.get("orig_leak_ok") if "orig_leak_ok" in b else b.get("leak_ok")
                attempt = int(b.get("redact_attempts", 0) or 0) + 1
                redacted_text, redaction_report, new_leak = rj_redact_to_usable_text(txt)

                # Update batch entry with redacted text and new leak status.
                b["_text"] = redacted_text
                b["text_len"] = int(len(redacted_text or ""))
                b["_leak"] = new_leak
                b["leak_ok"] = bool(new_leak.get("ok"))
                b["leak_risk"] = str(new_leak.get("risk"))
                b["leak_score"] = int(new_leak.get("score") or 0)
                b["redacted_ok"] = bool(new_leak.get("ok")) and not rj_redaction_needs_cleanup(redacted_text)
                b["orig_leak_ok"] = base_ok
                b["redact_attempts"] = attempt
                b["needs_cleanup"] = bool(rj_redaction_needs_cleanup(redacted_text))
                b["redaction_report"] = redaction_report

                # Persist across reruns by filename and overwrite on disk.
                fn = str(b.get("filename") or "")
                stamp = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
                safe_fn = re.sub(r"[^a-zA-Z0-9_.-]+", "_", fn).strip("_") or "case.txt"
                saved_path = os.path.join(ROBO_BATCH_DIR, f"redacted_overwrite__{stamp}__{safe_fn}")
                with open(saved_path, "w", encoding="utf-8") as f:
                    f.write(redacted_text)

                overrides[fn] = {
                    "text": redacted_text,
                    "saved_path": saved_path,
                    "redacted_ok": bool(new_leak.get("ok")) and not rj_redaction_needs_cleanup(redacted_text),
                    "orig_leak_ok": base_ok,
                    "redact_attempts": attempt,
                    "redaction_report": redaction_report,
                }
                b["redacted_saved_path"] = saved_path

                prog.progress(int(((i + 1) / max(1, len(targets))) * 100))

        st.session_state["rj_redacted_overrides"] = overrides
        remaining = len([
            b for b in batch_items
            if (not b.get("leak_ok")) or rj_redaction_needs_cleanup(str(b.get("_text") or ""))
        ])
        status.write(f"Auto-redaction complete. Remaining problem files: {remaining} of {total_all}.")
        return batch_items

