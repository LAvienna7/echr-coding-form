def extract_sections_text(full_text: str) -> Dict[str, Any]:
    """Best-effort section extraction used by Robo-Judge outputs."""
    raw = str(full_text or "")
    raw = raw.replace("\u00a0", " ")
    raw = re.sub(r"\r\n?", "\n", raw)
    raw = re.sub(r"[ \t]+", " ", raw)
    raw = re.sub(r"\n{3,}", "\n\n", raw).strip()
    if not raw:
        return {
            "facts": "",
            "law": "",
            "operative": "",
            "diagnostics": {"facts_start": -1, "law_start": -1, "operative_start": -1, "text_len": 0},
        }

    up = raw.upper()
    def _first_idx(needles: List[str]) -> int:
        best = -1
        for n in needles:
            idx = up.find(n)
            if idx != -1 and (best == -1 or idx < best):
                best = idx
        return best

    facts_start = _first_idx(_FACTS_MARKERS)
    law_start = _first_idx(_LAW_MARKERS)
    # Prefer explicit operative headers over generic "HOLDS".
    op_explicit = _first_idx(["FOR THESE REASONS", "OPERATIVE PROVISIONS"])
    op_holds = _first_idx(["HOLDS"])
    operative_start = op_explicit if op_explicit != -1 else op_holds

    # Fallbacks when headings are missing.
    if law_start == -1 and operative_start != -1:
        law_start = 0

    facts = raw[facts_start:law_start].strip() if facts_start != -1 and law_start != -1 and facts_start < law_start else ""
    law_end = operative_start if operative_start != -1 else len(raw)
    law = raw[law_start:law_end].strip() if law_start != -1 and law_start < law_end else ""
    operative = raw[operative_start:].strip() if operative_start != -1 else ""

    return {
        "facts": facts,
        "law": law,
        "operative": operative,
        "diagnostics": {
            "facts_start": facts_start,
            "law_start": law_start,
            "operative_start": operative_start,
            "text_len": len(raw),
        },
    }


def _evidence_backfill_snippets(law_text: str, key: str) -> List[str]:
    """Simple fallback to avoid missing-name errors during Robo-Judge contract builds."""
    text = str(law_text or "")
    if not text:
        return []
    # Lightweight snippet extraction: return the first sentence containing the key token.
    key_l = str(key or "").lower().replace("_", " ")
    sentences = re.split(r"(?<=[\.!\?])\s+", text)
    for s in sentences:
        if key_l and key_l in s.lower():
            return [s.strip()[:300]]
    return []


def safe_filename(s: str) -> str:
    s0 = re.sub(r"\s+", " ", str(s or "")).strip()
    keep = "".join(c for c in s0 if c.isalnum() or c in (" ", "-", "_"))
    return keep.replace(" ", "_")


