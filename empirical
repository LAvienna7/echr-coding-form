    st.markdown("---")
    st.subheader("Judicial Discretion: Decision-Path Diversity Tree (Human vs AI)")
    st.caption(
        "Measures diversity of doctrinal routes used to reach outcomes. "
        "For comparability, the AI side now selects one run per case to approximate the human V/NV split "
        "(treating partial violations as violations)."
    )

    def _human_path(hrow: Dict[str, Any]) -> str:
        steps = [
            ("Interference", int(hrow.get("Step_Interference", 0) or 0)),
            ("Lawfulness", int(hrow.get("Step_Lawfulness", 0) or 0)),
            ("LegitimateAim", int(hrow.get("Step_LegitimateAim", 0) or 0)),
            ("Necessity", int(hrow.get("Step_Necessity", 0) or 0)),
        ]
        step_path = "->".join([name for name, v in steps if v == 1]) or "NoSteps"
        driver = str(hrow.get("PrimaryDriver", "SG") or "SG")
        top = str(hrow.get("Human_TopFactor1", "NA") or "NA")
        return f"{step_path}|Driver:{driver}|Top:{top}"

    def _binary_outcome_label(raw_outcome: Any) -> str:
        s = str(raw_outcome or "").upper().strip()
        if s == "NV":
            return "NV"
        if s in ("V", "P"):
            return "V"
        return "UNK"

    def _robo_path_from_run(run: Dict[str, Any]) -> str:
        top = run.get("TopReasons", []) if isinstance(run.get("TopReasons", []), list) else []
        top_join = ",".join([str(t) for t in top[:3]]) if top else "NoReasons"
        return f"Top:{top_join}"

    def _pick_robo_run_for_binary(ritem: Dict[str, Any], target_binary: str) -> Optional[Dict[str, Any]]:
        rep = ritem.get("RepresentativeRun", {}) if isinstance(ritem.get("RepresentativeRun", {}), dict) else {}
        runs = ritem.get("AllRuns", []) if isinstance(ritem.get("AllRuns", []), list) else []
        run_pool = [r for r in runs if isinstance(r, dict)] or ([rep] if rep else [])
        if not run_pool:
            return None

        def _distance_from_boundary(run: Dict[str, Any]) -> Tuple[float, int]:
            score = float(run.get("DecisionScore", 0.0) or 0.0)
            threshold = float(run.get("DecisionThreshold", ROBO_BASE_THRESHOLD) or ROBO_BASE_THRESHOLD)
            run_no = int(run.get("run", 10**9) or 10**9)
            return (abs(score - threshold), run_no)

        matching = [r for r in run_pool if _binary_outcome_label(r.get("RoboOutcome", "")) == target_binary]
        if rep and _binary_outcome_label(rep.get("RoboOutcome", "")) == target_binary:
            return rep
        if matching:
            return min(matching, key=_distance_from_boundary)
        if rep:
            return rep
        return min(run_pool, key=_distance_from_boundary)

    human_paths: Dict[Tuple[str, str], int] = {}
    robo_paths: Dict[Tuple[str, str], int] = {}
    human_split = {"V": 0, "NV": 0, "UNK": 0}
    robo_split = {"V": 0, "NV": 0, "UNK": 0}
    robo_selected_cases: List[Dict[str, Any]] = []

    for d in matched:
        hrow = d.get("human_row", {})
        if isinstance(hrow, dict):
            human_outcome = _binary_outcome_label(hrow.get("Art8_Outcome", "UNK"))
            hp = _human_path(hrow)
            human_paths[(human_outcome, hp)] = human_paths.get((human_outcome, hp), 0) + 1
            human_split[human_outcome] = human_split.get(human_outcome, 0) + 1
        ritem = d.get("robo_item", {})
        if isinstance(ritem, dict):
            target_binary = human_outcome if isinstance(hrow, dict) else "UNK"
            selected_run = _pick_robo_run_for_binary(ritem, target_binary)
            if selected_run is None:
                continue
            selected_binary = _binary_outcome_label(selected_run.get("RoboOutcome", "UNK"))
            robo_selected_cases.append({
                "ritem": ritem,
                "target_binary": target_binary,
                "selected_run": selected_run,
                "selected_binary": selected_binary,
            })

    target_v = int(human_split.get("V", 0) or 0)
    current_v = sum(1 for entry in robo_selected_cases if entry.get("selected_binary") == "V")
    if current_v < target_v:
        candidates = [
            entry for entry in robo_selected_cases
            if entry.get("selected_binary") != "V" and _pick_robo_run_for_binary(entry.get("ritem", {}), "V") is not None
        ]
        candidates.sort(
            key=lambda entry: float(
                ((entry.get("ritem", {}) or {}).get("RunSummary", {}) or {}).get("p_violation", 0.0) or 0.0
            ),
            reverse=True,
        )
        for entry in candidates[: max(0, target_v - current_v)]:
            alt_run = _pick_robo_run_for_binary(entry.get("ritem", {}), "V")
            if alt_run is not None:
                entry["selected_run"] = alt_run
                entry["selected_binary"] = "V"
    elif current_v > target_v:
        candidates = [
            entry for entry in robo_selected_cases
            if entry.get("selected_binary") == "V" and _pick_robo_run_for_binary(entry.get("ritem", {}), "NV") is not None
        ]
        candidates.sort(
            key=lambda entry: float(
                ((entry.get("ritem", {}) or {}).get("RunSummary", {}) or {}).get("p_violation", 0.0) or 0.0
            )
        )
        for entry in candidates[: max(0, current_v - target_v)]:
            alt_run = _pick_robo_run_for_binary(entry.get("ritem", {}), "NV")
            if alt_run is not None:
                entry["selected_run"] = alt_run
                entry["selected_binary"] = "NV"

    for entry in robo_selected_cases:
        selected_binary = str(entry.get("selected_binary", "UNK") or "UNK")
        selected_run = entry.get("selected_run", {}) if isinstance(entry.get("selected_run", {}), dict) else {}
        rp = _robo_path_from_run(selected_run)
        robo_paths[(selected_binary, rp)] = robo_paths.get((selected_binary, rp), 0) + 1
        robo_split[selected_binary] = robo_split.get(selected_binary, 0) + 1

    def _entropy(counts: Dict[str, int]) -> float:
        total = sum(counts.values()) or 1
        ent = 0.0
        for c in counts.values():
            p = float(c) / float(total)
            if p > 0:
                ent -= p * math.log(p, 2)
        return ent

    h_entropy = _entropy({f"{k[0]}|{k[1]}": v for k, v in human_paths.items()})
    r_entropy = _entropy({f"{k[0]}|{k[1]}": v for k, v in robo_paths.items()})
    h_unique = len(human_paths)
    r_unique = len(robo_paths)

    e1, e2, e3, e4 = st.columns(4)
    e1.metric("Human unique paths", h_unique)
    e2.metric("AI unique paths", r_unique)
    e3.metric("Human path entropy", f"{h_entropy:.3f}")
    e4.metric("AI path entropy", f"{r_entropy:.3f}")
    st.caption(
        f"Human split used for the tree: V={human_split.get('V', 0)}, NV={human_split.get('NV', 0)}. "
        f"AI tree is built from one selected run per case with the closest feasible matched split: "
        f"V={robo_split.get('V', 0)}, NV={robo_split.get('NV', 0)}."
    )

    try:
        import plotly.graph_objects as go  # type: ignore

        def _build_sankey(paths: Dict[Tuple[str, str], int], title: str):
            def _clip(label: str, max_len: int = 70) -> str:
                if len(label) <= max_len:
                    return label
                return label[: max_len - 1].rstrip() + "…"

            outcomes = sorted({k[0] for k in paths.keys()}) or ["UNK"]
            root = "Article 8 case"
            outcome_labels = [f"Outcome: {o}" for o in outcomes]
            path_labels = [f"{o}: {_clip(p)}" for o, p in paths.keys()]
            labels = [root] + outcome_labels + path_labels

            label_index = {label: idx for idx, label in enumerate(labels)}
            source = []
            target = []
            value = []

            for outcome in outcomes:
                total = sum(v for (o, _), v in paths.items() if o == outcome)
                source.append(label_index[root])
                target.append(label_index[f"Outcome: {outcome}"])
                value.append(total)

            for (outcome, path), count in paths.items():
                source.append(label_index[f"Outcome: {outcome}"])
                target.append(label_index[f"{outcome}: {_clip(path)}"])
                value.append(count)

            fig = go.Figure(
                data=[
                    go.Sankey(
                        node=dict(label=labels, pad=10, thickness=14),
                        link=dict(source=source, target=target, value=value),
                    )
                ]
            )
            fig.update_layout(title_text=title, font_size=10, height=420)
            return fig

        c1, c2 = st.columns(2)
        with c1:
            st.plotly_chart(_build_sankey(human_paths, "Human decision paths"), use_container_width=True)
        with c2:
            st.plotly_chart(_build_sankey(robo_paths, "AI decision paths"), use_container_width=True)
    except Exception:
        def _tree_fallback(paths: Dict[Tuple[str, str], int], title: str):
            def _clip(label: str, max_len: int = 72) -> str:
                if len(label) <= max_len:
                    return label
                return label[: max_len - 1].rstrip() + "…"

            outcome_colors = {
                "V": "#1b5e9b",
                "NV": "#2f7f5f",
                "P": "#b58900",
                "UNK": "#6c757d",
            }
            grouped: Dict[str, List[Tuple[str, int]]] = {}
            for (outcome, path), count in sorted(paths.items(), key=lambda kv: (str(kv[0][0]), -int(kv[1]), str(kv[0][1]))):
                grouped.setdefault(str(outcome), []).append((str(path), int(count)))

            if not grouped:
                fig, ax = plt.subplots(figsize=(8, 3))
                ax.axis("off")
                ax.text(0.5, 0.5, "No decision paths available", ha="center", va="center", fontsize=12)
                ax.set_title(title)
                fig.patch.set_facecolor("white")
                return fig

            total_leaves = sum(max(1, len(items)) for items in grouped.values())
            fig_height = max(4.0, 0.75 * float(total_leaves) + 1.0)
            fig, ax = plt.subplots(figsize=(10, fig_height))
            fig.patch.set_facecolor("white")
            ax.set_facecolor("white")
            ax.axis("off")

            root_x, outcome_x, path_x = 0.08, 0.38, 0.77
            y_cursor = float(total_leaves)
            outcome_y: Dict[str, float] = {}
            leaf_nodes: List[Tuple[str, str, int, float]] = []

            for outcome, items in grouped.items():
                ys: List[float] = []
                for path, count in items:
                    y = y_cursor
                    y_cursor -= 1.0
                    ys.append(y)
                    leaf_nodes.append((outcome, path, count, y))
                outcome_y[outcome] = sum(ys) / float(len(ys)) if ys else float(total_leaves) / 2.0

            root_y = sum(outcome_y.values()) / float(len(outcome_y))
            total_cases = sum(count for items in grouped.values() for _path, count in items)

            ax.text(
                root_x,
                root_y,
                f"Article 8 case\nn={total_cases}",
                ha="center",
                va="center",
                fontsize=10,
                bbox=dict(boxstyle="round,pad=0.35", facecolor="#f8f9fa", edgecolor="#0b2a4a", linewidth=1.2),
            )

            for outcome, y in outcome_y.items():
                color = outcome_colors.get(outcome, "#6c757d")
                outcome_total = sum(count for _path, count in grouped.get(outcome, []))
                ax.plot([root_x + 0.08, outcome_x - 0.08], [root_y, y], color=color, linewidth=2.0, alpha=0.7)
                ax.text(
                    outcome_x,
                    y,
                    f"Outcome: {outcome}\nn={outcome_total}",
                    ha="center",
                    va="center",
                    fontsize=10,
                    bbox=dict(boxstyle="round,pad=0.30", facecolor="white", edgecolor=color, linewidth=1.4),
                )

            for outcome, path, count, y in leaf_nodes:
                color = outcome_colors.get(outcome, "#6c757d")
