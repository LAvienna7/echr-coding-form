def render_audit_panel(rows: List[Dict[str, Any]]) -> None:
    """Audit panel with explicit, per-case explanations.

    Layout:
      - LEFT: computer-side diagnostics (clustering keys + axis-1 cluster + neighbors + jury variance)
      - RIGHT: human-side explainability (text provenance + LAW preview + ECS + factor-level attribution)
    """
    if not st.session_state.get("audit_mode", False):
        return
    if st.session_state.get("app_subpage") != "Human Analysis":
        return

    st.markdown("---")
    with st.expander("Audit - per-case explanations (recomputed)", expanded=False):
        if not rows:
            st.info("No saved case JSONs found yet. Save at least one case to enable audit explanations.")
            return

        keys = [f"{r.get('Case_ID','')} [{r.get('SubUnit_ID','NA')}]" for r in rows]
        sel = st.selectbox("Select case", options=keys, index=0)
        idx = keys.index(sel)
        r = rows[idx]

        case_id = str(r.get("Case_ID", ""))
        subunit = str(r.get("SubUnit_ID", "NA"))
        st.write(f"Case: {case_id} - SubUnit: {subunit}")

        src = _get_source_text(r)
        sec = extract_sections_text(src) if src else {"facts": "", "law": "", "operative": "", "diagnostics": {}}
        law_text = str(sec.get("law") or "").strip() or str(src or "")
        facts_text = str(sec.get("facts") or "").strip()

        left, right = st.columns([1, 1])

        with left:
            st.subheader("Computer-side diagnostics")

            st.caption("Clustering keys (what the similarity engine actually sees)")
            st.json({
                "InterferenceType_Primary": r.get("InterferenceType_Primary"),
                "ReviewPosture": r.get("ReviewPosture"),
                "ContextTrigger": r.get("ContextTrigger"),
                "ClusterKey_Core": r.get("ClusterKey_Core"),
            })

            p = _axis1_params_from_session()
            try:
                axis1_res = compute_axis1_consistency_gap(
                    rows=rows,
                    method=p["method"],
                    sim_threshold=float(p["sim_threshold"]),
                    knn_k=int(p["knn_k"]),
                    missing_mode=p["missing_mode"],
                    min_overlap=int(p["min_overlap"]),
                    require_same_type=bool(p["require_same_type"]),
                    require_same_posture=bool(p["require_same_posture"]),
                    require_same_trigger=bool(p["require_same_trigger"]),
                    min_cluster_size=int(p["min_cluster_size"]),
                )

                st.caption("Axis 1 recomputation (clustered outcome variance within near-identical cases)")
                st.write(
                    f"consistency_gap={axis1_res.get('consistency_gap')}, overall_var={axis1_res.get('overall_var')}, "
                    f"eligible_pairs={axis1_res.get('eligible_pairs')}, edges={axis1_res.get('edges')}, singletons={axis1_res.get('singletons')}"
                )

                st.caption("Axis 1 parameters")
                st.json(p)

                cluster = _find_cluster_for_case(axis1_res, case_id)
                if cluster:
                    st.write(
                        f"Cluster: #{cluster.get('cluster')} - size={cluster.get('size')} - "
                        f"p_any_violation={cluster.get('p_any_violation')} - variance={cluster.get('variance')} - "
                        f"disagreement={cluster.get('disagreement')} - entropy={cluster.get('entropy')}"
                    )
                    st.caption("Cluster cases")
                    st.write(cluster.get("cases"))
                else:
                    st.write("Cluster membership: none (singleton or filtered out under current settings)")

                neigh = _axis1_top_neighbors(
                    rows,
                    target_idx=idx,
                    missing_mode=p["missing_mode"],
                    min_overlap=int(p["min_overlap"]),
                    require_same_type=bool(p["require_same_type"]),
                    require_same_posture=bool(p["require_same_posture"]),
                    require_same_trigger=bool(p["require_same_trigger"]),
                    topn=5,
                )
                st.caption("Top similarity neighbors (recomputed)")
                if neigh:
                    st.table({
                        "Neighbor Case_ID": [c for c, _ in neigh],
                        "Similarity": [round(s, 4) for _, s in neigh],
                    })
                else:
                    st.write("No eligible neighbors under current filter settings.")

            except Exception as e:
                st.warning(f"Could not recompute Axis 1 clustering/diagnostics: {e}")

            st.markdown("---")
            st.subheader("Jury variance")
            o = str(r.get("Art8_Outcome", "") or "")
            try:
                b = int(r.get("Art8_BinaryAnyViolation") or 0)
            except Exception:
                b = 0
            st.write(f"Stored outcome fields: Art8_Outcome={o}; Art8_BinaryAnyViolation={b}")
            if r.get("_jury_vote_evidence"):
                st.caption("Extracted jury vote evidence")
                st.code(str(r.get("_jury_vote_evidence"))[:900])
            else:
                st.write("No jury vote evidence extracted for this case (field _jury_vote_evidence empty).")

        with right:
            st.subheader("Human-side explainability")

            st.caption("Text provenance and section extraction")
            source_field = "none"
            if isinstance(r.get("_human_full_text"), str) and str(r.get("_human_full_text") or "").strip():
                source_field = "_human_full_text"
            elif isinstance(r.get("_offline_full_text"), str) and str(r.get("_offline_full_text") or "").strip():
                source_field = "_offline_full_text"

            st.json({
                "source_text_field": source_field,
                "source_text_len": int(len(src or "")),
                "section_diagnostics": sec.get("diagnostics") if isinstance(sec, dict) else {},
                "law_len": int(len(law_text or "")),
                "facts_len": int(len(facts_text or "")),
            })

            with st.expander("Preview: LAW section used for metrics", expanded=False):
                st.text_area("LAW section", value=str(law_text or "")[:8000], height=260)

            try:
                hm = human_explainability_coverage(r)
                st.caption("Recomputed human metrics")
                st.write(
                    f"ECS={hm.get('ECS')} (Coverage={hm.get('ECS_Coverage')}, Quality={hm.get('ECS_Quality')}) - "
                    f"LineAdherence={hm.get('LineAdherence')} (evidence coverage={hm.get('LineEvidenceCoverage')})"
                )
                st.caption("Metric decomposition (what moved the numbers)")
                st.json({
                    "StepsCovered_Evidence": hm.get("StepsCovered_Evidence"),
                    "StepsCovered_Checkbox": hm.get("StepsCovered_Checkbox"),
                    "SafeguardsEvidenceCovered": hm.get("SafeguardsEvidenceCovered"),
                    "SafeguardsEvidenceCoverage": hm.get("SafeguardsEvidenceCoverage"),
                    "SafeguardsEvidenceQuality": hm.get("SafeguardsEvidenceQuality"),
                    "RemedyCoverage": hm.get("RemedyCoverage"),
                    "TurningPointCoverage": hm.get("TurningPointCoverage"),
                    "FactsCoverage": hm.get("FactsCoverage"),
                    "_ECS_SectionDiagnostics": hm.get("_ECS_SectionDiagnostics"),
                })
            except Exception as e:
                st.warning(f"Could not recompute human metrics for this case: {e}")

            ev = r.get("_autocode_evidence")
            if not isinstance(ev, dict):
                ev = {}
            law_norm = _norm_for_span_match(law_text or "")

            st.caption("Safeguards attribution check (stored value, evidence, LAW support, backfill)")
            audit_rows: List[Dict[str, Any]] = []
            for k in AXIS1_SAFEGUARDS + ["RemedyAccess"]:
                stored_val = r.get(k)
                raw = ev.get(k)
                if isinstance(raw, list):
                    snips = [str(x) for x in raw if str(x or "").strip()]
                elif raw:
                    snips = [str(raw)]
                else:
                    snips = []

                supported = [s for s in snips if _snippet_supported_in_section(str(s or ""), law_norm)]
                backfill = _evidence_backfill_snippets(law_text or "", k)

                example = ""
                if supported:
                    example = supported[0]
                elif snips:
                    example = snips[0]
                elif backfill:
                    example = backfill[0]

                audit_rows.append({
                    "factor": k,
                    "stored": str(stored_val or ""),
                    "snips": int(len(snips)),
                    "law_supported": "YES" if bool(supported) else "NO",
                    "backfill_found": int(len(backfill)),
                    "example": (example[:220] + "...") if len(example) > 220 else example,
                })

            if _PANDAS_OK and pd is not None:
                st.dataframe(pd.DataFrame(audit_rows), use_container_width=True)
            else:
                st.json(audit_rows)

