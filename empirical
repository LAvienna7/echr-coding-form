def compute_pairwise_similarity_matrix(
    rows: List[Dict[str, Any]],
    weights: Dict[str, float],
    missing_mode: str = "midpoint",
    min_overlap: int = 0,
) -> Tuple[List[List[float]], List[Tuple[int, int]]]:
    """Compute the full pairwise similarity matrix.

    The second return value is kept for compatibility and is currently an empty edge list.
    """
    n = len(rows)
    sim_matrix = [[0.0 for _ in range(n)] for _ in range(n)]
    
    for i in range(n):
        sim_matrix[i][i] = 1.0
        for j in range(i + 1, n):
            sim = _axis1_pair_similarity(rows[i], rows[j], weights, missing_mode=missing_mode, min_overlap=min_overlap)
            if sim >= 0:
                sim_matrix[i][j] = float(sim)
                sim_matrix[j][i] = float(sim)
    
    return sim_matrix, []


def compute_distance_adjusted_variance(
    cluster_members: List[int],
    rows: List[Dict[str, Any]],
    sim_matrix: List[List[float]],
    k: int = 2,
) -> Tuple[float, Dict[str, Any]]:
    """
    Compute distance-adjusted variance for a cluster.
    
    Weighted disagreement = sum(weight_ij * pair_disagree_ij) / sum(weight_ij)
    where weight_ij = sim_matrix[i][j]^k
    
    Returns (adjusted_variance, diagnostics)
    """
    if len(cluster_members) < 2:
        return 0.0, {"n": len(cluster_members), "raw_variance": 0.0, "adjusted_variance": 0.0}
    
    # Get outcomes for cluster members
    outcomes = [_axis1_outcome_binary(rows[i]) for i in cluster_members]
    
    # Raw variance (Bernoulli)
    p = sum(outcomes) / len(outcomes)
    raw_var = p * (1.0 - p)
    
    # Distance-adjusted variance
    weight_sum = 0.0
    weighted_disagree = 0.0
    
    for i_idx, i in enumerate(cluster_members):
        for j_idx, j in enumerate(cluster_members):
            if i >= j:
                continue
            sim = sim_matrix[i][j]
            weight = sim ** k
            pair_disagree = 1 if outcomes[i_idx] != outcomes[j_idx] else 0
            weight_sum += weight
            weighted_disagree += weight * pair_disagree
    
    adjusted_var = (weighted_disagree / weight_sum) if weight_sum > 0 else raw_var
    
    return adjusted_var, {
        "n": len(cluster_members),
        "p": round(p, 4),
        "raw_variance": round(raw_var, 6),
        "adjusted_variance": round(adjusted_var, 6),
        "weight_sum": round(weight_sum, 4),
        "pairs_analyzed": len(cluster_members) * (len(cluster_members) - 1) // 2,
    }


def analyze_clustering_sensitivity(
    rows: List[Dict[str, Any]],
    method: str = "threshold",
    weights: Dict[str, float] = None,
    thresholds: List[float] = None,
    min_cluster_sizes: List[int] = None,
) -> Dict[str, Any]:
    """
    Run clustering across multiple threshold and min_size configurations.
    Analyze stability of findings across configurations.
    """
    if weights is None:
        weights = {
            "InterferenceType_Primary": 3.0,
            "ReviewPosture": 3.0,
            "ContextTrigger": 2.0,
            "IndepPriorAuth": 2.0,
            "ExecOnlyAuth": 1.5,
            "SelectorCategoriesConstrained": 1.0,
            "PersonLinkedSelectorsPreAuth": 1.0,
            "IndepOversight": 2.0,
            "ExPostReview": 1.5,
            "Notification": 1.0,
            "RetentionLimits": 1.5,
            "AccessLogging": 1.0,
            "DestructionRules": 1.0,
            "SharingRules_ForeignPartners": 1.0,
            "RemedyAccess": 1.5,
            "RemedyEffectiveness": 1.0,
        }
    
    if thresholds is None:
        thresholds = [0.75, 0.80, 0.85, 0.90, 0.95]
    
    if min_cluster_sizes is None:
        min_cluster_sizes = [2, 3, 5]
    
    results_by_config = []
    case_movements = {}  # Track which cases move between clusters
    
    for threshold in thresholds:
        for min_size in min_cluster_sizes:
            res = compute_axis1_consistency_gap(
                rows=rows,
                method=method,
                sim_threshold=float(threshold),
                knn_k=3,
                missing_mode="midpoint",
                min_overlap=0,
                require_same_type=False,
                require_same_posture=False,
                require_same_trigger=False,
                min_cluster_size=int(min_size),
            )
            
            config_key = f"threshold={threshold:.2f}, min_size={min_size}"
            results_by_config.append({
                "config": config_key,
                "threshold": threshold,
                "min_size": min_size,
                "n_clusters": res.get("n_clusters", 0),
                "consistency_gap": res.get("consistency_gap", 0.0),
                "overall_var": res.get("overall_var", 0.0),
                "singletons": res.get("singletons", 0),
            })
    
    # Find stable findings
    consistency_gaps = [r["consistency_gap"] for r in results_by_config if r["consistency_gap"] is not None]
    stable_gap = len(consistency_gaps) > 0
    if stable_gap:
        gap_std = (max(consistency_gaps) - min(consistency_gaps)) / (sum(consistency_gaps) / len(consistency_gaps) + 1e-6) if consistency_gaps else 0
        stable_gap = gap_std < 0.5  # Coefficient of variation < 50%
    
    return {
        "results_by_config": results_by_config,
        "n_configs_tested": len(results_by_config),
        "consistency_gap_stable": stable_gap,
        "gap_range": (min(consistency_gaps), max(consistency_gaps)) if consistency_gaps else (0.0, 0.0),
    }


def extract_claims_and_citations(
    decision_text: str,
    evidence_snippets: Dict[str, List[str]],
    doctrinal_factors: List[str] = None,
    contract: Optional[Dict[str, Any]] = None,
    dossier_text: str = "",
) -> Dict[str, Any]:
    """
    Extract structured explanation claims and their support.

    If a Robo contract is available, prefer the structured decision trace over regexes
    against the generated prose. Regex-based extraction is only a fallback.
    
    Returns:
    {
        "claims": [
            {"id": "step_interference", "text": "...", "citations": [...], "citation_strength": "strong/medium/weak"},
            ...
        ],
        "evidence_coverage": fraction_with_citations,
        "citation_quality": average_strength,
    }
    """
    if isinstance(contract, dict) and contract:
        structured = _rj_structured_claims_analysis(contract, dossier_text)
        if structured.get("claims"):
            return structured

    if doctrinal_factors is None:
        doctrinal_factors = [
            "Interference",
            "Lawfulness",
            "Legitimate Aim",
            "Necessity",
            "Quality of Law",
            "Safeguards",
            "Oversight",
            "Remedies",
        ]
    
    claims = []
    
    # Fallback: extract coarse doctrinal claims from the decision text itself.
    step_patterns = {
        "Interference": r"(there is|there has been|constitutes).{0,50}(interference|encroachment)",
        "Lawfulness": r"(in accordance with|prescribed|quality of).{0,30}(law|legislation)",
        "Legitimate Aim": r"(legitimate aim|pursues|national security|crime prevention|public safety)",
        "Necessity": r"(necessary in a democratic|proportionate|fair balance|margin of appreciation)",
    }
    
    for factor, pattern in step_patterns.items():
        try:
            m = re.search(pattern, decision_text, re.IGNORECASE)
            if m:
                snippet = decision_text[max(0, m.start()-50):min(len(decision_text), m.end()+50)]
                quality = _rj_support_quality_score([snippet], dossier_text)
                claims.append({
                    "id": f"step_{factor.lower().replace(' ', '_')}",
                    "text": f"{factor} step",
                    "snippet": snippet,
                    "citations": [snippet],
                    "citation_strength": _rj_support_strength_label(quality),
                    "quality_score": float(quality),
                    "requires_support": True,
                })
        except Exception:
            pass
    
    # Map evidence snippets to claims
    for key, snippets in evidence_snippets.items():
        if snippets:
            citations = _rj_clean_explanation_fragments(list(snippets)[:2])
            quality = _rj_support_quality_score(citations, dossier_text)
            claims.append({
                "id": f"safeguard_{key}",
                "text": f"Safeguard: {key}",
                "citations": citations,
                "citation_strength": _rj_support_strength_label(quality),
                "quality_score": float(quality),
                "requires_support": True,
            })

    claims_with_citations = sum(1 for c in claims if c.get("citations"))
    total_claims = len(claims)
    evidence_coverage = (claims_with_citations / total_claims) if total_claims else 0.0
    citation_quality = (
        sum(float(c.get("quality_score", 0.0) or 0.0) for c in claims) / float(total_claims)
        if total_claims else 0.0
    )
    
    return {
        "claims": claims,
        "evidence_coverage": round(evidence_coverage, 4),
        "citation_quality": round(citation_quality, 4),
        "total_claims": total_claims,
        "claims_with_citations": claims_with_citations,
    }


def _classify_failure_mode_impl(
    human_outcome: str,
    robo_outcome: str,
    human_evidence_coverage: float,
    robo_evidence_coverage: float,
    extraction_confidence: float,
    leakage_risk: str,
    human_robo_safeguard_overlap: float,
) -> Dict[str, Any]:
    """
    Classify the type of failure/mismatch between human and robo outcomes.
    
    Returns: {"primary_mode": str, "contributing_factors": List[str], "severity": "low/medium/high"}
    """
    if human_outcome == robo_outcome:
        return {"primary_mode": "no_mismatch", "contributing_factors": [], "severity": "none"}
    
    failure_modes = []
    severity_scores = []
    
    # 1. Extraction failure
    if extraction_confidence < 0.6:
        failure_modes.append("extraction_failure")
        severity_scores.append(0.8)
    
    # 2. Leakage contamination
    if leakage_risk in ("HIGH", "MED"):
        failure_modes.append("leakage_contamination")
        severity_scores.append(0.9 if leakage_risk == "HIGH" else 0.6)
    
    # 3. Missing safeguard evidence
    if human_evidence_coverage > 0.7 and robo_evidence_coverage < 0.5:
        failure_modes.append("missing_safeguard_evidence")
        severity_scores.append(0.7)
    
    # 4. Threshold boundary case
    if human_evidence_coverage > 0.4 and human_evidence_coverage < 0.6:
        failure_modes.append("threshold_boundary_case")
        severity_scores.append(0.5)
    
    # 5. Safeguard interpretation gap
    if human_robo_safeguard_overlap < 0.5:
        failure_modes.append("safeguard_interpretation_gap")
        severity_scores.append(0.6)
    
    # 6. Doctrinal step omission
    if robo_evidence_coverage < 0.3:
        failure_modes.append("doctrinal_step_omission")
        severity_scores.append(0.7)
    
    if not failure_modes:
        failure_modes.append("other_divergence")
        severity_scores.append(0.4)
    
    primary_mode = failure_modes[0] if failure_modes else "unknown"
    avg_severity = sum(severity_scores) / len(severity_scores) if severity_scores else 0.0
    
    if avg_severity > 0.7:
        severity = "high"
    elif avg_severity > 0.4:
        severity = "medium"
    else:
        severity = "low"
    
    return {
        "primary_mode": primary_mode,
        "contributing_factors": failure_modes,
        "severity": severity,
        "severity_score": round(avg_severity, 4),
    }


def _compute_axis1_consistency_gap_impl(
    rows: List[Dict[str, Any]],
    method: str,
    sim_threshold: float,
    knn_k: int,
    missing_mode: str,
    min_overlap: int,
    require_same_type: bool,
    require_same_posture: bool,
    require_same_trigger: bool,
    min_cluster_size: int,
) -> Dict[str, Any]:
    weights = {
        "InterferenceType_Primary": 3.0,
        "ReviewPosture": 3.0,
        "ContextTrigger": 2.0,
        "IndepPriorAuth": 2.0,
        "ExecOnlyAuth": 1.5,
        "SelectorCategoriesConstrained": 1.0,
        "PersonLinkedSelectorsPreAuth": 1.0,
        "IndepOversight": 2.0,
        "ExPostReview": 1.5,
        "Notification": 1.0,
        "RetentionLimits": 1.5,
        "AccessLogging": 1.0,
        "DestructionRules": 1.0,
        "SharingRules_ForeignPartners": 1.0,
        "RemedyAccess": 1.5,
        "RemedyEffectiveness": 1.0,
        "Flag_Journalist": 0.5,
        "Flag_LawyerPrivilege": 0.5,
        "Flag_ThirdPartyCapture": 0.5,
    }

    n = len(rows)
    edges: List[Tuple[int, int]] = []
    sims_all: List[float] = []

    def eligible(a: Dict[str, Any], b: Dict[str, Any]) -> bool:
        if require_same_type and a.get("InterferenceType_Primary") != b.get("InterferenceType_Primary"):
            return False
        if require_same_posture and a.get("ReviewPosture") != b.get("ReviewPosture"):
            return False
        if require_same_trigger and a.get("ContextTrigger") != b.get("ContextTrigger"):
            return False
        return True

    eligible_pairs = 0
    edge_count = 0

    if method == "threshold":
        for i in range(n):
            for j in range(i + 1, n):
                if not eligible(rows[i], rows[j]):
                    continue
                eligible_pairs += 1
                sim = _axis1_pair_similarity(
                    rows[i],
                    rows[j],
                    weights,
                    missing_mode=missing_mode,
                    min_overlap=min_overlap,
                )
                if sim < 0:
                    continue
                sims_all.append(sim)
                if sim >= float(sim_threshold):
                    edges.append((i, j))
                    edge_count += 1

    elif method == "knn":
        k = max(1, int(knn_k))
        for i in range(n):
            scored: List[Tuple[float, int]] = []
            for j in range(n):
                if i == j:
                    continue
                a, b = rows[i], rows[j]
                if not eligible(a, b):
                    continue
                eligible_pairs += 1
                s = _axis1_pair_similarity(a, b, weights, missing_mode=missing_mode, min_overlap=min_overlap)
                if s < 0:
                    continue
                sims_all.append(s)
                if s >= sim_threshold:
                    scored.append((s, j))
            scored.sort(key=lambda x: x[0], reverse=True)
            for s, j in scored[:k]:
                ii, jj = (i, j) if i < j else (j, i)
                edges.append((ii, jj))
                edge_count += 1

    else:
        raise ValueError("Unknown clustering method")

    components_all = _axis1_union_find_clusters(n, edges)
    singletons = sum(1 for c in components_all if len(c) == 1)

    clusters = [c for c in components_all if len(c) >= int(min_cluster_size)]
    clusters.sort(key=len, reverse=True)

    y_all = [_axis1_outcome_binary(r) for r in rows]
    p_all = (sum(y_all) / len(y_all)) if y_all else 0.0
    overall_var = _axis1_bernoulli_variance(p_all)

    cluster_stats: List[Dict[str, Any]] = []
    for idx_c, members in enumerate(clusters, start=1):
        ys = [_axis1_outcome_binary(rows[k]) for k in members]
        p = (sum(ys) / len(ys)) if ys else 0.0
        cluster_stats.append({
            "cluster": idx_c,
            "size": len(members),
            "p_any_violation": round(p, 3),
            "variance": round(_axis1_bernoulli_variance(p), 4),
            "disagreement": round(_axis1_disagreement_rate(p), 4),
            "entropy": round(_axis1_entropy(p), 4),
            "cases": [rows[k].get("Case_ID", f"case_{k}") for k in members],
        })

    consistency_gap: Optional[float] = None
    if cluster_stats:
        tot = float(sum(r["size"] for r in cluster_stats))
        consistency_gap = sum(float(r["variance"]) * float(r["size"]) for r in cluster_stats) / tot

    sim_mean = sum(sims_all) / len(sims_all) if sims_all else 0.0
    sim_min = min(sims_all) if sims_all else 0.0
    sim_max = max(sims_all) if sims_all else 0.0

    return {
        "n_rows": n,
        "eligible_pairs": eligible_pairs,
        "edges": edge_count,
        "edges_list": list(edges),
        "components_total": len(components_all),
        "singletons": singletons,
        "n_clusters": len(cluster_stats),
        "overall_var": overall_var,
        "consistency_gap": consistency_gap,
        "cluster_stats": cluster_stats,
        "clusters": clusters,
        "pair_sims": sims_all,
        "sim_mean": sim_mean,
        "sim_min": sim_min,
        "sim_max": sim_max,
    }


