                        ksig = hashlib.md5(fn.encode("utf-8", errors="ignore")).hexdigest()[:10]
                        final_case = auto_case_id
                        final_su = auto_su

                        if override or auto_case_id == "UNASSIGNED":
                            final_case = st.session_state.get(f"assign_case__{ksig}", auto_case_id)
                            final_su = st.session_state.get(f"assign_su__{ksig}", auto_su)

                        if (not override) and (final_case == "UNASSIGNED" or sc < int(min_score)):
                            report.append({
                                "filename": fn,
                                "status": "UNASSIGNED",
                                "case_id": "",
                                "subunit": auto_su,
                                "reason": f"{rsn} (score {sc})",
                            })
                            prog.progress(int((i / total) * 100))
                            continue

                        if final_case == "UNASSIGNED" or final_case not in by_id:
                            report.append({
                                "filename": fn,
                                "status": "UNASSIGNED",
                                "case_id": "",
                                "subunit": final_su,
                                "reason": "manual assignment missing",
                            })
                            prog.progress(int((i / total) * 100))
                            continue

                        try:
                            base = by_id[final_case]
                            p = save_casepack_bytes(data, fn, base["Case_ID"], final_su)

                            if do_extract:
                                extracted = extract_text_from_path(p)
                                offline_payload = build_or_update_payload_from_offline(
                                    base_case=base,
                                    subunit_id=final_su,
                                    extracted_text=extracted,
                                    source_path=p,
                                )
                                save_case(offline_payload)
                                status = "EXTRACTED"
                            else:
                                status = "SAVED"

                            report.append({
                                "filename": fn,
                                "status": status,
                                "case_id": base.get("Case_ID"),
                                "subunit": final_su,
                                "reason": ("manual override" if override else f"{rsn} (score {sc})"),
                                "saved_path": p,
                            })
                        except Exception as e:
                            report.append({
                                "filename": fn,
                                "status": "ERROR",
                                "case_id": final_case,
                                "subunit": final_su,
                                "error": str(e),
                            })

                        prog.progress(int((i / total) * 100))

                    st.session_state["_offline_batch_report"] = report

                    ok = sum(1 for r in report if r.get("status") in ("SAVED", "EXTRACTED"))
