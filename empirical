        overall = expl.get("overall_explainability")
        if overall is None and expl:
            overall = (
                float(expl.get("structure_completeness", 0.0))
                + float(expl.get("evidence_coverage_score", 0.0))
                + float(expl.get("evidence_quality_score", 0.0))
                + float(expl.get("doctrinal_fidelity_score", 0.0))
