def explainability_coverage_score(row: Dict[str, Any]) -> float:
    """
    Explainability Coverage Score (ECS), range 0.0 to 1.0

    Definition (operational, reproducible):
    ECS = (# of key coded safeguards with at least one evidence snippet) / (total key safeguards)
    where evidence snippets are taken from row.get("_autocode_evidence", {}).

    Additive artifacts (+2 denominator):
    - TurningPoint_1Sentence present
    - AI_FactsBlock length >= 80 words

    This is evidence-backed and does not reward unsubstantiated manual coding.
    """
    ev = row.get("_autocode_evidence", {}) or {}

    safeguard_keys = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
        "RemedyEffectiveness",
    ]

    covered = 0
    total = len(safeguard_keys)

    for k in safeguard_keys:
        snips = ev.get(k, [])
        try:
            if isinstance(snips, list) and len([s for s in snips if str(s).strip()]) > 0:
                covered += 1
        except Exception:
            pass

    extra_total = 2
    extra_covered = 0
    if str(row.get("TurningPoint_1Sentence", "") or "").strip():
        extra_covered += 1
    if word_count(str(row.get("AI_FactsBlock", "") or "")) >= 80:
        extra_covered += 1

    denom = float(total + extra_total)
    return (covered + extra_covered) / denom if denom else 0.0


