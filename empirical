def human_explainability_coverage(row: Dict[str, Any]) -> Dict[str, Any]:
    """Late-bound wrapper to avoid NameError before full definition loads."""
    impl = globals().get("_human_explainability_coverage_impl")
    if callable(impl):
        return impl(row)
    evidence = row.get("_autocode_evidence") if isinstance(row.get("_autocode_evidence"), dict) else {}
    safeguards = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]
    safeguard_hits = sum(1 for k in safeguards if (evidence.get(k) or []))
    safeguards_cov = safeguard_hits / float(len(safeguards)) if safeguards else 0.0
    steps = [
        int(row.get("Step_Interference", 0) or 0),
        int(row.get("Step_Lawfulness", 0) or 0),
        int(row.get("Step_LegitimateAim", 0) or 0),
        int(row.get("Step_Necessity", 0) or 0),
    ]
    line_adherence = sum(steps) / 4.0
    remedy_cov = 1.0 if str(row.get("RemedyEffectiveness", "") or "").upper() not in ("", "UNK") else 0.0
    turning_cov = 1.0 if len(str(row.get("TurningPoint_1Sentence", "") or "")) >= 20 else 0.0
    facts_cov = 1.0 if len(str(row.get("AI_FactsBlock", "") or "")) >= 120 else 0.0
    ecs_cov = (safeguards_cov + line_adherence + remedy_cov + turning_cov + facts_cov) / 5.0
    return {
        "ECS": float(round(ecs_cov, 4)),
        "ECS_Coverage": float(round(ecs_cov, 4)),
        "ECS_Quality": 0.0,
        "LineAdherence": float(round(line_adherence, 4)),
        "LineEvidenceCoverage": float(round(line_adherence, 4)),
        "SafeguardsEvidenceCoverage": float(round(safeguards_cov, 4)),
        "SafeguardsEvidenceQuality": 0.0,
        "StepsCovered_Checkbox": int(sum(steps)),
        "StepsCovered_Evidence": int(sum(steps)),
        "SafeguardsEvidenceCovered": int(safeguard_hits),
        "RemedyCoverage": float(remedy_cov),
        "TurningPointCoverage": float(turning_cov),
        "FactsCoverage": float(facts_cov),
    }


