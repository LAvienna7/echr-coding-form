def human_case_needs_refresh(payload: Dict[str, Any]) -> bool:
    """Early-safe stale-dossier detector for pages dispatched before helper definitions load."""
    try:
        schema_version = int(payload.get("_human_autocode_schema_version", 0) or 0)
    except Exception:
        schema_version = 0
    if schema_version < int(HUMAN_AUTOCODE_SCHEMA_VERSION):
        return True
    vals = [
        str(payload.get(k, "") or "").upper().strip()
        for k in [
            "IndepPriorAuth",
            "ExecOnlyAuth",
            "SelectorCategoriesConstrained",
            "PersonLinkedSelectorsPreAuth",
            "IndepOversight",
            "ExPostReview",
            "Notification",
            "RetentionLimits",
            "AccessLogging",
            "DestructionRules",
            "SharingRules_ForeignPartners",
            "RemedyAccess",
        ]
    ]
    human_text = str(payload.get("_human_full_text", "") or payload.get("_offline_full_text", "") or "").strip()
    text_norm = re.sub(r"\s+", " ", human_text).strip()
    looks_placeholder = text_norm in ("", "HUDOC - European Court of Human Rights")
    short_text = len(text_norm) < 200
    flat_part = bool(vals) and all(v == "PART" for v in vals)
    all_unk = bool(vals) and all(v == "UNK" for v in vals)
    default_driver = str(payload.get("PrimaryDriver", "SG") or "SG").upper().strip() == "SG"
    missing_gt = any(k not in payload for k, _label in GT_CHECKS)
    missing_steps = any(k not in payload for k in HUMAN_LINE_STEPS)
    step_values = [int(payload.get(k, 1) or 1) for k in HUMAN_LINE_STEPS]
    all_steps_one = bool(step_values) and all(v == 1 for v in step_values)
    evidence = payload.get("_autocode_evidence") if isinstance(payload.get("_autocode_evidence"), dict) else {}
    evidence_hits = sum(1 for k in evidence.keys() if not str(k).startswith("_") and evidence.get(k))
    legacy_empty_autocode = all_unk and all_steps_one and evidence_hits == 0
    return looks_placeholder or short_text or (flat_part and default_driver) or legacy_empty_autocode or missing_gt or missing_steps


