def _snippet_supported_in_section(snippet: str, section_norm: str) -> bool:
    """Robust support check using token overlap (not exact match)."""
    if not snippet or not section_norm:
        return False
    sn = _norm_for_span_match(snippet)
    if len(sn) < 18:
        return False
    toks = [t for t in sn.split(" ") if len(t) >= 4]
    toks = toks[:14]
    if len(toks) < 3:
        return False
    hit = sum(1 for t in toks if t in section_norm)
    needed = max(3, int(math.ceil(0.55 * len(toks))))
    return hit >= needed


