def _norm_text_for_search(text: str) -> str:
    t = str(text or "")
    t = t.replace("\u00a0", " ")
    t = re.sub(r"\s+", " ", t)
    return t


def _yesno_severity_impl(v: Any) -> int:
    s = str(v or "").upper().strip()
    # deficit severity: YES = 0, PART/UNK = 1, NO = 2
    if s == "YES":
        return 0
    if s == "NO":
        return 2
    if s == "PART":
        return 1
    return 1


def _field_yesno_severity_impl(field: str, v: Any) -> int:
    s = str(v or "").upper().strip()
    if str(field or "").strip() == "ExecOnlyAuth":
        if s == "YES":
            return 2
        if s == "NO":
            return 0
        if s == "PART":
            return 1
        return 1
    return _yesno_severity_impl(v)


def _remedy_severity_impl(v: Any) -> int:
    s = str(v or "").upper().strip()
    # deficit severity: EFF = 0, LIM/UNK = 1, NONE = 2
    if s == "EFF":
        return 0
    if s == "NONE":
        return 2
    if s == "LIM":
        return 1
    return 1


def extract_art8_outcome_from_text(full_text: str) -> str:
    """Best-effort extraction of the human Art. 8 outcome from judgment text.

    Returns: V / NV / P
    """
    raw = str(full_text or "")
    sec = extract_sections_text(raw)
    operative = str(sec.get("operative") or "")
    # Prefer operative part if available, otherwise fall back to full text.
    t = _norm_text_for_search(operative if operative else raw).lower()

    # Strip admissibility-only language (not an outcome on the merits).
    if re.search(r"\binadmissible\b|\badmissible\b", t):
        t = re.sub(r"(inadmissible|admissible)[^\.]*\.", " ", t, flags=re.IGNORECASE)
        t = re.sub(r"\s+", " ", t).strip()

    # Operative-focused sentence scan for Article 8 outcome.
    sent_outcomes: List[str] = []
    for s in re.split(r"(?<=[\.!\?])\s+", t):
        if not re.search(r"article\s*8|art\.?\s*8", s):
            continue
        if re.search(r"no\s+violation\s+of\s+article\s*8", s) or re.search(r"no\s+breach\s+of\s+article\s*8", s):
            sent_outcomes.append("NV")
        elif re.search(r"\bviolation\s+of\s+article\s*8\b", s) or re.search(r"\bbreach\s+of\s+article\s*8\b", s):
            sent_outcomes.append("V")

    if sent_outcomes:
        if "V" in sent_outcomes and "NV" in sent_outcomes:
            return "P"
        if "NV" in sent_outcomes:
            return "NV"
        if "V" in sent_outcomes:
            return "V"

    nv = bool(re.search(r"no\s+violation\s+of\s+article\s*8", t)) or bool(re.search(r"no\s+breach\s+of\s+article\s*8", t))
    v = bool(re.search(r"\bviolation\s+of\s+article\s*8\b", t)) or bool(re.search(r"\bbreach\s+of\s+article\s*8\b", t))

    if nv and v:
        return "P"
    if nv:
        return "NV"
    if v:
        return "V"

    # Fallback: operative-part style
    holds_nv = bool(re.search(r"holds?,\s*(unanimously|by\s+[^\s]+\s+votes\s+to\s+[^\s]+)\s*,?\s*that\s+there\s+has\s+been\s+no\s+violation\s+of\s+article\s*8", t))
    holds_v = bool(re.search(r"holds?,\s*(unanimously|by\s+[^\s]+\s+votes\s+to\s+[^\s]+)\s*,?\s*that\s+there\s+has\s+been\s+a\s+violation\s+of\s+article\s*8", t))
    if holds_nv and holds_v:
        return "P"
    if holds_nv:
        return "NV"
    if holds_v:
        return "V"

    return "P"


def infer_ground_truth_checks_from_text(text: str) -> Dict[str, int]:
    """Populate GT_* checkboxes (0/1) from the judgment text.

    Heuristic coverage proxy, not a doctrinal classifier.
    """
    sec = extract_sections_text(text or "")
    primary_sources = _unique_text_sources([str(sec.get("law") or "")], [str(sec.get("operative") or "")])
    secondary_sources = _unique_text_sources([str(sec.get("facts") or "")], [str(text or "")])

    def has_any(pats: List[str]) -> bool:
        return bool(find_snippets_in_sources(primary_sources, pats, max_snips=1) or find_snippets_in_sources(secondary_sources, pats, max_snips=1))

    return {
        "GT_Accessibility": int(has_any([r"accessible", r"published", r"publicly\s+available", r"available\s+to\s+the\s+public"])),
        "GT_Foreseeability": int(has_any([r"foresee", r"foreseeable", r"predictable", r"with\s+sufficient\s+clarity"])),
        "GT_ScopeClarity": int(has_any([r"scope", r"limits\s+of\s+the\s+power", r"clearly\s+defined", r"clearly\s+delimited", r"categories of selectors?"])),
        "GT_Authorisation": int(has_any([
            r"judicial authori[sz]ation",
            r"authori[sz]ed by (a|the) (judge|court)",
            r"court\s+order",
            r"warrant",
            r"secretary\s+of\s+state",
            r"\bminister\b",
            r"authori[sz]ed by (the )?(government|executive|prosecutor)",
        ])),
        "GT_Oversight": int(has_any([r"oversight", r"supervision", r"commissioner", r"supervisory\s+authority", r"g\s*10\s+commission", r"parliamentary\s+oversight"])),
        "GT_ExPostReview": int(has_any([r"ex\s+post", r"post\s+facto", r"subsequent\s+review", r"review\s+after\s+the\s+event"])),
        "GT_Notification": int(has_any([r"notification", r"to\s+be\s+informed", r"subsequently\s+informed", r"duty to notify"])),
        "GT_RetentionDestruction": int(has_any([
            r"retention period",
            r"storage\s+period",
            r"time[-\s]*limit",
            r"destroyed",
            r"erasure",
            r"deleted",
            r"destruction",
        ])),
        "GT_Remedies": int(has_any([
            r"effective\s+remedy",
            r"judicial\s+review",
            r"constitutional\s+complaint",
            r"investigatory\s+powers\s+tribunal",
            r"interception\s+of\s+communications\s+tribunal",
            r"complaint to (a|the) (court|tribunal)",
            r"avenue of redress",
            r"seek redress",
        ])),
        "GT_ProportionalityFairBalance": int(has_any([
            r"proportion",
            r"proportionality",
            r"fair\s+balance",
            r"necessary\s+in\s+a\s+democratic\s+society",
            r"adequate\s+and\s+effective\s+guarantees",
        ])),
    }


def infer_primary_driver_from_text(text: str) -> str:
    sec = extract_sections_text(text or "")
    primary_sources = _unique_text_sources([str(sec.get("law") or "")], [str(sec.get("operative") or "")])
    secondary_sources = _unique_text_sources([str(sec.get("facts") or "")], [str(text or "")[:5000]])

    def score(pats: List[str]) -> int:
        primary_hits = find_snippets_in_sources(primary_sources, pats, max_snips=3)
        secondary_hits = find_snippets_in_sources(secondary_sources, pats, max_snips=2)
        return (2 * len(primary_hits)) + len(secondary_hits)

    scores = {"LWF": 0, "REM": 0, "PROP": 0, "SG": 0}
    scores["LWF"] += score([
        r"not in accordance with the law",
        r"quality of the law",
        r"accessible",
        r"foreseeable",
        r"with sufficient clarity",
    ])
    scores["REM"] += score([
        r"no effective remedy",
        r"ineffective remedy",
        r"article 13",
        r"judicial review",
        r"constitutional complaint",
        r"investigatory powers tribunal",
        r"interception of communications tribunal",
        r"avenue of redress",
    ])
    scores["PROP"] += score([
        r"not necessary in a democratic society",
        r"proportion",
        r"fair balance",
        r"margin of appreciation",
        r"pressing social need",
    ])
    scores["SG"] += score([
        r"adequate and effective safeguards",
        r"end[-\s]*to[-\s]*end safeguards",
        r"independent oversight",
        r"ex post review",
        r"notification",
        r"retention period",
        r"destruction",
        r"sharing with foreign",
    ])
    best = max(scores.items(), key=lambda kv: kv[1])
    if best[1] > 0:
        return best[0]
    return "SG"


def derive_top_factors_from_payload(payload: Dict[str, Any]) -> List[str]:
    """Derive Human_TopFactor1-3 from the safeguards grid.

    Uses deficit severity (NO > PART/UNK > YES) weighted by doctrinal relevance.
    """
    mapping: List[Tuple[str, str, float]] = [
        ("IndepPriorAuth", "AUTH", 2.0),
        ("ExecOnlyAuth", "AUTH", 1.5),
        ("SelectorCategoriesConstrained", "SELECTOR", 1.0),
        ("PersonLinkedSelectorsPreAuth", "SELECTOR", 1.0),
        ("IndepOversight", "OVERS", 2.0),
        ("ExPostReview", "REVIEW", 1.5),
        ("Notification", "NOTICE", 1.0),
        ("RetentionLimits", "RETAIN", 1.5),
        ("AccessLogging", "OVERS", 1.0),
        ("DestructionRules", "DESTROY", 1.0),
        ("SharingRules_ForeignPartners", "SHARING", 1.0),
        ("RemedyAccess", "REMEDY", 1.5),
    ]

    deficits: List[Tuple[float, str]] = []
    for field, factor, w in mapping:
        sev = _field_yesno_severity(field, payload.get(field))
        score = float(sev) * float(w)
        if score > 0:
            deficits.append((score, factor))

    rem_score = float(_remedy_severity(payload.get("RemedyEffectiveness"))) * 1.0
    if rem_score > 0:
        deficits.append((rem_score, "REMEDY"))

    deficits.sort(key=lambda x: x[0], reverse=True)

    out: List[str] = []
    for _score, fac in deficits:
        if fac not in out:
            out.append(fac)
        if len(out) >= 3:
            break

    if not out:
        out = ["NA"]

    return out[:3]


def _wordnum_to_int(s: str) -> Optional[int]:
    m = {
        "one": 1,
        "two": 2,
        "three": 3,
        "four": 4,
        "five": 5,
        "six": 6,
        "seven": 7,
        "eight": 8,
        "nine": 9,
        "ten": 10,
        "eleven": 11,
        "twelve": 12,
        "thirteen": 13,
        "fourteen": 14,
        "fifteen": 15,
        "sixteen": 16,
        "seventeen": 17,
        "eighteen": 18,
        "nineteen": 19,
        "twenty": 20,
        "twenty one": 21,
    }
    s0 = str(s or "").strip().lower()
    if not s0:
        return None
    s0 = s0.replace("-", " ")
    if s0.isdigit():
        try:
            return int(s0)
        except Exception:
            return None
    return m.get(s0)


def extract_article8_vote_split(full_text: str) -> Dict[str, Any]:
    """Extract the Article 8 vote split.

    Looks for: 'by X votes to Y ... (no) violation of Article 8'.
    Stores minority size (absolute + relative) for jury variance.
    """
    raw = str(full_text or "")
    sec = extract_sections_text(raw)
    operative = str(sec.get("operative") or "")
    t = _norm_text_for_search(operative if operative else raw)
    pattern = re.compile(
        r"by\s+(\d+|one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen|eighteen|nineteen|twenty|twenty[-\s]one)\s+votes?\s+to\s+(\d+|one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen|eighteen|nineteen|twenty|twenty[-\s]one)",
        flags=re.IGNORECASE,
    )

    for m in pattern.finditer(t):
        a = max(0, m.start() - 500)
        b = min(len(t), m.end() + 800)
        window = t[a:b]
        wl = window.lower()

        if not re.search(r"article\s*8|art\.?\s*8", wl):
            continue

        x = _wordnum_to_int(m.group(1))
        y = _wordnum_to_int(m.group(2))
        if x is None or y is None:
            continue

        total = int(x) + int(y)
        if total <= 0:
            continue

        v_votes: Optional[int] = None
        nv_votes: Optional[int] = None

        if re.search(r"no\s+violation", wl):
            nv_votes = int(x)
            v_votes = int(y)
        elif re.search(r"\bviolation\b", wl) and not re.search(r"no\s+violation", wl):
            v_votes = int(x)
            nv_votes = int(y)

        if v_votes is None or nv_votes is None:
            continue

        minority = int(min(v_votes, nv_votes))
        return {
            "Jury_ViolationVotes": int(v_votes),
            "Jury_NoViolationVotes": int(nv_votes),
            "Jury_TotalVotes": int(total),
            "Jury_MinorityVotes": int(minority),
            "Jury_MinorityShare": float(minority) / float(total) if total else 0.0,
            "_jury_vote_evidence": window.strip()[:520],
        }

    tl = t.lower()
    if re.search(r"unanimously", tl) and re.search(r"article\s*8|art\.?\s*8", tl) and re.search(r"no\s+violation|\bviolation\b", tl):
        return {
            "Jury_MinorityVotes": 0,
            "Jury_MinorityShare": 0.0,
            "_jury_vote_evidence": "unanimously (Article 8)",
        }

    return {}


def apply_human_ground_truth_and_factors(payload: Dict[str, Any], source_text: str, set_outcome: bool = True) -> Dict[str, Any]:
    """Fill Section 6 (human ground truth) and Section 8 (human decisive factors) from uploaded/judgment text."""
    text = _normalize_human_source_text(source_text or "")
    llm = _llm_extract_human_fields(text) if text else {}

    # 6) Human ground truth: outcome + GT checks
    if set_outcome:
        outcome = ""
        if isinstance(llm, dict) and llm.get("Art8_Outcome") in OUTCOME_OPTIONS:
            outcome = str(llm.get("Art8_Outcome"))
        if not outcome:
            outcome = extract_art8_outcome_from_text(text)
        payload["Art8_Outcome"] = outcome
        payload["Art8_BinaryAnyViolation"] = 0 if outcome == "NV" else 1

    payload.update(infer_ground_truth_checks_from_text(text))
    payload.update(infer_doctrinal_steps_from_text(text))

    # Primary driver: text-based signal
    if isinstance(llm, dict) and llm.get("PrimaryDriver"):
        payload["PrimaryDriver"] = llm.get("PrimaryDriver")
    else:
        payload["PrimaryDriver"] = infer_primary_driver_from_text(text)

    # 8) Decisive factors: derive from safeguards grid
    if isinstance(llm, dict) and llm.get("Human_TopFactor1"):
        payload["Human_TopFactor1"] = llm.get("Human_TopFactor1", "NA")
        payload["Human_TopFactor2"] = llm.get("Human_TopFactor2", "NA")
        payload["Human_TopFactor3"] = llm.get("Human_TopFactor3", "NA")
    else:
        top = derive_top_factors_from_payload(payload)
        payload["Human_TopFactor1"] = top[0] if len(top) > 0 else "NA"
        payload["Human_TopFactor2"] = top[1] if len(top) > 1 else "NA"
        payload["Human_TopFactor3"] = top[2] if len(top) > 2 else "NA"

    # Jury split
    if isinstance(llm, dict) and any(k in llm for k in ["Jury_ViolationVotes", "Jury_NoViolationVotes", "Jury_TotalVotes", "Jury_MinorityVotes", "Jury_MinorityShare"]):
        for k in ["Jury_ViolationVotes", "Jury_NoViolationVotes", "Jury_TotalVotes", "Jury_MinorityVotes", "Jury_MinorityShare"]:
            if k in llm:
                payload[k] = llm.get(k)
    else:
        payload.update(extract_article8_vote_split(text))

    payload.setdefault("_autofill_notes", [])
    if isinstance(llm, dict) and llm:
        if llm.get("_llm_error"):
            payload["_autofill_notes"].append(
                f"LLM extraction requested but failed ({llm.get('_llm_error')}). Heuristics used instead."
            )
        else:
            payload["_autofill_notes"].append(
                "LLM extraction: Section 6 (GT_* and Art8 outcome), Section 8 (decisive factors), and jury vote split were extracted from text. Verify against source."
            )
    else:
        payload["_autofill_notes"].append(
            "Heuristic extraction: Section 6 (GT_* and optionally Art8 outcome), Section 8 (decisive factors), and jury vote split were extracted from text. Verify against source; see _jury_vote_evidence if present."
        )
    if not text:
        payload["_autofill_notes"].append(
            "Human ground-truth extraction had no substantive source text. Outcome may still come from HUDOC conclusion, but GT_* and decisive-factor fields should be verified manually."
        )

    payload["_human_autocode_schema_version"] = int(HUMAN_AUTOCODE_SCHEMA_VERSION)

    return payload


def recompute_autofill(base_case: Dict[str, Any], subunit_id: str) -> Dict[str, Any]:
    meta = hudoc_lookup_from_case(base_case.get("Case_ID", ""), base_case.get("App_No", ""))
    if meta.get("_status") == "deps_missing":
        raise RuntimeError("Missing dependencies. Install: pip install echr-extractor dateparser")
    if meta.get("_status") != "ok":
        raise RuntimeError(f"HUDOC lookup failed: {meta.get('_status')}")

    hudoc_text = _coerce_text(meta.get("_full_text", "") or "")
    full_text, source_kind, source_path = _resolve_best_human_source_text(base_case.get("Case_ID", ""), subunit_id, hudoc_text)
    conclusion = _coerce_text(meta.get("conclusion", "") or "")

    payload = autofill_payload_from_hudoc(base_case, subunit_id)
    payload["_hudoc_matched_appno"] = meta.get("_matched_appno")
    if source_path:
        payload["_offline_source_path"] = source_path
        payload["_offline_full_text"] = full_text

    payload.update(autocode_safeguards_and_flags(conclusion, full_text))

    # Persist source text for downstream human metrics (ECS / Line Adherence)
    payload["_human_full_text"] = full_text
    payload["TurningPoint_1Sentence"] = extract_turning_point(conclusion, full_text)


    # Derive decisive factors and jury split from the full judgment text (do not override conclusion-derived outcome here)
    try:
        payload = apply_human_ground_truth_and_factors(payload, full_text, set_outcome=False)
    except Exception:
        pass

    payload.setdefault("_autofill_notes", [])
    payload["_autofill_notes"].append("Safeguards/flags/driver autocode is heuristic. Verify via _autocode_evidence.")
    if source_kind == "casepack":
        payload["_autofill_notes"].append("Human-case extraction used the locally saved case pack because HUDOC full text was unavailable or non-substantive.")
    elif not full_text:
        payload["_autofill_notes"].append("No substantive full judgment text was available. Safeguards remain UNK until a case pack or valid HUDOC full text is available.")

    payload = force_no_unk_safeguards(payload)
    payload["_human_autocode_schema_version"] = int(HUMAN_AUTOCODE_SCHEMA_VERSION)
    return payload


def diff_payload(a: Dict[str, Any], b: Dict[str, Any], keys: List[str]) -> List[Dict[str, Any]]:
    out: List[Dict[str, Any]] = []
    for k in keys:
        if a.get(k) != b.get(k):
            out.append({"field": k, "current": a.get(k), "recomputed": b.get(k)})
    return out


def infer_outcome_from_conclusion(conclusion: str) -> str:
    if not conclusion:
        return "P"

    c = re.sub(r"\s+", " ", conclusion).strip().lower()
    has_a8 = bool(re.search(r"\b(article\s*8|art\.?\s*8)\b", c))
    if not has_a8:
        return "P"

    nv = bool(re.search(r"\bno\s+violation\b.*\b(article\s*8|art\.?\s*8)\b|\b(article\s*8|art\.?\s*8)\b.*\bno\s+violation\b", c))
    v = bool(re.search(r"\bviolation\b", c)) and not nv

    if v and nv:
        return "P"
    if nv:
        return "NV"
    if v:
        return "V"
    return "P"


def infer_interference_type(text: str) -> str:
    t = (text or "").lower()
    if any(k in t for k in ["bulk interception", "strategic monitoring", "signals intelligence", "mass surveillance"]):
        return "BI"
    if any(k in t for k in ["data retention", "retention of", "communications data", "traffic data", "subscriber data"]):
        return "RET"
    if any(k in t for k in ["gps", "geolocation", "location tracking"]):
        return "GPS"
    if any(k in t for k in ["workplace", "employer", "employee", "email", "internet", "internet usage", "telephone numbers dialled"]):
        return "CDA"
    if any(k in t for k in ["telephone tapping", "wiretap", "interception", "metering"]):
        return "TI"
    if any(k in t for k in ["covert listening", "listening device", "bugging"]):
        return "CLD"
    if any(k in t for k in ["intelligence file", "security service file", "data storage", "personal data were stored", "register"]):
        return "FILE"
    return "TI"


def infer_review_posture(text: str) -> str:
    t = (text or "").lower()
    if any(k in t for k in ["in abstracto", "potential victim", "system of secret", "surveillance legislation", "general regime", "bulk regime", "legislation permitting"]):
        return "REG"
    return "IND"


def infer_context_trigger(text: str) -> str:
    t = (text or "").lower()
    if "national security" in t or "terror" in t or "espionage" in t or "foreign intelligence" in t:
        return "NS"
    if "crime" in t or "criminal" in t:
        return "CP"
    return "OTH"


def extract_facts_block(full_text: str, target_words: int = 170) -> str:
    if not full_text:
        return ""
    sec = extract_sections_text(full_text)
    snippet = str(sec.get("facts") or "").strip()
    if not snippet:
        t = re.sub(r"\s+", " ", full_text).strip()
        markers = ["THE FACTS", "I. THE CIRCUMSTANCES OF THE CASE", "THE CIRCUMSTANCES OF THE CASE"]
        start = 0
        upper = t.upper()
        for m in markers:
            idx = upper.find(m)
            if idx != -1:
                start = idx
                break
        stop_markers = ["THE LAW", "AS TO THE LAW"]
        stop = len(t)
        for m in stop_markers:
            idx = upper.find(m)
            if idx != -1 and idx > start:
                stop = idx
                break
        snippet = t[start:stop]
    words = snippet.split()
    return " ".join(words[:target_words])


def autofill_payload_from_hudoc(base_case: Dict[str, Any], subunit_id: str) -> Dict[str, Any]:
    meta = hudoc_lookup_from_case(base_case.get("Case_ID", ""), base_case.get("App_No", ""))
    if meta.get("_status") == "deps_missing":
        raise RuntimeError("Missing dependencies. Install: pip install echr-extractor dateparser")
    if meta.get("_status") != "ok":
        raise RuntimeError(f"HUDOC lookup failed: {meta.get('_status')}")

    hudoc_text = _coerce_text(meta.get("_full_text", "") or "")
    full_text, source_kind, source_path = _resolve_best_human_source_text(base_case.get("Case_ID", ""), subunit_id, hudoc_text)
    conclusion = _coerce_text(meta.get("conclusion", "") or "")

    outcome = infer_outcome_from_conclusion(conclusion)

    c_low = re.sub(r"\s+", " ", (conclusion or "")).strip().lower()
    c_tmp = c_low.replace("no violation", "no_violation")

    nv_a8 = bool(
        re.search(
            r"\bno_violation\b.*\b(article\s*8|art\.?\s*8)\b|\b(article\s*8|art\.?\s*8)\b.*\bno_violation\b",
            c_tmp,
        )
    )
    v_a8 = bool(
        re.search(
            r"\bviolation\b.*\b(article\s*8|art\.?\s*8)\b|\b(article\s*8|art\.?\s*8)\b.*\bviolation\b",
            c_tmp,
        )
    )

    if v_a8 and nv_a8:
        outcome = "P"
    any_v = 1 if outcome in ["V", "P"] else 0

    year = base_case.get("Year")
    kp = meta.get("kpdate") or meta.get("decisiondate")
    if kp and dateparse:
        dt = dateparse(str(kp))
        if dt:
            year = dt.year

    chamber = base_case.get("Chamber", "CH")
    ob = (meta.get("originatingbody") or "").lower()
    if "grand chamber" in ob:
        chamber = "GC"

    text_probe = " ".join([base_case.get("Case_ID", ""), conclusion, full_text[:8000]])
    it_primary = infer_interference_type(text_probe)
    posture = infer_review_posture(text_probe)
    trigger = infer_context_trigger(text_probe)

    facts_block = extract_facts_block(full_text)

    notes = [
        "Art8_Outcome inferred from HUDOC conclusion.",
        "InterferenceType_Primary/ReviewPosture/ContextTrigger inferred heuristically. Verify.",
        "Facts block is extractive. Standardise to 120-180 words for your AI runs.",
    ]
    if source_kind == "hudoc":
        notes.append("Full text fetched from HUDOC and accepted as substantive judgment text.")
    elif source_kind == "casepack":
        notes.append("HUDOC full text was unavailable/non-substantive; using the locally saved case pack for human extraction.")
    else:
        notes.append("No substantive full judgment text available yet; only outcome-level metadata could be inferred reliably.")

    payload: Dict[str, Any] = {
        "Case_ID": base_case.get("Case_ID", ""),
        "App_No": base_case.get("App_No", ""),
        "Year": int(year) if year else int(base_case.get("Year", 0)),
        "Chamber": chamber,
        "Merits_Judgment": 1,
        "MultiRegime": 0,
        "SubUnit_ID": subunit_id or "NA",
        "Art8_Outcome": outcome,
        "Art8_BinaryAnyViolation": int(any_v),
        "InterferenceType_Primary": it_primary,
        "ReviewPosture": posture,
        "ContextTrigger": trigger,
        "Step_Interference": 0,
        "Step_Lawfulness": 0,
        "Step_LegitimateAim": 0,
        "Step_Necessity": 0,
        "PrimaryDriver": "SG",
        "TurningPoint_1Sentence": "",
        "IndepPriorAuth": "UNK",
        "ExecOnlyAuth": "UNK",
        "SelectorCategoriesConstrained": "UNK",
        "PersonLinkedSelectorsPreAuth": "UNK",
        "IndepOversight": "UNK",
        "ExPostReview": "UNK",
        "Notification": "UNK",
        "RetentionLimits": "UNK",
        "AccessLogging": "UNK",
        "DestructionRules": "UNK",
        "SharingRules_ForeignPartners": "UNK",
        "RemedyAccess": "UNK",
        "RemedyEffectiveness": "UNK",
        "Flag_Journalist": 0,
        "Flag_LawyerPrivilege": 0,
        "Flag_ThirdPartyCapture": 0,
        "Flag_CrossArticleGravity": 0,
        "Human_TopFactor1": "NA",
        "Human_TopFactor2": "NA",
        "Human_TopFactor3": "NA",
        "AI_FactsBlock": facts_block,
        "_hudoc_itemid": meta.get("itemid"),
        "_hudoc_kpdate": meta.get("kpdate") or meta.get("decisiondate"),
        "_hudoc_conclusion": conclusion,
        "_autofill_notes": notes,
    }
    if source_path:
        payload["_offline_source_path"] = source_path
        payload["_offline_full_text"] = full_text

    payload.update(autocode_safeguards_and_flags(conclusion, full_text))

    # Persist source text for downstream human metrics (ECS / Line Adherence)
    payload["_human_full_text"] = full_text
    payload["TurningPoint_1Sentence"] = extract_turning_point(conclusion, full_text)


    # Derive decisive factors and jury split from the full judgment text (do not override conclusion-derived outcome here)
    try:
        payload = apply_human_ground_truth_and_factors(payload, full_text, set_outcome=False)
    except Exception:
        pass

    payload["ClusterKey_Core"] = f"{payload['InterferenceType_Primary']}_{payload['ReviewPosture']}_{payload['ContextTrigger']}"
    payload = force_no_unk_safeguards(payload)
    payload["_human_autocode_schema_version"] = int(HUMAN_AUTOCODE_SCHEMA_VERSION)
    return payload

