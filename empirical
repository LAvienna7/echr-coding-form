    # ================================================================
    # NEW: Consistency Gap Comparison (Human vs Robo Decision Stability)
    # ================================================================
    st.markdown("---")
    st.subheader("Consistency Gap Comparison: Human vs Robo Decision Stability")
    st.caption(
        "Compare how consistently humans vs Robo-Judge decide within the same near-identical case clusters. "
        "Clusters are derived from the current Axis 1 similarity settings, then the same cluster membership is applied to both human and Robo outcomes."
    )

    human_outcomes = []
    robo_outcomes = []
    human_ecs_scores = []
    robo_ecs_scores = []
    robo_variances = []

    for d in comparison_data:
        human_outcome_binary = 0 if str(d["Human_Outcome"]).upper() == "NV" else 1
