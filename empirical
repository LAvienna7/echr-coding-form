    else:
        st.caption("Consistency Gap = outcome dispersion among near-identical clusters after controlling for legally relevant factors (your feature grid).")

        a1, a2, a3 = st.columns(3)
        with a1:
            method = st.selectbox("Clustering method", ["threshold", "knn"], index=1, key="axis1_method")
