def _axis1_encode_yesno(v: Any) -> float:
    s = str(v or "").upper().strip()
    if s == "YES":
        return 1.0
    if s == "NO":
        return 0.0
    if s == "PART":
        return 0.5
    return 0.5


def _axis1_encode_remedy_eff(v: Any) -> float:
    s = str(v or "").upper().strip()
    if s == "EFF":
        return 1.0
    if s == "NONE":
        return 0.0
    if s == "LIM":
        return 0.5
    return 0.5


def _axis1_outcome_binary(row: Dict[str, Any]) -> int:
    """Return 1 if any Article 8 violation/partial, else 0."""
    o = str(row.get("Art8_Outcome", "")).upper().strip()
    if o in ("V", "P", "NV"):
        return 0 if o == "NV" else 1
    try:
        return int(row.get("Art8_BinaryAnyViolation") or 0)
    except Exception:
        return 1


def _robo_legal_variance_from_runs_impl(runs: List[Dict[str, Any]]) -> Dict[str, float]:
    """Variance/disagreement using a fixed legal threshold (reduces noise artifacts)."""
    if not runs:
        return {"legal_variance": 0.0, "legal_disagreement": 0.0, "p_violation_legal": 0.0}
    ys = []
    for r in runs:
        try:
            score = float(r.get("DecisionScore", ROBO_BASE_THRESHOLD))
        except Exception:
            score = float(ROBO_BASE_THRESHOLD)
        ys.append(1 if score >= float(ROBO_BASE_THRESHOLD) else 0)
    p = sum(ys) / float(len(ys))
    variance = p * (1.0 - p)
    disagreement = 1.0 - max(p, 1.0 - p)
    return {
        "legal_variance": float(round(variance, 6)),
        "legal_disagreement": float(round(disagreement, 6)),
        "p_violation_legal": float(round(p, 6)),
    }


def _axis1_sim_cat(a: Any, b: Any) -> float:
    return 1.0 if str(a) == str(b) else 0.0


def _axis1_sim_num(a: float, b: float) -> float:
    return 1.0 - abs(a - b)


def _axis1_pair_similarity(
    a: Dict[str, Any],
    b: Dict[str, Any],
    weights: Dict[str, float],
    missing_mode: str = "midpoint",
    min_overlap: int = 0,
) -> float:
    def _is_missing_yesno(v: Any) -> bool:
        s = str(v or "").upper().strip()
        return s in ("", "UNK")

    def _val_yesno(v: Any) -> float:
        return _axis1_encode_yesno(v)

    def _is_missing_remedy(v: Any) -> bool:
        s = str(v or "").upper().strip()
        return s in ("", "UNK")

    def _val_remedy(v: Any) -> float:
        return _axis1_encode_remedy_eff(v)

    sims: List[float] = []
    wsum = 0.0

    for k in AXIS1_ANCHORS:
        w = float(weights.get(k, 1.0))
        sims.append(w * _axis1_sim_cat(a.get(k), b.get(k)))
        wsum += w

    overlap = 0

    for k in AXIS1_SAFEGUARDS:
        va, vb = a.get(k), b.get(k)
        if missing_mode == "skip" and (_is_missing_yesno(va) or _is_missing_yesno(vb)):
            continue
        overlap += 1
        w = float(weights.get(k, 1.0))
        sims.append(w * _axis1_sim_num(_val_yesno(va), _val_yesno(vb)))
        wsum += w

    va, vb = a.get("RemedyEffectiveness"), b.get("RemedyEffectiveness")
    if not (missing_mode == "skip" and (_is_missing_remedy(va) or _is_missing_remedy(vb))):
        overlap += 1
        w = float(weights.get("RemedyEffectiveness", 1.0))
        sims.append(w * _axis1_sim_num(_val_remedy(va), _val_remedy(vb)))
        wsum += w

    for k in ["Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture"]:
        w = float(weights.get(k, 0.5))
        try:
            sims.append(w * _axis1_sim_cat(int(a.get(k, 0)), int(b.get(k, 0))))
        except Exception:
            sims.append(w * _axis1_sim_cat(a.get(k), b.get(k)))
        wsum += w

    if min_overlap and overlap < int(min_overlap):
        return -1.0

    return (sum(sims) / wsum) if wsum else -1.0


def _axis1_union_find_clusters(n: int, edges: List[Tuple[int, int]]) -> List[List[int]]:
    parent = list(range(n))
    rank = [0] * n

    def find(x: int) -> int:
        while parent[x] != x:
            parent[x] = parent[parent[x]]
            x = parent[x]
        return x

    def union(x: int, y: int) -> None:
        rx, ry = find(x), find(y)
        if rx == ry:
            return
        if rank[rx] < rank[ry]:
            parent[rx] = ry
        elif rank[rx] > rank[ry]:
            parent[ry] = rx
        else:
            parent[ry] = rx
            rank[rx] += 1

    for i, j in edges:
        union(i, j)

    groups: Dict[int, List[int]] = {}
    for i in range(n):
        r = find(i)
        groups.setdefault(r, []).append(i)

    return list(groups.values())


def _axis1_bin_hist(values: List[float], bins: int = 20) -> Tuple[List[float], List[int]]:
    if not values:
        return ([], [])
    lo, hi = min(values), max(values)
    if hi == lo:
        return ([lo], [len(values)])
    step = (hi - lo) / float(bins)
    counts = [0 for _ in range(bins)]
    centers = [lo + (i + 0.5) * step for i in range(bins)]
    for v in values:
        idx = int((v - lo) / step)
        if idx >= bins:
            idx = bins - 1
        if idx < 0:
            idx = 0
        counts[idx] += 1
    return (centers, counts)


def _axis1_bernoulli_variance(p: float) -> float:
    return p * (1.0 - p)


def _axis1_disagreement_rate(p: float) -> float:
    return 1.0 - max(p, 1.0 - p)


def _axis1_entropy(p: float) -> float:
    eps = 1e-12
    p = min(max(p, eps), 1.0 - eps)
    return -p * math.log(p, 2) - (1.0 - p) * math.log(1.0 - p, 2)


def axis1_outcome_distribution(rows: List[Dict[str, Any]]) -> Dict[str, Any]:
    counts = {"V": 0, "NV": 0, "P": 0, "UNK": 0}
    bin_counts = {0: 0, 1: 0}
    mismatches: List[Dict[str, Any]] = []

    for r in rows:
        o = str(r.get("Art8_Outcome", "")).upper().strip()
        if o not in ("V", "NV", "P"):
            counts["UNK"] += 1
        else:
            counts[o] += 1

        try:
            b = int(r.get("Art8_BinaryAnyViolation") or 0)
        except Exception:
            b = 0
        b = 1 if b else 0
        bin_counts[b] += 1

        if o in ("V", "P", "NV"):
            derived = 0 if o == "NV" else 1
            if derived != b:
                mismatches.append({
                    "Case_ID": r.get("Case_ID"),
                    "Art8_Outcome": o,
                    "StoredBinary": b,
                    "DerivedBinary": derived,
                })

    return {"outcome_counts": counts, "binary_counts": bin_counts, "mismatches": mismatches}


