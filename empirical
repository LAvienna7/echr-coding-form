def rj_extract_text_from_upload(uploaded_file: Any) -> str:
    """Extract plain text from an uploaded file (PDF/DOCX/TXT)."""
    if uploaded_file is None:
        return ""
    name = str(getattr(uploaded_file, "name", "") or "").lower()
    data = uploaded_file.getvalue()  # Streamlit UploadedFile

    # TXT
    if name.endswith(".txt"):
        try:
            return data.decode("utf-8", errors="ignore")
        except Exception:
            return str(data)

    # PDF/DOCX via optional deps
    if not _OFFLINE_OK:
        raise RuntimeError("Offline ingestion deps missing. Install: pip install pdfplumber python-docx")

    with tempfile.NamedTemporaryFile(delete=False, suffix=os.path.splitext(name)[1] or ".bin") as tmp:
        tmp.write(data)
        tmp_path = tmp.name

    try:
        if name.endswith(".pdf"):
            if pdfplumber is None:
                raise RuntimeError("pdfplumber missing")
            parts: List[str] = []
            with pdfplumber.open(tmp_path) as pdf:  # type: ignore
                for i, page in enumerate(pdf.pages, start=1):
                    txt = (page.extract_text() or "").strip()
                    if txt:
                        parts.append(f"\n[PAGE {i}]\n")
                        parts.append(txt)
            return "\n".join(parts).strip()

        if name.endswith(".docx"):
            if Document is None:
                raise RuntimeError("python-docx missing")
            doc = Document(tmp_path)
            parts: List[str] = []
            for para in doc.paragraphs:
                t = (para.text or "").strip()
                if t:
                    parts.append(t)
            for tbl in doc.tables:
                for row in tbl.rows:
                    cells = [((c.text or "").strip()) for c in row.cells]
                    line = " | ".join([c for c in cells if c])
                    if line:
                        parts.append(line)
            return "\n".join(parts).strip()

        raise ValueError("Unsupported file type. Please upload PDF, DOCX, or TXT.")
    finally:
        try:
            os.unlink(tmp_path)
        except Exception:
            pass


def rj_infer_case_and_subunit_from_filename(filename: str) -> Tuple[str, str]:
    """Infer (Case_ID, SubUnit_ID) from a filename.

    Supported patterns:
      - "Case Name__A.pdf" -> ("Case Name", "A")
      - "Case Name__NA.pdf" -> ("Case Name", "NA")
      - "Case Name - A.pdf" -> ("Case Name", "A")
      - otherwise: (stem, "NA")
    """
    name = os.path.basename(str(filename or "")).strip()
    stem = os.path.splitext(name)[0].strip()

    if "__" in stem:
        parts = [p.strip() for p in stem.split("__") if p.strip()]
        if len(parts) >= 2:
            case_id = parts[0]
            su = parts[1].upper().strip()
            if su in ("A", "B", "C", "NA"):
                return case_id, su
            return stem, "NA"

    m = re.search(r"^(.*?)[\s\-–]+(A|B|C|NA)$", stem, flags=re.IGNORECASE)
    if m:
        case_id = (m.group(1) or "").strip()
        su = (m.group(2) or "NA").upper().strip()
        return (case_id if case_id else stem), su

    return (stem if stem else name), "NA"


def rj_outcome_leak_check(text: str) -> Dict[str, Any]:
    """Detect outcome leakage and structured output artifacts that make a dossier unusable."""
    t = str(text or "")
    tl = t.lower()

    patterns = {
        "operative_markers": [
            r"for these reasons",
            r"operative provisions",
            r"^\s*holds\b",
            r"^\s*declares\b",
            r"^\s*decides\b",
            r"\bunanimously\b",
            r"\bseparate opinion\b",
            r"\bdissenting opinion\b",
            r"\bconcurring opinion\b",
        ],
        "explicit_outcome": [
            r"\bviolation\s+of\s+article\s*8\b",
            r"\bno\s+violation\s+of\s+article\s*8\b",
            r"\bbreach\s+of\s+article\s*8\b",
            r"\bno\s+breach\s+of\s+article\s*8\b",
            r"\bthere\s+has\s+been\s+(?:a\s+)?violation\b",
            r"\bthere\s+has\s+been\s+no\s+violation\b",
            r"\bfinds?\s+that\s+there\s+has\s+been\b",
            r"\bconcludes?\s+that\s+there\s+has\s+been\b",
            r"\bholds?,?\s+that\s+there\s+has\s+been\b",
            r"\bfound\s+that\s+there\s+had\s+been\b",
            r"\bopinion\s+that\s+there\s+had\s+been\b",
            r"\bopined?\s+that\s+there\s+had\s+been\b",
            r"\bdisclosed?\s+(?:a|the)\s+breach\b",
            r"\bbreach\s+by\s+the\s+respondent\s+state\b",
            r"\bno\s+need\s+to\s+examine\b",
        ],
        "vote_language": [
            r"\bby\s+\d+\s+votes\s+to\s+\d+\b",
            r"\bby\s+(one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen)\s+votes\s+to\s+(one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen)\b",
        ],
        "admissibility": [
            r"\bdeclares?\s+the\s+application\b.{0,80}\badmissible\b",
            r"\bdeclares?\s+the\s+application\b.{0,80}\binadmissible\b",
            r"\bapplication\s+is\s+admissible\b",
            r"\bapplication\s+is\s+inadmissible\b",
        ],
        "just_satisfaction": [
            r"\bjust satisfaction\b",
            r"\barticle\s*41\b",
            r"\bawards?\b.{0,80}\beur\b",
            r"\bcosts?\s+and\s+expenses\b",
            r"\bpecuniary\s+damage\b",
            r"\bnon-pecuniary\s+damage\b",
            r"\bdefault interest\b",
        ],
        "structured_artifacts": [
            r"\bsanitized_packet\b",
            r"\"case_metadata\"",
            r"\"application_no\"",
            r"\"procedural_history\"",
            r"\"facts\"",
            r"\"law\"",
        ],
    }

    hits: Dict[str, List[str]] = {k: [] for k in patterns}
    score = 0

    for group, pats in patterns.items():
        for pat in pats:
            try:
                matches = list(re.finditer(pat, tl, flags=re.IGNORECASE | re.MULTILINE))
            except re.error:
                matches = []
            for m in matches[:3]:
                a = max(0, m.start() - 80)
                b = min(len(t), m.end() + 120)
                snippet = t[a:b].strip()
                if snippet and snippet not in hits[group]:
                    hits[group].append(snippet)

    score += 5 * len(hits["explicit_outcome"])
    score += 4 * len(hits["vote_language"])
    score += 3 * len(hits["operative_markers"])
    score += 3 * len(hits["admissibility"])
    score += 3 * len(hits["just_satisfaction"])
    score += 1 * len(hits["structured_artifacts"])

    ok = score == 0
    risk = "LOW" if score == 0 else ("MED" if score <= 4 else "HIGH")

    return {"ok": ok, "risk": risk, "score": score, "hits": {k: v for k, v in hits.items() if v}}


def _rj_normalize_redaction_text(text: str) -> str:
    raw = str(text or "").replace("\u00a0", " ")
    raw = re.sub(r"\r\n?", "\n", raw)
    raw = re.sub(r"[ \t]+", " ", raw)
    raw = re.sub(r"\n{3,}", "\n\n", raw)
    return raw.strip()


def _rj_collect_packet_strings(node: Any, out: List[str], parent_key: str = "") -> None:
    skip_keys = {
        "title",
        "application_no",
        "parties",
        "dates",
        "procedural_history",
        "procedure",
        "jurisdiction",
        "court_section",
        "source",
        "citation",
        "location",
        "document",
        "verbatim_trigger_excerpt",
        "verdict",
        "outcome",
        "decision",
        "decision_score",
        "result",
        "holding",
        "holdings",
        "operative",
        "disposition",
        "article_41",
        "just_satisfaction",
        "citations",
        "vote",
        "votes",
    }
    key_l = str(parent_key or "").lower()
    if key_l in skip_keys or "citation" in key_l:
        return
    if isinstance(node, dict):
        for k, v in node.items():
            _rj_collect_packet_strings(v, out, str(k))
        return
    if isinstance(node, list):
        for item in node:
            _rj_collect_packet_strings(item, out, parent_key)
        return
    if isinstance(node, str):
        s = _rj_normalize_redaction_text(node)
        if len(s) < 25:
            return
        if s not in out:
            out.append(s)


def _rj_line_looks_like_structured_artifact(line: str) -> bool:
    s = str(line or "").strip()
    if not s:
        return False
    if re.fullmatch(r"[\[\]\{\},:]+", s):
        return True
    if re.match(
        r'^\s*"?('
        r'sanitized_packet|case_metadata|application_no|procedural_history|court_section|'
        r'jurisdiction|source|outcome|verdict|decision|decision_score|holdings?|'
        r'disposition|article_41|just_satisfaction|citations'
        r')"?\s*:',
        s,
        flags=re.IGNORECASE,
    ):
        return True
    if s.count('":') >= 2 or (s.startswith("{") and s.endswith("}")):
        return True
    return False


def _rj_strip_structured_packet_wrappers(text: str) -> Tuple[str, Dict[str, Any]]:
    raw = _rj_normalize_redaction_text(text)
    if not raw:
        return "", {"parsed_json": False, "removed_metadata_lines": 0, "notes": ["empty input"]}

    report: Dict[str, Any] = {"parsed_json": False, "removed_metadata_lines": 0, "recovered_segments": 0}
    json_start = raw.find("{")
    json_end = raw.rfind("}")
    if json_start != -1 and json_end > json_start and (
        "sanitized_packet" in raw.lower() or raw.lstrip().startswith("{")
    ):
        payload = None
        try:
            payload = json.loads(raw[json_start : json_end + 1])
        except Exception:
            payload = None
        if isinstance(payload, (dict, list)):
            pieces: List[str] = []
            packet_root: Any = payload
            if isinstance(payload, dict) and isinstance(payload.get("sanitized_packet"), (dict, list)):
                packet_root = payload.get("sanitized_packet")
            if isinstance(packet_root, dict):
                preferred_keys = ["facts", "law", "background", "analysis", "reasoning"]
                for key in preferred_keys:
                    if key in packet_root:
                        _rj_collect_packet_strings(packet_root.get(key), pieces, key)
            if not pieces:
                _rj_collect_packet_strings(packet_root, pieces)
            if pieces:
                prefix = raw[:json_start].strip()
                rebuilt = []
                if prefix and len(prefix) <= 200:
                    rebuilt.append(prefix)
                rebuilt.extend(pieces)
                report["parsed_json"] = True
                report["recovered_segments"] = len(pieces)
                return "\n\n".join(rebuilt).strip(), report

    cleanup_source = raw
    facts_like = re.search(r'"\s*facts\s*"\s*:', raw, flags=re.IGNORECASE)
    law_like = re.search(r'"\s*law\s*"\s*:', raw, flags=re.IGNORECASE)
    start_idx = -1
    if facts_like:
        start_idx = facts_like.start()
    elif law_like:
        start_idx = law_like.start()
    if start_idx != -1:
        end_idx = len(raw)
        for pat in [
            r'"\s*operative\s*"\s*:',
            r'"\s*decision\s*"\s*:',
            r'"\s*disposition\s*"\s*:',
            r'"\s*just_satisfaction\s*"\s*:',
        ]:
            match = re.search(pat, raw[start_idx:], flags=re.IGNORECASE)
            if match:
                candidate_end = start_idx + match.start()
                if candidate_end > start_idx:
                    end_idx = min(end_idx, candidate_end)
        cleanup_source = raw[start_idx:end_idx].strip()

    cleaned_lines: List[str] = []
    removed_lines = 0
    for line in cleanup_source.splitlines():
        if _rj_line_looks_like_structured_artifact(line):
            removed_lines += 1
            continue
        stripped = re.sub(r'^\s*"[^"]+"\s*:\s*', "", line).strip().strip(",")
        stripped = stripped.strip('"')
        if not stripped:
            continue
        cleaned_lines.append(stripped)

    report["removed_metadata_lines"] = removed_lines
    return _rj_normalize_redaction_text("\n".join(cleaned_lines)), report


def _rj_cut_text_before_heading(text: str, patterns: List[str]) -> Tuple[str, List[Dict[str, Any]]]:
    raw = _rj_normalize_redaction_text(text)
    if not raw:
        return "", []
    earliest: Optional[re.Match[str]] = None
    matched_pattern = ""
    for pat in patterns:
        try:
            match = re.search(pat, raw, flags=re.IGNORECASE | re.MULTILINE)
        except re.error:
            match = None
        if match and (earliest is None or match.start() < earliest.start()):
            earliest = match
            matched_pattern = pat
    if earliest is None:
        return raw, []
    removed = [{"pattern": matched_pattern, "from": int(earliest.start()), "to": int(len(raw))}]
    return raw[: earliest.start()].strip(), removed


def _rj_sentence_drop_patterns() -> List[str]:
    return [
        r"\bthere\s+has\s+been\s+(?:a\s+)?violation\b",
        r"\bthere\s+has\s+been\s+no\s+violation\b",
        r"\bviolation\s+of\s+article\s*8\b",
        r"\bno\s+violation\s+of\s+article\s*8\b",
        r"\bbreach\s+of\s+article\s*8\b",
        r"\bno\s+breach\s+of\s+article\s*8\b",
        r"\bfound\s+that\s+there\s+had\s+been\b",
        r"\bopinion\s+that\s+there\s+had\s+been\b",
        r"\bopined?\s+that\s+there\s+had\s+been\b",
        r"\bdisclosed?\s+(?:a|the)\s+breach\b",
        r"\bbreach\s+by\s+the\s+respondent\s+state\b",
        r"\bby\s+\d+\s+votes\s+to\s+\d+\b",
        r"\bby\s+(one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen)\s+votes\s+to\s+(one|two|three|four|five|six|seven|eight|nine|ten|eleven|twelve|thirteen|fourteen|fifteen|sixteen|seventeen)\b",
        r"\bunanimously\b",
        r"\bjust satisfaction\b",
        r"\barticle\s*41\b",
        r"\bcosts?\s+and\s+expenses\b",
        r"\bpecuniary\s+damage\b",
        r"\bnon-pecuniary\s+damage\b",
        r"\bdefault interest\b",
        r"\bawards?\b.{0,80}\beur\b",
        r"\bdeclares?\s+the\s+application\b.{0,80}\b(?:inadmissible|admissible)\b",
        r"\bapplication\s+is\s+(?:inadmissible|admissible)\b",
        r"\bno\s+need\s+to\s+examine\b",
        r"\bseparate\s+opinion\b",
        r"\bdissenting\s+opinion\b",
        r"\bconcurring\s+opinion\b",
        r"^\s*(for these reasons|holds\b|declares\b|decides\b|operative provisions)\b",
        r"\bsanitized_packet\b",
        r"\"case_metadata\"",
    ]


def _rj_sentence_level_leak_cleanup(text: str) -> Tuple[str, Dict[str, Any]]:
    raw = _rj_normalize_redaction_text(text)
    if not raw:
        return "", {"removed_sentences": 0, "removed_paragraphs": 0}

    drop_patterns = _rj_sentence_drop_patterns()
    kept_paragraphs: List[str] = []
    removed_sentences = 0
    removed_paragraphs = 0

    for para in re.split(r"\n\s*\n", raw):
        p0 = _rj_normalize_redaction_text(para)
        if not p0:
            continue
        if _rj_line_looks_like_structured_artifact(p0):
            removed_paragraphs += 1
            continue
        sentences = re.split(r"(?<=[.!?])\s+", p0)
        kept_sentences: List[str] = []
        for sent in sentences:
            s0 = _rj_normalize_redaction_text(sent)
            if not s0:
                continue
            if _rj_line_looks_like_structured_artifact(s0):
                removed_sentences += 1
                continue
            hit = False
            for pat in drop_patterns:
                try:
                    if re.search(pat, s0, flags=re.IGNORECASE | re.MULTILINE):
                        hit = True
                        break
                except re.error:
                    continue
            if hit:
                removed_sentences += 1
            else:
                kept_sentences.append(s0)
        cleaned_para = " ".join(kept_sentences).strip()
        cleaned_para = re.sub(r"\s+", " ", cleaned_para).strip()
        if cleaned_para:
            kept_paragraphs.append(cleaned_para)
        else:
            removed_paragraphs += 1

    return "\n\n".join(kept_paragraphs).strip(), {
        "removed_sentences": int(removed_sentences),
        "removed_paragraphs": int(removed_paragraphs),
    }


def _rj_extract_facts_first_clean_text(text: str) -> Tuple[str, Dict[str, Any]]:
    raw = _rj_normalize_redaction_text(text)
    if not raw:
        return "", {"used_sections": [], "facts_only_fallback": True}

    sections = extract_sections_text(raw)
    used_sections: List[str] = []
    chunks: List[str] = []
    facts = _rj_normalize_redaction_text(str(sections.get("facts") or ""))
    law = _rj_normalize_redaction_text(str(sections.get("law") or ""))
    if facts:
        used_sections.append("facts")
        chunks.append(facts)
    if law:
        used_sections.append("law")
        chunks.append(law)
    if not chunks:
        chunks.append(raw)
    candidate = "\n\n".join(chunks).strip()
    cleaned, cleanup_report = _rj_sentence_level_leak_cleanup(candidate)
    if cleaned:
        return cleaned, {"used_sections": used_sections or ["full_text"], "facts_only_fallback": False, **cleanup_report}

    fallback = facts or raw
    fallback_cleaned, fallback_report = _rj_sentence_level_leak_cleanup(fallback)
    return fallback_cleaned, {
        "used_sections": ["facts"] if facts else ["full_text"],
        "facts_only_fallback": True,
        **fallback_report,
    }


def rj_redaction_needs_cleanup(text: str) -> bool:
    raw = _rj_normalize_redaction_text(text)
    if not raw or len(raw) < 120:
        return True
    lower = raw.lower()
    if "sanitized_packet" in lower or '"case_metadata"' in lower or '"application_no"' in lower:
        return True
    if raw.count('":') >= 4 or raw.count("{") + raw.count("}") >= 8:
        return True
    return False


def rj_redact_to_usable_text(text: str, max_rounds: int = 3) -> Tuple[str, Dict[str, Any], Dict[str, Any]]:
    raw = _rj_normalize_redaction_text(text)
    if not raw:
        leak = rj_outcome_leak_check("")
        return "", {"rounds": [], "final_len": 0, "notes": ["empty input"]}, leak

    current = raw
    rounds: List[Dict[str, Any]] = []
    for round_idx in range(max_rounds):
        next_text, round_report = rj_auto_redact_outcome_leaks(current)
        leak = rj_outcome_leak_check(next_text)
        rounds.append(
            {
                "round": round_idx + 1,
                "input_len": len(current),
                "output_len": len(next_text),
                "needs_cleanup": rj_redaction_needs_cleanup(next_text),
                "leak_ok": bool(leak.get("ok")),
                "score": int(leak.get("score") or 0),
                "report": round_report,
            }
        )
        if next_text == current or (bool(leak.get("ok")) and not rj_redaction_needs_cleanup(next_text)):
            return next_text, {"rounds": rounds, "final_len": len(next_text)}, leak
        current = next_text

    final_leak = rj_outcome_leak_check(current)
    return current, {"rounds": rounds, "final_len": len(current)}, final_leak


# -----------------------------------------
# Outcome leakage auto-redaction helper
# -----------------------------------------

def rj_auto_redact_outcome_leaks(text: str) -> Tuple[str, Dict[str, Any]]:
    """Produce an outcome-blind dossier that stays usable for Robo-Judge ingestion."""
    raw = _rj_normalize_redaction_text(text)
    if not raw:
        return "", {"removed_sections": [], "removed_paragraphs": 0, "notes": ["empty input"]}

    report: Dict[str, Any] = {"removed_sections": [], "notes": []}

    unwrapped, unwrap_report = _rj_strip_structured_packet_wrappers(raw)
    report["unwrap"] = unwrap_report
    working = _rj_normalize_redaction_text(unwrapped or raw)
    if unwrap_report.get("parsed_json"):
        report["notes"].append("Rebuilt narrative text from a structured packet wrapper.")
    elif int(unwrap_report.get("removed_metadata_lines") or 0) > 0:
        report["notes"].append("Removed structured metadata lines.")

    working, removed_sep = _rj_cut_text_before_heading(
        working,
        [
            r"^\s*separate opinion\b",
            r"^\s*dissenting opinion\b",
            r"^\s*concurring opinion\b",
            r"^\s*partly dissenting opinion\b",
            r"^\s*partly concurring opinion\b",
        ],
    )
    report["removed_sections"].extend({"type": "separate_opinions", **r} for r in removed_sep)

    working, removed_ops = _rj_cut_text_before_heading(
        working,
        [
            r"^\s*for these reasons\b",
            r"^\s*operative provisions\b",
            r"^\s*holds\b",
            r"^\s*declares\b",
            r"^\s*decides\b",
            r"^\s*just satisfaction\b",
        ],
    )
    report["removed_sections"].extend({"type": "operative_part", **r} for r in removed_ops)

    cleaned, content_report = _rj_extract_facts_first_clean_text(working)
    report.update(content_report)

    final_text = cleaned
    if not final_text:
        lines = []
        for line in working.splitlines():
            s0 = _rj_normalize_redaction_text(line)
            if not s0 or _rj_line_looks_like_structured_artifact(s0):
                continue
            if any(re.search(pat, s0, flags=re.IGNORECASE | re.MULTILINE) for pat in _rj_sentence_drop_patterns()):
                continue
            lines.append(s0)
        final_text = "\n".join(lines[:40]).strip()
        report["notes"].append("Used a line-level fallback because section-based cleanup produced no text.")

    final_text = _rj_normalize_redaction_text(final_text)
    if len(final_text) < 160:
        sentence_fallback, sentence_report = _rj_sentence_level_leak_cleanup(_rj_normalize_redaction_text(unwrapped or raw))
        sentence_fallback = _rj_normalize_redaction_text(sentence_fallback)
        sentence_leak = rj_outcome_leak_check(sentence_fallback)
        if (
            len(sentence_fallback) > len(final_text)
            and bool(sentence_leak.get("ok"))
            and not rj_redaction_needs_cleanup(sentence_fallback)
        ):
            final_text = sentence_fallback
            report["sentence_fallback"] = sentence_report
            report["notes"].append("Recovered additional factual narrative with sentence-level fallback.")

    final_leak = rj_outcome_leak_check(final_text)
    if not bool(final_leak.get("ok")):
        # Final facts-only fallback if anything dispositive still remains.
        facts = _rj_normalize_redaction_text(str(extract_sections_text(working).get("facts") or ""))
        fallback_text, fallback_report = _rj_sentence_level_leak_cleanup(facts or working)
        if fallback_text:
            final_text = _rj_normalize_redaction_text(fallback_text)
            report["final_fallback"] = fallback_report
            report["notes"].append("Used a stricter facts-first fallback to clear residual leakage.")

    report["removed_paragraphs"] = int(report.get("removed_paragraphs") or 0)
    report["final_len"] = len(final_text)
    report["final_leak_score"] = int(rj_outcome_leak_check(final_text).get("score") or 0)
    report["needs_cleanup"] = bool(rj_redaction_needs_cleanup(final_text))
    report["notes"].append("Review the cleaned dossier before running the final Robo verdict.")
    return final_text, report


def rj_pick_yesno(yes_hits: int, no_hits: int) -> str:
    if yes_hits == 0 and no_hits == 0:
        return "UNK"
    if yes_hits > 0 and no_hits == 0:
        return "YES"
    if no_hits > 0 and yes_hits == 0:
        return "NO"
    # If both present, only return PART when evidence is truly mixed.
    if yes_hits >= (2 * no_hits):
        return "YES"
    if no_hits >= (2 * yes_hits):
        return "NO"
    return "PART"


def rj_find_snippets(text: str, patterns: List[str], window: int = 160, max_snips: int = 3) -> List[str]:
    if not text:
        return []
    t = re.sub(r"\s+", " ", text)
    out: List[str] = []
    for pat in patterns:
        try:
            for m in re.finditer(pat, t, flags=re.IGNORECASE):
                a = max(0, m.start() - window)
                b = min(len(t), m.end() + window)
                snip = t[a:b].strip()
                if snip and snip not in out:
                    out.append(snip)
                if len(out) >= max_snips:
                    return out
        except re.error:
            continue
    return out


def rj_autocode_grid_from_text(text: str) -> Dict[str, Any]:
    """Heuristic safeguards grid extraction from cleaned text (for rule-engine input)."""
    lower = (text or "").lower()
    evidence: Dict[str, List[str]] = {}

    pat_jud_auth = [
        r"judicial authori[sz]ation",
        r"authori[sz]ed by (a|the) (judge|court)",
        r"(order|warrant) (issued|granted|made) by (a|the) (judge|court)",
        r"prior (judicial|judge|court) (authori[sz]ation|review)",
        r"prior authori[sz]ation",
        r"court[-\s]issued warrant",
        r"judge[-\s]issued warrant",
        r"judicial warrant",
        r"court order",
        r"authori[sz]ation by an independent (judge|court|body)",
    ]
    pat_no_jud = [
        r"without (any )?judicial",
        r"no judicial (authori[sz]ation|control|oversight)",
        r"absence of (any )?judicial",
        r"lack of (any )?judicial (control|review)",
        r"no prior judicial",
        r"no independent authori[sz]ation",
        r"without prior authori[sz]ation",
    ]
    pat_exec_auth = [
        r"secretary of state",
        r"authori[sz]ed by (the )?government",
        r"authori[sz]ed by (the )?executive",
        r"public prosecutor",
        r"authori[sz]ed by (the )?prosecutor",
        r"minister",
        r"administrative authori[sz]ation",
        r"executive order",
    ]

    evidence["IndepPriorAuth"] = rj_find_snippets(text, pat_jud_auth + pat_no_jud, max_snips=10)
    evidence["ExecOnlyAuth"] = rj_find_snippets(text, pat_exec_auth, max_snips=10)

    jud_yes = len(rj_find_snippets(text, pat_jud_auth, max_snips=10))
    jud_no = len(rj_find_snippets(text, pat_no_jud, max_snips=10))
    exec_yes = len(evidence["ExecOnlyAuth"])

    IndepPriorAuth = rj_pick_yesno(jud_yes, jud_no)

    if exec_yes == 0 and jud_yes > 0:
        ExecOnlyAuth = "NO"
    elif exec_yes > 0 and jud_yes == 0:
        ExecOnlyAuth = "YES"
    elif exec_yes > 0 and jud_yes > 0:
        ExecOnlyAuth = "PART"
    else:
        ExecOnlyAuth = "UNK"

    # Oversight / review / notice / retention / logging / destruction / sharing / remedies
    pat_oversight_yes = [
