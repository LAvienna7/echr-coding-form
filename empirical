# Ensure these globals exist even if earlier code paths were refactored.
if "_FACTS_MARKERS" not in globals():
    _FACTS_MARKERS = ["THE FACTS", "FACTS"]
if "_LAW_MARKERS" not in globals():
    _LAW_MARKERS = ["THE LAW", "LAW"]
if "_OPERATIVE_MARKERS" not in globals():
    _OPERATIVE_MARKERS = ["FOR THESE REASONS", "HOLDS", "OPERATIVE PROVISIONS"]
if "_SEPARATE_OPINION_MARKERS" not in globals():
    _SEPARATE_OPINION_MARKERS = [
        "SEPARATE OPINION",
        "DISSENTING OPINION",
        "CONCURRING OPINION",
        "PARTLY DISSENTING OPINION",
        "PARTLY CONCURRING OPINION",
    ]

def extract_sections_text(full_text: str) -> Dict[str, Any]:
    """Return robust section slices and diagnostics.

    Strategy:
      - Prefer explicit heading markers.
      - Clip LAW at the start of OPERATIVE or separate opinions.
      - If markers are missing, fall back to best-effort spans.
    """
    raw = _cleanup_source_text(full_text or "")
    if not raw:
        return {
            "facts": "",
            "law": "",
            "operative": "",
            "diagnostics": {"facts_start": -1, "law_start": -1, "operative_start": -1, "separate_start": -1, "text_len": 0},
        }

    up = raw.upper()

    facts_start = _find_first_index(up, _FACTS_MARKERS)
    law_start = _find_first_index(up, _LAW_MARKERS)
    operative_start = _find_first_index(up, _OPERATIVE_MARKERS)
    separate_start = _find_first_index(up, _SEPARATE_OPINION_MARKERS)

    # If LAW marker is missing but OPERATIVE exists, treat everything before OPERATIVE as LAW.
    if law_start == -1 and operative_start != -1:
        law_start = 0

    # LAW end: stop at OPERATIVE or separate opinions
    law_end = len(raw)
    for stop in [operative_start, separate_start]:
        if stop != -1 and (law_start == -1 or stop > law_start):
            law_end = min(law_end, stop)

    # FACTS end: prefer stopping at LAW start
    facts_end = len(raw)
    if law_start != -1 and (facts_start == -1 or law_start > facts_start):
        facts_end = min(facts_end, law_start)

    facts = ""
    if facts_start != -1:
        facts = raw[facts_start:facts_end].strip()

    law = ""
    if law_start != -1:
        law = raw[law_start:law_end].strip()

    operative = ""
    if operative_start != -1:
        op_end = len(raw)
        if separate_start != -1 and separate_start > operative_start:
            op_end = min(op_end, separate_start)
        operative = raw[operative_start:op_end].strip()

    return {
        "facts": facts,
        "law": law,
        "operative": operative,
        "diagnostics": {
            "facts_start": int(facts_start),
            "law_start": int(law_start),
            "operative_start": int(operative_start),
            "separate_start": int(separate_start),
            "text_len": int(len(raw)),
        },
    }


