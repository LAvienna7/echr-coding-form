def extract_turning_point(conclusion: str, full_text: str) -> str:
    t = re.sub(r"\s+", " ", (conclusion or "") + " " + (full_text or "")).strip()
    sents = re.split(r"(?<=[\.!\?])\s+", t)
    priorities = [
        r"not in accordance with the law",
        r"quality of the law",
        r"adequate and effective guarantees",
        r"end-to-end safeguards",
        r"no effective remedy",
        r"not necessary in a democratic society",
        r"absence of.*review",
    ]
    for pat in priorities:
        for s in sents:
            if re.search(pat, s, flags=re.IGNORECASE):
                s2 = s.strip()
                if 20 <= len(s2) <= 220:
                    return s2[:200]
    for s in sents:
        s2 = s.strip()
        if 20 <= len(s2) <= 220:
            return s2[:200]
    return ""


