    for h in human_metrics_rows:
        key = (_norm_case_id_for_match(h.get("Case_ID", "")), str(h.get("SubUnit_ID", "NA")).strip().upper())
        human_metrics_map[key] = h

    human_minority_share_map: Dict[Tuple[str, str], float] = {}
    for r in human_rows:
        key = (_norm_case_id_for_match(r.get("Case_ID", "")), str(r.get("SubUnit_ID", "NA")).strip().upper())
        try:
            mv = r.get("Jury_MinorityShare")
            if mv is not None:
                human_minority_share_map[key] = float(mv)
        except Exception:
            pass

    # Robo metrics map
    robo_index: List[Tuple[Dict[str, Any], str, set, str]] = []
    for item in robo_batch:
        if not isinstance(item, dict):
            continue
        subunit = str(item.get("InputPayload", {}).get("SubUnit_ID", "NA")).strip().upper()
        candidates = set(_robo_case_candidates_for_match(item))
        if not candidates:
            continue
        canonical = _canonical_case_candidate(list(candidates))
        if not canonical:
            continue
        robo_index.append((item, subunit, candidates, canonical))

    robo_map: Dict[Tuple[str, str], Dict[str, Any]] = {}
    for item, subunit, candidates, case_norm in robo_index:
        key = (case_norm, subunit)

        contract = item.get("_contract", {}) if isinstance(item.get("_contract", {}), dict) else {}
        expl = contract.get("explainability", {}) if isinstance(contract, dict) else {}
        if not expl:
