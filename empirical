                    json.dump(runs, f, ensure_ascii=False, indent=2)
                st.caption(f"Saved batch file to: {out_path}")

    if run_all:
        if not batch:
            st.warning("No batch loaded. Upload files first.")
            return

        prog = st.progress(0)
        status = st.empty()
        batch_outputs: List[Dict[str, Any]] = []
        total = len(batch)
        for i, b in enumerate(batch):
            status.write(f"Running case {i + 1}/{total}...")
            txt = str(b.get("_text") or "")
            if not txt:
                continue

            leak_b = b.get("_leak") or {}
            if (not bool(leak_b.get("ok"))) and (not allow_run_on_leak):
                continue

            case_id_b = _rj_default_case_id("", str(b.get("inferred_case") or ""), str(b.get("filename") or ""))
            subunit_b = _rj_default_subunit("", str(b.get("inferred_su") or "NA"))

            base_b = rj_autocode_grid_from_text(txt)
            payload_b = {
                "Case_ID": case_id_b,
                "SubUnit_ID": subunit_b,
                "IndepPriorAuth": str(base_b.get("IndepPriorAuth", "UNK")).upper(),
                "ExecOnlyAuth": str(base_b.get("ExecOnlyAuth", "UNK")).upper(),
                "IndepOversight": str(base_b.get("IndepOversight", "UNK")).upper(),
                "ExPostReview": str(base_b.get("ExPostReview", "UNK")).upper(),
                "Notification": str(base_b.get("Notification", "UNK")).upper(),
                "RetentionLimits": str(base_b.get("RetentionLimits", "UNK")).upper(),
                "AccessLogging": str(base_b.get("AccessLogging", "UNK")).upper(),
                "DestructionRules": str(base_b.get("DestructionRules", "UNK")).upper(),
                "SharingRules_ForeignPartners": str(base_b.get("SharingRules_ForeignPartners", "UNK")).upper(),
                "RemedyAccess": str(base_b.get("RemedyAccess", "UNK")).upper(),
                "RemedyEffectiveness": str(base_b.get("RemedyEffectiveness", "UNK")).upper(),
                "_rj_autocode_evidence": base_b.get("_rj_autocode_evidence") or {},
                "_rj_flags": base_b.get("_rj_flags") or {},
                "_rj_dossier_text": txt,
            }

            res_b = rj_run_reruns(
                payload_b,
                n=int(n),
                temperature=float(temperature),
                seed_mode=str(seed_mode),
                base_seed=int(base_seed) + i,
            )

            modal_b = str(res_b.get("ModalOutcome") or "")
            rep_b = _rj_pick_representative_run(res_b.get("runs") or [], modal_b)

            contract_b = build_robo_contract_output(
                case_id=case_id_b,
                subunit_id=subunit_b,
                dossier_text=txt,
                input_payload=payload_b,
                runs_output=res_b,
                leakage_before=leak_b or {},
                leakage_after=leak_b or {},
            )

            out_b = {
                "InputPayload": payload_b,
                "RunSummary": {
                    "n": res_b.get("n"),
                    "p_violation": res_b.get("p_violation"),
                    "RoboOutcomeVariance": res_b.get("RoboOutcomeVariance"),
                    "RoboDisagreementRate": res_b.get("RoboDisagreementRate"),
                    "ModalOutcome": res_b.get("ModalOutcome"),
                    "ReasonStability": res_b.get("ReasonStability"),
                    "DiscretionWeightVariance": res_b.get("DiscretionWeightVariance"),
                    "DiscretionWeightVarianceByFactor": res_b.get("DiscretionWeightVarianceByFactor"),
                    "DiscretionFlipRate": res_b.get("DiscretionFlipRate"),
                    "DiscretionFlipRat": res_b.get("DiscretionFlipRat"),
                    "MeanWeightEntropy": res_b.get("MeanWeightEntropy"),
                },
                "RepresentativeRun": rep_b,
                "AllRuns": res_b.get("runs") or [],
                "_contract": contract_b,
                "SourceFilename": str(b.get("filename") or ""),
            }

            batch_outputs.append(out_b)
            _rj_store_run_output(out_b, case_id_b, subunit_b, str(b.get("filename") or ""))
            _rj_save_run_output(out_b, case_id_b, subunit_b)

            prog.progress(int(((i + 1) / total) * 100))

        status.write("Batch run complete.")
        if batch_outputs:
            if auto_save_runs:
                stamp = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
                out_path = os.path.join(ROBO_BATCH_DIR, f"robo_batch__{stamp}.json")
                with open(out_path, "w", encoding="utf-8") as f:
                    json.dump(batch_outputs, f, ensure_ascii=False, indent=2)
                st.success(f"Saved Robo-Judge batch to: {out_path}")
        else:
            st.warning("No runs completed (check leakage settings or empty texts).")


# Dispatch: if Robo-Judge selected, render it and stop execution before the coding-form UI.
