def _find_cluster_for_case(axis1_res: Dict[str, Any], case_id: str) -> Optional[Dict[str, Any]]:
    if not axis1_res:
        return None
    for c in axis1_res.get("cluster_stats", []) or []:
        try:
            if case_id in (c.get("cases") or []):
                return c
        except Exception:
            continue
    return None


def _axis1_top_neighbors(
    rows: List[Dict[str, Any]],
    target_idx: int,
    missing_mode: str,
    min_overlap: int,
    require_same_type: bool,
    require_same_posture: bool,
    require_same_trigger: bool,
    topn: int = 5,
) -> List[Tuple[str, float]]:
    """Compute top-N most similar neighbors (by the same similarity function used for clustering)."""
    weights = {
        "InterferenceType_Primary": 3.0,
        "ReviewPosture": 3.0,
        "ContextTrigger": 2.0,
        "IndepPriorAuth": 2.0,
        "ExecOnlyAuth": 1.5,
        "SelectorCategoriesConstrained": 1.0,
        "PersonLinkedSelectorsPreAuth": 1.0,
        "IndepOversight": 2.0,
        "ExPostReview": 1.5,
        "Notification": 1.0,
        "RetentionLimits": 1.5,
        "AccessLogging": 1.0,
        "DestructionRules": 1.0,
        "SharingRules_ForeignPartners": 1.0,
        "RemedyAccess": 1.5,
        "RemedyEffectiveness": 1.0,
        "Flag_Journalist": 0.5,
        "Flag_LawyerPrivilege": 0.5,
        "Flag_ThirdPartyCapture": 0.5,
    }

    def eligible(a: Dict[str, Any], b: Dict[str, Any]) -> bool:
        if require_same_type and a.get("InterferenceType_Primary") != b.get("InterferenceType_Primary"):
            return False
        if require_same_posture and a.get("ReviewPosture") != b.get("ReviewPosture"):
            return False
        if require_same_trigger and a.get("ContextTrigger") != b.get("ContextTrigger"):
            return False
        return True

    a = rows[target_idx]
    scored: List[Tuple[float, str]] = []
    for j, b in enumerate(rows):
        if j == target_idx:
            continue
        if not eligible(a, b):
            continue
        s = _axis1_pair_similarity(a, b, weights, missing_mode=missing_mode, min_overlap=min_overlap)
        if s < 0:
            continue
        scored.append((float(s), str(b.get("Case_ID", f"case_{j}"))))

    scored.sort(key=lambda x: x[0], reverse=True)
    return [(cid, float(sim)) for sim, cid in scored[: max(1, int(topn))]]


