def _cleanup_source_text(t: str) -> str:
    if not t:
        return ""
    s = str(t).replace("\u00a0", " ")
    s = re.sub(r"\r\n?", "\n", s)
    s = re.sub(r"[ \t]+", " ", s)
    s = re.sub(r"\n{3,}", "\n\n", s)
    return s.strip()


def _find_first_index(haystack_upper: str, needles: List[str]) -> int:
    best = -1
    for n in needles:
        idx = haystack_upper.find(n)
        if idx != -1:
            if best == -1 or idx < best:
                best = idx
    return best


 
