def validate_dossier(payload: Dict[str, Any]) -> Tuple[List[str], List[str]]:
    """Validate a dossier for completeness/consistency.

    Returns (errors, warnings). Errors indicate required issues; warnings indicate quality/robustness issues.
    """
    errors: List[str] = []
    warnings: List[str] = []

    if not payload:
        return (["No dossier loaded."], [])

    # Required core identifiers
    for k in ["Case_ID", "SubUnit_ID", "Year", "Chamber"]:
        if k not in payload or str(payload.get(k) or "").strip() == "":
            errors.append(f"Missing required field: {k}")

    # Outcome
    o = str(payload.get("Art8_Outcome", "") or "").upper().strip()
    if o not in OUTCOME_OPTIONS:
        errors.append(f"Art8_Outcome must be one of {OUTCOME_OPTIONS}; got '{o}'")

    # Anchors
    for k in ["InterferenceType_Primary", "ReviewPosture", "ContextTrigger"]:
        if str(payload.get(k) or "").strip() == "":
            errors.append(f"Missing anchor field: {k}")

    for k, _label in GT_CHECKS:
        if k not in payload:
            warnings.append(f"Ground-truth field '{k}' is missing from the dossier.")
    for k in HUMAN_LINE_STEPS:
        if k not in payload:
            warnings.append(f"Doctrinal-step field '{k}' is missing from the dossier.")

    # Safeguards should not be UNK for analysis
    safeguard_keys = list(AXIS1_SAFEGUARDS) + ["RemedyEffectiveness"]
    for k in safeguard_keys:
        v = str(payload.get(k, "") or "").upper().strip()
        if k == "RemedyEffectiveness":
            if v in ("", "UNK"):
                warnings.append("RemedyEffectiveness is UNK/empty; metrics and variance will be less stable.")
        else:
            if v in ("", "UNK"):
                warnings.append(f"Safeguard '{k}' is UNK/empty; clustering similarity becomes noisy.")

    # Evidence presence
    ev = payload.get("_autocode_evidence")
    if not isinstance(ev, dict) or not ev:
        warnings.append("_autocode_evidence missing/empty. ECS will likely be low and safeguards verification is weak.")

    # Turning point and facts block quality
    tp = str(payload.get("TurningPoint_1Sentence", "") or "").strip()
    if len(tp) < 20:
        warnings.append("TurningPoint_1Sentence is missing/too short (<20 chars).")

    fb = str(payload.get("AI_FactsBlock", "") or "").strip()
    if word_count(fb) < 80:
        warnings.append("AI_FactsBlock appears very short (<80 words). Consider extracting a fuller facts summary.")

    # Jury votes consistency
    try:
        tv = payload.get("Jury_TotalVotes")
        vv = payload.get("Jury_ViolationVotes")
        nv = payload.get("Jury_NoViolationVotes")
        if tv is not None and vv is not None and nv is not None:
            tv_i = int(tv)
            vv_i = int(vv)
            nv_i = int(nv)
            if tv_i != vv_i + nv_i:
                warnings.append("Jury vote inconsistency: Jury_TotalVotes != ViolationVotes + NoViolationVotes")
            if tv_i > 0:
                ms = payload.get("Jury_MinorityShare")
                if ms is None:
                    warnings.append("Jury_MinorityShare missing despite vote counts being present.")
    except Exception:
        warnings.append("Could not validate jury vote fields (non-integer values).")

    # Offline source path exists (if present)
    sp = str(payload.get("_offline_source_path", "") or "").strip()
    if sp and not os.path.exists(sp):
        warnings.append(f"Offline source path does not exist on disk: {sp}")

    # Human text stored for metrics
    ht = _normalize_human_source_text(str(payload.get("_human_full_text", "") or ""))
    if len(ht) < 2000:
        warnings.append("_human_full_text missing/non-substantive/too short. ECS, line-adherence, and safeguard extraction will be unreliable.")

    safeguard_keys = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]
    safeguard_vals = [str(payload.get(k, "") or "").upper().strip() for k in safeguard_keys]
    if safeguard_vals and all(v == "UNK" for v in safeguard_vals):
        warnings.append("All safeguard fields are UNK. This usually means autocode could not find substantive judgment text or the dossier still needs refresh.")
    step_vals = [int(payload.get(k, 0) or 0) for k in HUMAN_LINE_STEPS]
    if step_vals and all(v == 1 for v in step_vals) and len(ht) < 2000:
        warnings.append("All doctrinal Step_* fields are 1 despite non-substantive source text. Re-run extraction before using this dossier for analysis.")

    return errors, warnings



