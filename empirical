def render_robo_analysis():
    """Analyze saved Robo-Judge outputs for stability and explainability metrics."""
    st.header("Robo Analysis")
    st.caption(
        "Load and analyze saved Robo-Judge runs. Compute outcome stability, reason consistency, and explainability metrics."
    )

    robo_batch_files = list_saved_robo_batches()

    if st.button("Delete all saved Robo-Judge batches", key="rj_delete_all_batches_btn"):
        try:
            removed = 0
            for fn in list(robo_batch_files):
                p = os.path.join(ROBO_BATCH_DIR, fn)
                if os.path.isfile(p):
                    os.remove(p)
                    removed += 1
            robo_batch_files = []
            st.success(f"Deleted {removed} batch file(s).")
            st.rerun()
        except Exception as e:
            st.error(f"Failed to delete batches: {e}")

    if not robo_batch_files:
        st.info("No saved Robo-Judge batches found. Run the Robo-Judge first and save the batch.")
        return

    selected_file = st.selectbox(
        "Select saved Robo-Judge batch",
        options=robo_batch_files,
        format_func=lambda f: f.replace("robo_batch__", "").replace(".json", ""),
        key="robo_analysis_batch_select",
    )

    batch_path = os.path.join(ROBO_BATCH_DIR, selected_file)
    try:
        with open(batch_path, "r", encoding="utf-8") as f:
            batch_data = json.load(f)
    except Exception as e:
        st.error(f"Failed to load batch: {e}")
        return

    if not isinstance(batch_data, list):
        st.error("Batch file format unexpected (should be a list of case runs).")
        return
    batch_data = [_rj_enrich_saved_item(item) if isinstance(item, dict) else item for item in batch_data]

    st.markdown("---")
    st.subheader("Batch Overview")

    c1, c2, c3 = st.columns(3)
    c1.metric("Cases in batch", len(batch_data))
    
    # Try to extract run counts if the data has the expected structure
    run_count_total = 0
    for item in batch_data:
        if isinstance(item, dict) and "AllRuns" in item:
            run_count_total += len(item.get("AllRuns", []))
    c2.metric("Total runs across batch", run_count_total)
    c3.metric("Batch file", selected_file[:30] + "..." if len(selected_file) > 30 else selected_file)

    # Select specific case from batch
    case_options = []
    case_map = {}
    for i, item in enumerate(batch_data):
        if isinstance(item, dict):
            case_id = item.get("InputPayload", {}).get("Case_ID", f"Case_{i}")
            subunit = item.get("InputPayload", {}).get("SubUnit_ID", "NA")
            label = f"{case_id} [{subunit}]"
            case_options.append(label)
            case_map[label] = i

    if not case_options:
        st.warning("No valid case entries found in batch.")
        return

    selected_case = st.selectbox("Select case to analyze", options=case_options)
    case_idx = case_map[selected_case]
    case_data = batch_data[case_idx]

    st.markdown("---")
    st.subheader(f"Analysis for {selected_case}")

    # Extract data
    run_summary = case_data.get("RunSummary", {})
    all_runs = case_data.get("AllRuns", [])
    rep_run = case_data.get("RepresentativeRun", {})
    contract = case_data.get("_contract", {})
    input_payload = case_data.get("InputPayload", {}) if isinstance(case_data.get("InputPayload", {}), dict) else {}

    c1, c2, c3, c4 = st.columns(4)
    c1.metric("Total runs (N)", int(run_summary.get("n", 0)))
    c2.metric("p(Violation)", f"{float(run_summary.get('p_violation', 0.0)):.4f}")
    c3.metric("Outcome variance", f"{float(run_summary.get('RoboOutcomeVariance', 0.0)):.6f}")
    c4.metric("Disagreement rate", f"{float(run_summary.get('RoboDisagreementRate', 0.0)):.6f}")
    d1, d2, d3 = st.columns(3)
    d1.metric("Weight variance", f"{float(run_summary.get('DiscretionWeightVariance', 0.0)):.6f}")
    d2.metric("Flip rate", f"{float(run_summary.get('DiscretionFlipRate', 0.0)):.6f}")
    d3.metric("Mean weight entropy", f"{float(run_summary.get('MeanWeightEntropy', 0.0)):.6f}")
    legal_stats = _robo_legal_variance_from_runs(all_runs)
    l1, l2 = st.columns(2)
    l1.metric("Legal variance (fixed threshold)", f"{float(legal_stats.get('legal_variance', 0.0)):.6f}")
    l2.metric("Legal disagreement", f"{float(legal_stats.get('legal_disagreement', 0.0)):.6f}")

    st.caption(f"Modal outcome: **{run_summary.get('ModalOutcome')}**")

    # Explainability metrics (if contract is available)
    if contract:
        st.markdown("---")
        st.subheader("Explainability Analysis")
        expl_metrics = compute_robo_explainability_metrics(contract, "")
        
        e1, e2, e3, e4, e5 = st.columns(5)
        e1.metric("Structure", f"{float(expl_metrics.get('structure_completeness', 0.0)):.2f}")
        e2.metric("Coverage", f"{float(expl_metrics.get('evidence_coverage_score', 0.0)):.2f}")
        e3.metric("Evidence Q", f"{float(expl_metrics.get('evidence_quality_score', 0.0)):.2f}")
        e4.metric("Alignment", f"{float(expl_metrics.get('doctrinal_fidelity_score', 0.0)):.2f}")
        e5.metric("Overall ECS", f"{float(expl_metrics.get('overall_explainability', 0.0)):.2f}")

    # Reason–Outcome Coherence Index
    st.markdown("---")
    st.subheader("Reason–Outcome Coherence Index")
    outcome = str(run_summary.get("ModalOutcome", "") or "").upper()
    score = float(rep_run.get("DecisionScore", 0.0) or 0.0)
    threshold = float(rep_run.get("DecisionThreshold", ROBO_BASE_THRESHOLD) or ROBO_BASE_THRESHOLD)
    comps = rep_run.get("Components", []) if isinstance(rep_run.get("Components", []), list) else []
    top_reasons = rep_run.get("TopReasons", []) if isinstance(rep_run.get("TopReasons", []), list) else []
    evidence = input_payload.get("_rj_autocode_evidence", {}) if isinstance(input_payload.get("_rj_autocode_evidence", {}), dict) else {}
    evidence_hits = sum(1 for k, v in evidence.items() if v)
    evidence_cov = float(evidence_hits) / max(1, len(evidence))

    top_sum = 0.0
    total_sum = 0.0
    for c in comps:
        if not isinstance(c, dict):
            continue
        val = float(c.get("contribution", 0.0) or 0.0)
        total_sum += val
        if c.get("factor") in top_reasons:
            top_sum += val

    score_aligned = 1.0 if ((outcome == "V" and score >= threshold) or (outcome == "NV" and score < threshold)) else 0.0
    reason_strength = min(1.0, top_sum / (total_sum + 1e-6)) if total_sum > 0 else 0.0
    evidence_strength = min(1.0, evidence_cov)
    coherence = 0.0
    if outcome in ("V", "NV"):
        if outcome == "V":
            coherence = (0.4 * score_aligned) + (0.3 * reason_strength) + (0.3 * evidence_strength)
        else:
            # For NV, coherence is higher when score is below threshold and reasons are weak.
            coherence = (0.5 * score_aligned) + (0.3 * (1.0 - reason_strength)) + (0.2 * (1.0 - evidence_strength))
    coherence = max(0.0, min(1.0, coherence))

    st.metric("Coherence index", f"{coherence:.2f}")
    st.caption(
        f"Score/threshold alignment={score_aligned:.2f}, reason_strength={reason_strength:.2f}, evidence_coverage={evidence_strength:.2f}."
    )

    # Explainability Coverage Matrix (Case × Doctrinal Step)
    st.markdown("---")
    st.subheader("Explainability Coverage Matrix (Case × Doctrinal Step)")
    st.caption("Rows = cases; columns = doctrinal steps. Cells show whether the decision explicitly addresses the step.")

    step_defs = [
        ("legality", [r"accordance with the law", r"quality of law", r"foreseeab", r"accessible", r"legal basis"]),
        ("legitimate aim", [r"legitimate aim", r"national security", r"crime", r"public safety", r"economic well[-\s]*being"]),
        ("necessity", [r"necessary in a democratic society", r"pressing social need", r"necessity"]),
        ("proportionality", [r"proportional", r"proportionality", r"fair balance"]),
        ("safeguards / balancing", [r"safeguard", r"oversight", r"review", r"remedy", r"end[-\s]*to[-\s]*end", r"adequate and effective guarantees"]),
    ]

    def _step_hit(text: str, pats: List[str]) -> int:
        if not text:
            return 0
        for p in pats:
            if re.search(p, text, flags=re.IGNORECASE):
                return 1
        return 0

    case_labels = []
    matrix = []
    case_step_snips: Dict[str, Dict[str, str]] = {}
    for item in batch_data:
        if not isinstance(item, dict):
            continue
        case_id = item.get("InputPayload", {}).get("Case_ID", "")
        subunit = item.get("InputPayload", {}).get("SubUnit_ID", "NA")
        label = f"{case_id} [{subunit}]"
        rep = item.get("RepresentativeRun", {}) if isinstance(item.get("RepresentativeRun", {}), dict) else {}
        text = str(rep.get("ReportText", "") or "")
        case_labels.append(label)
        row = []
        snips: Dict[str, str] = {}
        for step_name, pats in step_defs:
            hit = _step_hit(text, pats)
            row.append(hit)
            if hit:
                # Grab a short snippet around the first match.
                for p in pats:
                    m = re.search(p, text, flags=re.IGNORECASE)
                    if m:
                        a = max(0, m.start() - 120)
                        b = min(len(text), m.end() + 160)
                        snips[step_name] = text[a:b].strip()
                        break
        matrix.append(row)
        case_step_snips[label] = snips

    if matrix and _MPL_OK and plt is not None:
        fig = plt.figure(figsize=(12, max(4, 0.35 * len(case_labels))))
        ax = fig.add_subplot(111)
        im = ax.imshow(matrix, aspect="auto", interpolation="nearest", cmap="cividis", vmin=0, vmax=1)
        ax.set_yticks(list(range(len(case_labels))))
        ax.set_yticklabels(case_labels)
        ax.set_xticks(list(range(len(step_defs))))
        ax.set_xticklabels([s[0] for s in step_defs], rotation=30, ha="right")
        ax.set_title("Explainability Coverage Matrix")
        fig.colorbar(im, ax=ax, fraction=0.025, pad=0.02, label="Step addressed (0/1)")
        st.pyplot(fig, clear_figure=True)
    else:
        if _PANDAS_OK and pd is not None and matrix:
            dfm = pd.DataFrame(matrix, columns=[s[0] for s in step_defs], index=case_labels)  # type: ignore
            st.dataframe(dfm, use_container_width=True)

    with st.expander("Doctrinal step references (per case)", expanded=False):
        for label in case_labels:
            st.markdown(f"**{label}**")
            snips = case_step_snips.get(label, {})
            for step_name, _ in step_defs:
                if step_name in snips:
                    st.write(f"- {step_name}: {snips[step_name]}")
                else:
                    st.write(f"- {step_name}: (no explicit reference found)")

    # Per-case Robo factor-share heatmap using representative-run contributions.
    st.markdown("---")
    st.subheader("Factor Weighting (Machine-Discretion Matrix)")
    st.caption(
        "Per-case Robo-Judge factor weighting shares. "
        "Each row is normalized within the case, so darker cells indicate a larger share of that case's total factor weighting. "
        "This uses representative-run factor contribution shares rather than the discretized fixed `0..3` bins."
    )
    factor_keys = list(ROBO_DISCRETION_FACTORS)
    factor_labels = [str(ROBO_DISCRETION_FACTOR_META.get(f, {}).get("label", f)) for f in factor_keys]
    case_labels = []
    matrix: List[List[float]] = []
    for item in batch_data:
        if not isinstance(item, dict):
            continue
        payload = item.get("InputPayload", {}) if isinstance(item.get("InputPayload", {}), dict) else {}
        case_id = payload.get("Case_ID", "")
        su = payload.get("SubUnit_ID", "NA")
        label = f"{case_id} [{su}]"
        factor_map = _rj_case_factor_share_map(item)
        case_labels.append(label)
        matrix.append([float(factor_map.get(k, 0)) for k in factor_keys])

    if matrix and _MPL_OK and plt is not None:
        import numpy as np

        matrix_arr = np.nan_to_num(np.array(matrix), nan=0.0)
        matrix_max = max([0.25] + [float(v) for row in matrix for v in row])
        fig = plt.figure(figsize=(12.5, max(4, 0.42 * len(case_labels))))
        gs = fig.add_gridspec(1, 2, width_ratios=[1.0, 0.04], wspace=0.18)
        ax = fig.add_subplot(gs[0, 0])
        cax = fig.add_subplot(gs[0, 1])
        im = ax.imshow(matrix_arr, aspect="auto", interpolation="nearest", cmap="YlOrRd", vmin=0.0, vmax=matrix_max)
        ax.set_yticks(list(range(len(case_labels))))
        ax.set_yticklabels(case_labels, fontsize=8)
        ax.set_xticks(list(range(len(factor_keys))))
        ax.set_xticklabels(factor_labels, rotation=45, ha="right", fontsize=9)
        ax.set_title("Per-case factor weighting share", fontweight="bold")
        cbar_ticks = np.linspace(0.0, matrix_max, 5)
        cbar = fig.colorbar(im, cax=cax, ticks=cbar_ticks)
        cbar.ax.set_yticklabels([f"{tick:.0%}" for tick in cbar_ticks])
        cbar.set_label("Per-case factor share of total weighting")

        if len(case_labels) <= 8 and len(factor_keys) <= 12:
            for row_idx in range(matrix_arr.shape[0]):
                for col_idx in range(matrix_arr.shape[1]):
                    val = float(matrix_arr[row_idx, col_idx])
                    txt_color = "black" if val <= (matrix_max * 0.45) else "white"
                    ax.text(col_idx, row_idx, f"{val:.0%}", ha="center", va="center", color=txt_color, fontsize=7)

        fig.subplots_adjust(left=0.2, right=0.94, bottom=0.24, top=0.9)
        st.pyplot(fig, clear_figure=True)
    else:
        if _PANDAS_OK and pd is not None and matrix:
            dfm = pd.DataFrame(matrix, columns=factor_labels, index=case_labels)  # type: ignore
            st.dataframe(_format_share_dataframe(dfm), use_container_width=True)
        else:
            st.info("No factor-share data available for the heatmap.")

    # Reason stability
    reason_stab = run_summary.get("ReasonStability", {})
    if reason_stab:
        st.subheader("Reason Stability")
        c1, c2, c3 = st.columns(3)
        c1.metric("Modal top reason", str(reason_stab.get("Top1Modal") or "NA"))
        c2.metric("Modal share", f"{float(reason_stab.get('Top1Share', 0.0)):.3f}")
        c3.metric("Avg Jaccard", f"{float(reason_stab.get('AvgJaccardToModal', 0.0)):.3f}")

    # Run-level detail
    if all_runs:
        st.subheader("Per-run details")
        run_data_for_display = []
        for run in all_runs:
            run_data_for_display.append({
                "Run": int(run.get("run", 0)),
                "Outcome": str(run.get("RoboOutcome", "")),
                "Score": round(float(run.get("DecisionScore", 0.0)), 4),
                "Threshold": round(float(run.get("DecisionThreshold", 0.0)), 4),
                "WeightEntropy": round(float(run.get("WeightEntropy", 0.0) or 0.0), 4),
                "FlipRate": round(float((run.get("OutcomeSensitivity", {}) or {}).get("FlipRate", 0.0) or 0.0), 4),
                "# Reasons": len(run.get("TopReasons", [])),
            })
        
        if _PANDAS_OK and pd is not None:
            df = pd.DataFrame(run_data_for_display)
            st.dataframe(df, use_container_width=True)
        else:
            st.json(run_data_for_display)

    # Representative run detail
    if rep_run:
        st.subheader("Representative run (closest to modal outcome)")
        st.write(f"**Run #{rep_run.get('run')}** | Outcome: {rep_run.get('RoboOutcome')} | Score: {rep_run.get('DecisionScore')}")
        
        with st.expander("Decision text", expanded=False):
            st.text_area(
                "ECHR-style decision",
                value=str(rep_run.get("ReportText", "")),
                height=300,
                disabled=True,
            )

        with st.expander("Top reasons", expanded=False):
            st.json(rep_run.get("TopReasons", []))

        with st.expander("Components (transparency)", expanded=False):
            st.json(rep_run.get("Components", {}))

        with st.expander("Factor weights (0-3) + citations", expanded=False):
            factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run.get("FactorWeights", {}), dict) else {}
            factor_rows = [
                {
                    "Factor": factor,
                    "Label": meta.get("label", factor),
                    "Weight": int(meta.get("weight", 0) or 0),
                    "Contribution": float(meta.get("effective_contribution", 0.0) or 0.0),
                    "Citation": str(meta.get("citation", "")),
                }
                for factor, meta in factor_weights.items()
            ]
            if _PANDAS_OK and pd is not None:
                st.dataframe(pd.DataFrame(factor_rows), use_container_width=True)  # type: ignore
            else:
