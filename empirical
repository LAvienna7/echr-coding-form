def _rj_clean_explanation_fragments(values: List[Any], min_len: int = 20) -> List[str]:
    out: List[str] = []
    seen = set()
    for value in values:
        s = re.sub(r"\s+", " ", str(value or "")).strip()
        if not s:
            continue
        if s.lower() in {"(no citation located)", "unk", "none", "nan"}:
            continue
        if len(s) < min_len and not re.search(r"\b(score|threshold|weight|flip rate)\b", s, flags=re.IGNORECASE):
            continue
        key = s.lower()
        if key in seen:
            continue
        seen.add(key)
        out.append(s)
    return out


def _rj_support_quality_score(citations: List[str], dossier_text: str = "") -> float:
    cleaned = _rj_clean_explanation_fragments(citations)
    if not cleaned:
        return 0.0
    avg_len = sum(len(c) for c in cleaned) / float(len(cleaned))
    specificity = max(0.0, min(1.0, (avg_len - 40.0) / 140.0))
    diversity = max(0.0, min(1.0, len(cleaned) / 3.0))
    anchored = 0.0
    for c in cleaned:
        if (
            "§" in c
            or re.search(r"\bparagraphs?\b|\bparas?\b|\bsection\b|\bthe facts\b|\bthe law\b", c, flags=re.IGNORECASE)
            or (dossier_text and c in dossier_text)
        ):
            anchored = 1.0
            break
    return float(round(0.25 + (0.35 * specificity) + (0.20 * diversity) + (0.20 * anchored), 6))


def _rj_support_strength_label(score: float) -> str:
    if float(score) >= 0.7:
        return "strong"
    if float(score) >= 0.35:
        return "medium"
    return "weak"


def _rj_overlap_score(expected: List[str], observed: List[str]) -> float:
    exp = [str(x or "") for x in expected if str(x or "").strip()]
    obs = [str(x or "") for x in observed if str(x or "").strip()]
    if not exp and not obs:
        return 0.0
    if not exp or not obs:
        return 0.0
    exp_set = set(exp)
    obs_set = set(obs)
    return float(len(exp_set & obs_set)) / float(max(1, len(exp_set)))


def _rj_structured_claims_analysis(contract: Dict[str, Any], dossier_text: str = "") -> Dict[str, Any]:
    reasoning = contract.get("reasoning_structured", {}) if isinstance(contract.get("reasoning_structured", {}), dict) else {}
    evidence = contract.get("evidence", {}) if isinstance(contract.get("evidence", {}), dict) else {}
    extracted = evidence.get("extracted_elements", {}) if isinstance(evidence.get("extracted_elements", {}), dict) else {}
    safeguards = reasoning.get("safeguards_matrix", {}) if isinstance(reasoning.get("safeguards_matrix", {}), dict) else {}
    runs = contract.get("reruns", {}).get("runs", []) if isinstance(contract.get("reruns", {}), dict) else []
    verdict = contract.get("verdict", {}) if isinstance(contract.get("verdict", {}), dict) else {}
    rep_run = _rj_pick_representative_run(runs if isinstance(runs, list) else [], str(verdict.get("outcome", "") or ""))

    factor_weights = reasoning.get("factor_weights", {})
    if not isinstance(factor_weights, dict) or not factor_weights:
        factor_weights = rep_run.get("FactorWeights", {}) if isinstance(rep_run, dict) and isinstance(rep_run.get("FactorWeights", {}), dict) else {}

    facts_summary = re.sub(r"\s+", " ", str(extracted.get("facts_summary", "") or "")).strip()
    law_summary = re.sub(r"\s+", " ", str(extracted.get("law_summary", "") or "")).strip()
    facts_len = int(extracted.get("facts_len", 0) or 0)
    law_len = int(extracted.get("law_len", 0) or 0)

    if dossier_text and (not facts_summary or not law_summary):
        sections = extract_sections_text(dossier_text)
        if not facts_summary:
            facts_summary = re.sub(r"\s+", " ", str(sections.get("facts", "") or "")).strip()[:240]
            facts_len = max(facts_len, len(str(sections.get("facts", "") or "")))
        if not law_summary:
            law_summary = re.sub(r"\s+", " ", str(sections.get("law", "") or "")).strip()[:240]
            law_len = max(law_len, len(str(sections.get("law", "") or "")))

    claims: List[Dict[str, Any]] = []
    if facts_summary or facts_len > 0:
        citations = _rj_clean_explanation_fragments([facts_summary] if facts_summary else [])
        quality = _rj_support_quality_score(citations, dossier_text)
        claims.append({
            "id": "facts_context",
            "text": "Factual context of the surveillance measure",
            "claim_type": "context",
            "source": "facts",
            "citations": citations,
            "citation_strength": _rj_support_strength_label(quality),
            "quality_score": float(quality),
            "requires_support": True,
        })
    if law_summary or law_len > 0:
        citations = _rj_clean_explanation_fragments([law_summary] if law_summary else [])
        quality = _rj_support_quality_score(citations, dossier_text)
        claims.append({
            "id": "legal_basis",
            "text": "Legal basis and governing rule set",
            "claim_type": "context",
            "source": "law",
            "citations": citations,
            "citation_strength": _rj_support_strength_label(quality),
            "quality_score": float(quality),
            "requires_support": True,
        })

    ranked_factors: List[Tuple[str, Dict[str, Any]]] = []
    if isinstance(factor_weights, dict):
        ranked_factors = sorted(
            [
                (str(factor), meta if isinstance(meta, dict) else {})
                for factor, meta in factor_weights.items()
            ],
            key=lambda kv: (
                float((kv[1] or {}).get("effective_contribution", 0.0) or 0.0),
                float((kv[1] or {}).get("weight", 0.0) or 0.0),
            ),
            reverse=True,
        )
    active_factors = [
        (factor, meta)
        for factor, meta in ranked_factors
        if float(meta.get("effective_contribution", 0.0) or 0.0) > 0.0
        or float(meta.get("weight", 0.0) or 0.0) > 0.0
    ]
    for factor, meta in (active_factors[:4] if active_factors else []):
        citations: List[str] = []
        factor_citation = str(meta.get("citation", "") or "").strip()
        if factor_citation:
            citations.append(factor_citation)
        for feature in meta.get("mapped_features", []) or []:
            row = safeguards.get(feature, {}) if isinstance(safeguards.get(feature, {}), dict) else {}
            citations.extend(list(row.get("snippet", []) or [])[:2])
        citations = _rj_clean_explanation_fragments(citations)
        quality = _rj_support_quality_score(citations, dossier_text)
        claims.append({
            "id": f"factor_{factor.lower()}",
            "text": f"{str(meta.get('label', factor))} materially influenced the verdict",
            "claim_type": "factor",
            "source": factor,
            "weight": int(meta.get("weight", 0) or 0),
            "contribution": float(meta.get("effective_contribution", 0.0) or 0.0),
            "citations": citations,
            "citation_strength": _rj_support_strength_label(quality),
            "quality_score": float(quality),
            "requires_support": True,
        })

    support_claims = [c for c in claims if bool(c.get("requires_support", True))]
    claims_with_citations = sum(1 for c in support_claims if c.get("citations"))
    total_support_claims = len(support_claims)
    evidence_coverage = (
        float(claims_with_citations) / float(total_support_claims)
        if total_support_claims > 0 else 0.0
    )
    citation_quality = (
        sum(float(c.get("quality_score", 0.0) or 0.0) for c in support_claims) / float(total_support_claims)
        if total_support_claims > 0 else 0.0
    )
    return {
        "claims": claims,
        "evidence_coverage": float(round(evidence_coverage, 6)),
        "citation_quality": float(round(citation_quality, 6)),
        "total_claims": int(len(claims)),
        "claims_with_citations": int(claims_with_citations),
        "support_claims": int(total_support_claims),
    }


def compute_robo_explainability_metrics(contract: Dict[str, Any], dossier_text: str) -> Dict[str, Any]:
    """
    Compute explainability metrics from the structured Robo decision trace.

    The score is based primarily on structured reasoning artifacts:
    facts/law summaries, decisive factors, factor contributions, evidence snippets,
    and the score-threshold trace of the representative run.
    """

    verdict = contract.get("verdict", {}) if isinstance(contract.get("verdict", {}), dict) else {}
    reasoning = contract.get("reasoning_structured", {}) if isinstance(contract.get("reasoning_structured", {}), dict) else {}
    evidence = contract.get("evidence", {}) if isinstance(contract.get("evidence", {}), dict) else {}
    extracted = evidence.get("extracted_elements", {}) if isinstance(evidence.get("extracted_elements", {}), dict) else {}
    runs = contract.get("reruns", {}).get("runs", []) if isinstance(contract.get("reruns", {}), dict) else []
    rep_run = _rj_pick_representative_run(runs if isinstance(runs, list) else [], str(verdict.get("outcome", "") or ""))
    claims_analysis = _rj_structured_claims_analysis(contract, dossier_text)

    facts_summary = str(extracted.get("facts_summary", "") or "").strip()
    law_summary = str(extracted.get("law_summary", "") or "").strip()
    facts_len = int(extracted.get("facts_len", 0) or 0)
    law_len = int(extracted.get("law_len", 0) or 0)
    decisive_factors = reasoning.get("decisive_factors", []) if isinstance(reasoning.get("decisive_factors", []), list) else []
    factor_scores = reasoning.get("factor_scores", {}) if isinstance(reasoning.get("factor_scores", {}), dict) else {}
    factor_weights = reasoning.get("factor_weights", {}) if isinstance(reasoning.get("factor_weights", {}), dict) else {}
    perturbation = reasoning.get("perturbation_test", {}) if isinstance(reasoning.get("perturbation_test", {}), dict) else {}

    facts_score = 1.0 if (facts_summary and facts_len > 0) else (0.6 if facts_len > 0 else 0.0)
    law_score = 1.0 if (law_summary and law_len > 0) else (0.6 if law_len > 0 else 0.0)
    reasons_score = (
        (
            (1.0 if decisive_factors else 0.0)
            + (1.0 if factor_scores else 0.0)
            + (1.0 if rep_run and rep_run.get("TopReasons") else 0.0)
        ) / 3.0
    )
    quant_trace_score = (
        (
            (1.0 if rep_run and rep_run.get("DecisionScore") is not None else 0.0)
            + (1.0 if rep_run and rep_run.get("DecisionThreshold") is not None else 0.0)
            + (1.0 if rep_run and isinstance(rep_run.get("Components", []), list) and rep_run.get("Components") else 0.0)
            + (1.0 if factor_weights else 0.0)
            + (1.0 if perturbation and int(perturbation.get("FactorsTested", 0) or 0) > 0 else 0.0)
        ) / 5.0
    )
    verdict_trace_score = (
        (
            (1.0 if str(verdict.get("outcome", "") or "").strip() else 0.0)
            + (1.0 if verdict.get("confidence_score") is not None else 0.0)
        ) / 2.0
    )
    structure_completeness = (
        facts_score
        + law_score
        + reasons_score
        + quant_trace_score
        + float(claims_analysis.get("evidence_coverage", 0.0) or 0.0)
        + verdict_trace_score
    ) / 6.0

    evidence_coverage_score = float(claims_analysis.get("evidence_coverage", 0.0) or 0.0)
    evidence_quality_score = float(claims_analysis.get("citation_quality", 0.0) or 0.0)

    top_reasons = rep_run.get("TopReasons", []) if isinstance(rep_run, dict) and isinstance(rep_run.get("TopReasons", []), list) else []
    components = rep_run.get("Components", []) if isinstance(rep_run, dict) and isinstance(rep_run.get("Components", []), list) else []
    positive_components = [
        str(c.get("factor", "") or "")
        for c in sorted(
            [c for c in components if isinstance(c, dict)],
            key=lambda row: float(row.get("contribution", 0.0) or 0.0),
            reverse=True,
        )
        if float(c.get("contribution", 0.0) or 0.0) > 0.0
    ]
    feature_to_factor: Dict[str, str] = {}
    conceptual_rank = []
    for factor, meta in factor_weights.items():
        if not isinstance(meta, dict):
            continue
        conceptual_rank.append((
            str(factor),
            float(meta.get("effective_contribution", 0.0) or 0.0),
            float(meta.get("weight", 0.0) or 0.0),
        ))
        for feature in meta.get("mapped_features", []) or []:
            feature_to_factor[str(feature)] = str(factor)
    conceptual_rank.sort(key=lambda row: (row[1], row[2]), reverse=True)
    conceptual_top = [factor for factor, contrib, weight in conceptual_rank if contrib > 0.0 or weight > 0.0][:3]
    explained_factors = [str(c.get("source", "") or "") for c in claims_analysis.get("claims", []) if c.get("claim_type") == "factor"]
    supported_factors = {
        str(c.get("source", "") or "")
        for c in claims_analysis.get("claims", [])
        if c.get("claim_type") == "factor" and c.get("citations")
    }

    reason_alignment = _rj_overlap_score(top_reasons, positive_components[:max(1, len(top_reasons))])
    factor_alignment = _rj_overlap_score(conceptual_top, explained_factors)
    top_reason_support = (
        sum(1 for reason in top_reasons if feature_to_factor.get(str(reason)) in supported_factors) / float(max(1, len(top_reasons)))
        if top_reasons else (1.0 if supported_factors else 0.0)
    )

    score_alignment = 0.0
    outcome_alignment = 0.0
    if isinstance(rep_run, dict):
        score = float(rep_run.get("DecisionScore", 0.0) or 0.0)
        threshold = float(rep_run.get("DecisionThreshold", ROBO_BASE_THRESHOLD) or ROBO_BASE_THRESHOLD)
        allow_violation = bool(int(rep_run.get("AllowViolation", 0) or 0))
        component_sum = sum(float(c.get("contribution", 0.0) or 0.0) for c in components if isinstance(c, dict))
        denom = max(1.0, abs(score), abs(component_sum))
        score_alignment = 1.0 - min(1.0, abs(component_sum - score) / denom)
        expected_outcome = "V" if (score >= threshold and allow_violation) else "NV"
        outcome_alignment = 1.0 if expected_outcome == str(verdict.get("outcome", "") or "").upper().strip() else 0.0

    doctrinal_fidelity_score = (
        reason_alignment
        + factor_alignment
        + top_reason_support
        + score_alignment
        + outcome_alignment
    ) / 5.0

    # Robustness stays separate from explainability.
    stability_metrics = contract.get("reruns", {}).get("stability_metrics", {})
    disagreement_rate = float(stability_metrics.get("disagreement_rate", 0.5))
    robustness_index = 1.0 - disagreement_rate  # Higher stability = more robust

    overall_explainability = (
        structure_completeness
        + evidence_coverage_score
        + evidence_quality_score
        + doctrinal_fidelity_score
    ) / 4.0
    
    return {
        "structure_completeness": float(structure_completeness),
        "evidence_coverage_score": float(evidence_coverage_score),
        "evidence_quality_score": float(evidence_quality_score),
        "doctrinal_fidelity_score": float(doctrinal_fidelity_score),
        "robustness_index": float(robustness_index),
        "overall_explainability": float(overall_explainability),
        "claims_total": int(claims_analysis.get("total_claims", 0) or 0),
        "claims_with_citations": int(claims_analysis.get("claims_with_citations", 0) or 0),
    }


def render_robo_judge():
    st.header("Robo-Judge")
    st.caption(
        "Upload cleaned case files, enforce outcome-blindness checks, and run a rule-engine that produces an ECHR-style decision with transparency. "
        "This is a deterministic baseline to be replaced or complemented by an LLM later."
    )

    # Session-state store for redacted overrides
    if "rj_redacted_overrides" not in st.session_state:
        st.session_state["rj_redacted_overrides"] = {}
    if "rj_run_outputs" not in st.session_state:
        st.session_state["rj_run_outputs"] = {}

    def _rj_safe_key(s: str) -> str:
        s0 = re.sub(r"\s+", " ", str(s or "")).strip()
        s0 = "".join(c for c in s0 if c.isalnum() or c in (" ", "-", "_"))
        return s0.replace(" ", "_")

    def _rj_aggressive_redact(text: str) -> str:
        """Compatibility wrapper for the unified redaction pipeline."""
        redacted_text, _report, _leak = rj_redact_to_usable_text(text)
        return redacted_text

    def _rj_default_case_id(case_id: str, inferred_case: str, filename: str) -> str:
        if str(case_id or "").strip():
            return str(case_id).strip()
        if str(inferred_case or "").strip():
            return str(inferred_case).strip()
        base = os.path.splitext(str(filename or ""))[0].strip()
        return base or "case"

    def _rj_default_subunit(subunit_id: str, inferred_su: str) -> str:
        if str(subunit_id or "").strip():
            return str(subunit_id).strip()
        if str(inferred_su or "").strip():
            return str(inferred_su).strip()
        return "NA"

    def _rj_store_run_output(out_json: Dict[str, Any], case_id: str, subunit_id: str, filename: str) -> None:
        key = f"{case_id}||{subunit_id}||{filename}"
        st.session_state["rj_run_outputs"][key] = out_json

    def _rj_save_run_output(out_json: Dict[str, Any], case_id: str, subunit_id: str) -> str:
        stamp = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
        safe_case = safe_filename(case_id or "case") or "case"
        safe_su = safe_filename(subunit_id or "NA") or "NA"
        out_path = os.path.join(ROBO_BATCH_DIR, f"robo_case__{safe_case}__{safe_su}__{stamp}.json")
        with open(out_path, "w", encoding="utf-8") as f:
            json.dump(out_json, f, ensure_ascii=False, indent=2)
        return out_path

    # Batch controls (save + reset) and a resettable uploader key
    if "rj_uploader_nonce" not in st.session_state:
        st.session_state.rj_uploader_nonce = 0

    btn1, btn2, _sp = st.columns([1, 1, 6])

    with btn1:
        if st.button("Save current batch", key="rj_save_batch_btn"):
            runs_map = st.session_state.get("rj_run_outputs") or {}
            runs = list(runs_map.values())
            if not runs:
                st.warning("No Robo-Judge runs found. Run cases first to save a batch with outcomes.")
            else:
                runs.sort(key=lambda r: (str(r.get("InputPayload", {}).get("Case_ID", "")), str(r.get("InputPayload", {}).get("SubUnit_ID", ""))))
                stamp = datetime.utcnow().strftime("%Y%m%d_%H%M%S")
                out_path = os.path.join(ROBO_BATCH_DIR, f"robo_batch__{stamp}.json")
                with open(out_path, "w", encoding="utf-8") as f:
                    json.dump(runs, f, ensure_ascii=False, indent=2)
                st.success(f"Saved Robo-Judge run batch to: {out_path}")

    with btn2:
        if st.button("Reset batch", key="rj_reset_batch_btn"):
            st.session_state.rj_uploader_nonce = int(st.session_state.get("rj_uploader_nonce") or 0) + 1
            for k in ["rj_current_batch", "rj_last_selected"]:
                if k in st.session_state:
                    del st.session_state[k]
            st.rerun()

    st.subheader("Batch upload (recommended)")
    uploaded_files = st.file_uploader(
        "Upload cleaned case files (PDF/DOCX/TXT) - multiple allowed",
        type=["pdf", "docx", "txt"],
        accept_multiple_files=True,
        key=f"rj_uploader_{int(st.session_state.get('rj_uploader_nonce') or 0)}",
    )
    zip_upload = st.file_uploader(
        "Or upload a ZIP folder of case files",
        type=["zip"],
        accept_multiple_files=False,
        key=f"rj_zip_uploader_{int(st.session_state.get('rj_uploader_nonce') or 0)}",
    )

    class _RJBytesFile:
        def __init__(self, name: str, data: bytes) -> None:
            self.name = name
            self._data = data

        def getvalue(self) -> bytes:
            return self._data

    def _rj_collect_inputs() -> List[Any]:
        inputs: List[Any] = []
        for uf in (uploaded_files or []):
            inputs.append(uf)

        if zip_upload is not None:
            try:
                zbytes = zip_upload.getvalue()
                with zipfile.ZipFile(io.BytesIO(zbytes), "r") as z:
                    for n in z.namelist():
                        if n.endswith("/"):
                            continue
                        ext = os.path.splitext(n)[1].lower().strip()
                        if ext not in (".pdf", ".docx", ".txt"):
                            continue
                        inputs.append(_RJBytesFile(os.path.basename(n), z.read(n)))
            except Exception as e:
                st.error(f"ZIP read failed: {e}")

        return inputs

    batch_inputs = _rj_collect_inputs()

    if not batch_inputs:
        st.info(
            "Upload at least one cleaned case file to begin. Filenames can encode subunits, e.g., \"Malone v. United Kingdom__A.pdf\"."
        )
        return

    batch: List[Dict[str, Any]] = []
    for uf in batch_inputs:
        inferred_case, inferred_su = rj_infer_case_and_subunit_from_filename(getattr(uf, "name", ""))
        try:
            txt = rj_extract_text_from_upload(uf)
            # If this filename was previously redacted/overwritten, reuse that text across reruns.
            ov_saved: Optional[Dict[str, Any]] = None
            try:
                overrides = st.session_state.get("rj_redacted_overrides") or {}
                if isinstance(overrides, dict):
                    ov = overrides.get(getattr(uf, "name", ""))
                    if isinstance(ov, dict) and isinstance(ov.get("text"), str) and ov.get("text").strip():
                        ov_text = str(ov.get("text") or "")
                        if rj_redaction_needs_cleanup(ov_text) or not bool(rj_outcome_leak_check(ov_text).get("ok")):
                            repaired_text, repaired_report, repaired_leak = rj_redact_to_usable_text(txt)
                            if repaired_text.strip():
                                ov = {
                                    **ov,
                                    "text": repaired_text,
                                    "redacted_ok": bool(repaired_leak.get("ok")),
                                    "redact_attempts": int(ov.get("redact_attempts", 0) or 0) + 1,
                                    "repair_report": repaired_report,
                                }
                                overrides[getattr(uf, "name", "")] = ov
                                st.session_state["rj_redacted_overrides"] = overrides
                                txt = repaired_text
                                ov_saved = ov
                            else:
                                txt = ov_text
                                ov_saved = ov
                        else:
                            txt = ov_text
                            ov_saved = ov
            except Exception:
                pass
        except Exception as e:
            batch.append(
                {
                    "filename": getattr(uf, "name", ""),
                    "inferred_case": inferred_case,
                    "inferred_su": inferred_su,
                    "text_len": 0,
                    "leak_ok": False,
