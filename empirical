        return

    robo_batch_files = list_saved_robo_batches()

    if not robo_batch_files:
        st.info("No saved Robo-Judge batches found. Run the Robo-Judge first.")
        return

    selected_robo_file = st.selectbox(
        "Select saved Robo-Judge batch",
        options=robo_batch_files,
        format_func=lambda f: f.replace("robo_batch__", "").replace(".json", ""),
        key="side_by_side_batch_select",
    )

    batch_path = os.path.join(ROBO_BATCH_DIR, selected_robo_file)
    try:
        with open(batch_path, "r", encoding="utf-8") as f:
            robo_batch = json.load(f)
    except Exception as e:
        st.error(f"Failed to load Robo batch: {e}")
        return

    if not isinstance(robo_batch, list):
        st.error("Robo batch format unexpected.")
        return
    robo_batch = [_rj_enrich_saved_item(item) if isinstance(item, dict) else item for item in robo_batch]

    # Human metrics map
    human_metrics_rows = build_human_metrics_rows(human_rows)
