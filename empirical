def compute_axis1_consistency_gap(
    rows: List[Dict[str, Any]],
    method: str,
    sim_threshold: float,
    knn_k: int,
    missing_mode: str,
    min_overlap: int,
    require_same_type: bool,
    require_same_posture: bool,
    require_same_trigger: bool,
    min_cluster_size: int,
) -> Dict[str, Any]:
    """Late-bound wrapper to avoid NameError before full definition loads."""
    impl = globals().get("_compute_axis1_consistency_gap_impl")
    if callable(impl):
        return impl(
            rows=rows,
            method=method,
            sim_threshold=sim_threshold,
            knn_k=knn_k,
            missing_mode=missing_mode,
            min_overlap=min_overlap,
            require_same_type=require_same_type,
            require_same_posture=require_same_posture,
            require_same_trigger=require_same_trigger,
            min_cluster_size=min_cluster_size,
        )

    weights = {
        "InterferenceType_Primary": 3.0,
        "ReviewPosture": 3.0,
        "ContextTrigger": 2.0,
        "IndepPriorAuth": 2.0,
        "ExecOnlyAuth": 1.5,
        "SelectorCategoriesConstrained": 1.0,
        "PersonLinkedSelectorsPreAuth": 1.0,
        "IndepOversight": 2.0,
        "ExPostReview": 1.5,
        "Notification": 1.0,
        "RetentionLimits": 1.5,
        "AccessLogging": 1.0,
        "DestructionRules": 1.0,
        "SharingRules_ForeignPartners": 1.0,
        "RemedyAccess": 1.5,
        "RemedyEffectiveness": 1.0,
        "Flag_Journalist": 0.5,
        "Flag_LawyerPrivilege": 0.5,
        "Flag_ThirdPartyCapture": 0.5,
    }
    axis1_anchors = ["InterferenceType_Primary", "ReviewPosture", "ContextTrigger"]
    axis1_safeguards = [
        "IndepPriorAuth",
        "ExecOnlyAuth",
        "SelectorCategoriesConstrained",
        "PersonLinkedSelectorsPreAuth",
        "IndepOversight",
        "ExPostReview",
        "Notification",
        "RetentionLimits",
        "AccessLogging",
        "DestructionRules",
        "SharingRules_ForeignPartners",
        "RemedyAccess",
    ]

    def _encode_yesno(v: Any) -> float:
        s = str(v or "").upper().strip()
        if s == "YES":
            return 1.0
        if s == "NO":
            return 0.0
        if s == "PART":
            return 0.5
        return 0.5

    def _encode_remedy(v: Any) -> float:
        s = str(v or "").upper().strip()
        if s == "EFF":
            return 1.0
        if s == "NONE":
            return 0.0
        if s == "LIM":
            return 0.5
        return 0.5

    def _outcome_binary(row: Dict[str, Any]) -> int:
        o = str(row.get("Art8_Outcome", "")).upper().strip()
        if o in ("V", "P", "NV"):
            return 0 if o == "NV" else 1
        try:
            return int(row.get("Art8_BinaryAnyViolation") or 0)
        except Exception:
            return 1

    def _sim_cat(a: Any, b: Any) -> float:
        return 1.0 if str(a) == str(b) else 0.0

    def _sim_num(a: float, b: float) -> float:
        return 1.0 - abs(a - b)

    def _pair_similarity(a: Dict[str, Any], b: Dict[str, Any]) -> float:
        sims: List[float] = []
        wsum = 0.0
        overlap = 0
        for key in axis1_anchors:
            w = float(weights.get(key, 1.0))
            sims.append(w * _sim_cat(a.get(key), b.get(key)))
            wsum += w
        for key in axis1_safeguards:
            va, vb = a.get(key), b.get(key)
            if missing_mode == "skip" and (str(va or "").upper().strip() in ("", "UNK") or str(vb or "").upper().strip() in ("", "UNK")):
                continue
            overlap += 1
            w = float(weights.get(key, 1.0))
            sims.append(w * _sim_num(_encode_yesno(va), _encode_yesno(vb)))
            wsum += w
        va, vb = a.get("RemedyEffectiveness"), b.get("RemedyEffectiveness")
        if not (missing_mode == "skip" and (str(va or "").upper().strip() in ("", "UNK") or str(vb or "").upper().strip() in ("", "UNK"))):
            overlap += 1
            w = float(weights.get("RemedyEffectiveness", 1.0))
            sims.append(w * _sim_num(_encode_remedy(va), _encode_remedy(vb)))
            wsum += w
        for key in ["Flag_Journalist", "Flag_LawyerPrivilege", "Flag_ThirdPartyCapture"]:
            w = float(weights.get(key, 0.5))
            try:
                sims.append(w * _sim_cat(int(a.get(key, 0)), int(b.get(key, 0))))
            except Exception:
                sims.append(w * _sim_cat(a.get(key), b.get(key)))
            wsum += w
        if min_overlap and overlap < int(min_overlap):
            return -1.0
        return (sum(sims) / wsum) if wsum else -1.0

    def _union_find_clusters(n: int, edges: List[Tuple[int, int]]) -> List[List[int]]:
        parent = list(range(n))
        rank = [0] * n

        def find(x: int) -> int:
            while parent[x] != x:
                parent[x] = parent[parent[x]]
                x = parent[x]
            return x

        def union(x: int, y: int) -> None:
            rx, ry = find(x), find(y)
            if rx == ry:
                return
            if rank[rx] < rank[ry]:
                parent[rx] = ry
            elif rank[rx] > rank[ry]:
                parent[ry] = rx
            else:
                parent[ry] = rx
                rank[rx] += 1

        for i, j in edges:
            union(i, j)
        groups: Dict[int, List[int]] = {}
        for i in range(n):
            root = find(i)
            groups.setdefault(root, []).append(i)
        return list(groups.values())

    def _bernoulli_variance(p: float) -> float:
        return p * (1.0 - p)

    def _disagreement_rate(p: float) -> float:
        return 1.0 - max(p, 1.0 - p)

    def _entropy(p: float) -> float:
        eps = 1e-12
        p = min(max(p, eps), 1.0 - eps)
        return -p * math.log(p, 2) - (1.0 - p) * math.log(1.0 - p, 2)

    def eligible(a: Dict[str, Any], b: Dict[str, Any]) -> bool:
        if require_same_type and a.get("InterferenceType_Primary") != b.get("InterferenceType_Primary"):
            return False
        if require_same_posture and a.get("ReviewPosture") != b.get("ReviewPosture"):
            return False
        if require_same_trigger and a.get("ContextTrigger") != b.get("ContextTrigger"):
            return False
        return True

    n = len(rows)
    edges: List[Tuple[int, int]] = []
    sims_all: List[float] = []
    eligible_pairs = 0
    edge_count = 0

    if method == "threshold":
        for i in range(n):
            for j in range(i + 1, n):
                if not eligible(rows[i], rows[j]):
                    continue
                eligible_pairs += 1
                sim = _pair_similarity(rows[i], rows[j])
                if sim < 0:
                    continue
                sims_all.append(sim)
                if sim >= float(sim_threshold):
                    edges.append((i, j))
                    edge_count += 1
    elif method == "knn":
        k = max(1, int(knn_k))
        for i in range(n):
            scored: List[Tuple[float, int]] = []
            for j in range(n):
                if i == j:
                    continue
                if not eligible(rows[i], rows[j]):
                    continue
                eligible_pairs += 1
                sim = _pair_similarity(rows[i], rows[j])
                if sim < 0:
                    continue
                sims_all.append(sim)
                if sim >= float(sim_threshold):
                    scored.append((sim, j))
            scored.sort(key=lambda item: item[0], reverse=True)
            for _score, j in scored[:k]:
                ii, jj = (i, j) if i < j else (j, i)
                if (ii, jj) not in edges:
                    edges.append((ii, jj))
                    edge_count += 1
    else:
        raise ValueError("Unknown clustering method")

    components_all = _union_find_clusters(n, edges)
    singletons = sum(1 for cluster in components_all if len(cluster) == 1)
    clusters = [cluster for cluster in components_all if len(cluster) >= int(min_cluster_size)]
    clusters.sort(key=len, reverse=True)

    y_all = [_outcome_binary(r) for r in rows]
    p_all = (sum(y_all) / len(y_all)) if y_all else 0.0
    overall_var = _bernoulli_variance(p_all)

    cluster_stats: List[Dict[str, Any]] = []
    for idx_c, members in enumerate(clusters, start=1):
        ys = [_outcome_binary(rows[idx]) for idx in members]
        p = (sum(ys) / len(ys)) if ys else 0.0
        cluster_stats.append({
            "cluster": idx_c,
            "size": len(members),
            "p_any_violation": round(p, 3),
            "variance": round(_bernoulli_variance(p), 4),
            "disagreement": round(_disagreement_rate(p), 4),
            "entropy": round(_entropy(p), 4),
            "cases": [rows[idx].get("Case_ID", f"case_{idx}") for idx in members],
        })

    consistency_gap: Optional[float] = None
    if cluster_stats:
        total = float(sum(row["size"] for row in cluster_stats))
        consistency_gap = sum(float(row["variance"]) * float(row["size"]) for row in cluster_stats) / total

    return {
        "n_rows": n,
        "eligible_pairs": eligible_pairs,
        "edges": edge_count,
        "edges_list": list(edges),
        "components_total": len(components_all),
        "singletons": singletons,
        "n_clusters": len(cluster_stats),
        "overall_var": overall_var,
        "consistency_gap": consistency_gap,
        "cluster_stats": cluster_stats,
        "clusters": clusters,
        "pair_sims": sims_all,
        "sim_mean": (sum(sims_all) / len(sims_all)) if sims_all else 0.0,
        "sim_min": min(sims_all) if sims_all else 0.0,
        "sim_max": max(sims_all) if sims_all else 0.0,
    }



