def infer_doctrinal_steps_from_text(text: str) -> Dict[str, int]:
    sec = extract_sections_text(text or "")
    primary_sources = _unique_text_sources([str(sec.get("law") or "")], [str(sec.get("operative") or "")])
    secondary_sources = _unique_text_sources([str(sec.get("facts") or "")], [str(text or "")])
    scope = "\n".join(primary_sources) if primary_sources else "\n".join(secondary_sources)
    ev_score, ev_breakdown, _first_pos = _step_evidence_coverage(scope)

    steps = {k: int(v) for k, v in ev_breakdown.items()}
    fallback_scope = _norm_text_for_search("\n".join(_unique_text_sources(primary_sources, secondary_sources))).lower()

    if steps.get("Step_Interference", 0) == 0 and any(
        token in fallback_scope for token in ["article 8", "private life", "correspondence", "home", "surveillance", "interception"]
    ):
        steps["Step_Interference"] = 1
    if steps.get("Step_Lawfulness", 0) == 0 and any(
        token in fallback_scope for token in ["accessible", "foreseeable", "quality of the law", "in accordance with the law"]
    ):
        steps["Step_Lawfulness"] = 1
    if steps.get("Step_LegitimateAim", 0) == 0 and any(
        token in fallback_scope for token in ["legitimate aim", "national security", "prevention of crime", "public safety", "economic well-being"]
    ):
        steps["Step_LegitimateAim"] = 1
    if steps.get("Step_Necessity", 0) == 0 and any(
        token in fallback_scope for token in [
            "necessary in a democratic society",
            "proportion",
            "fair balance",
            "pressing social need",
            "adequate and effective safeguards",
            "end to end safeguards",
        ]
    ):
        steps["Step_Necessity"] = 1

    if ev_score <= 0.0 and "article 8" in fallback_scope:
        steps["Step_Interference"] = max(1, int(steps.get("Step_Interference", 0) or 0))

    return {
        "Step_Interference": int(steps.get("Step_Interference", 0) or 0),
        "Step_Lawfulness": int(steps.get("Step_Lawfulness", 0) or 0),
        "Step_LegitimateAim": int(steps.get("Step_LegitimateAim", 0) or 0),
        "Step_Necessity": int(steps.get("Step_Necessity", 0) or 0),
    }


